  updatedAt DateTime @updatedAt

  @@map("talent_ops_checklists")
}

enum NegotiationStatus {
  OPEN
  COUNTERED
  AGREED
  DECLINED
  WITHDRAWN
}

// Negotiation Management (SYS-10 V2.0 Г‚В§7) Гўв‚¬вЂќ sits between the Offer and the Deal Memo.
model TalentNegotiation {
  id           String            @id @default(cuid())
  submissionId String            @unique
  submission   Submission        @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  status       NegotiationStatus @default(OPEN)
  currency     Currency          @default(AED)

  // Financial
  initialOffer Decimal? @db.Decimal(14, 2)
  counterOffer Decimal? @db.Decimal(14, 2)
  finalRate    Decimal? @db.Decimal(14, 2)

  // Terms
  travelClass           String? // ECONOMY | BUSINESS | FIRST
  accommodationTier     String? // STANDARD | EXECUTIVE | SUITE
  perDiem               Decimal? @db.Decimal(12, 2)
  buyout                String?
  exclusivity           String?
  marketingRequirements String?
  notes                 String?

  // Append-only history of rounds: [{ at, by, type, amount, note }]
  rounds Json?

