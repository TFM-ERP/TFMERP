  isOffScreen     Boolean     @default(false) // straight (on-screen) vs wavy/dashed (off-screen)
  cameras         Json?       // SYS-13b P4 вЂ” multi-camera slate [{ label, color, onScreen }] (в‰¤26)
  slateFormat     String?     // ALPHA | NUMERIC | DECIMAL
  createdById     String?
  createdAt       DateTime    @default(now())

  takes TakeLog[]

