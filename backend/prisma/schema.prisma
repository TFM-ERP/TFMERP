// -- SYS-13 . D1 -- Digital Script & Document Hub: document/revision/scene spine --
// A script belongs to a project; each upload is a Revision (White/Blue/PinkвЂ¦). On upload the
// backend extracts per-page text (pdf-parse) and parses sluglines into ScriptScene rows (the FK
// target for annotations + lining). pdfUrl is a local /uploads path (served via assetUrl).
model ScriptDocument {
  id               String   @id @default(cuid())
  projectId        String
  title            String   // e.g. "Episode 101"
  kind             String   @default("SCRIPT") // SCRIPT | SIDES | ONELINER | OTHER
  activeRevisionId String?  // the revision currently shown
  masterScriptId   String?  // SYS-13b P5 вЂ” optional link to a library MasterScript
  createdById      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  revisions    ScriptRevision[]
  layers       AnnotationLayer[]
  masterScript MasterScript? @relation(fields: [masterScriptId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([masterScriptId])
  @@map("script_documents")
}

// SYS-13b P5 вЂ” Standalone Script Library master (mirrors MasterLocation в†’ Location).
// A company-level script linkable into many projects; carries reusable palettes.
model MasterScript {
  id           String   @id @default(cuid())
  code         String?  @unique // optional human ref e.g. SCR-0001
  title        String
  logline      String?
  kind         String   @default("FEATURE") // FEATURE | SERIES | SHORT | OTHER
  writer       String?
  status       String   @default("DEVELOPMENT") // DEVELOPMENT | ACTIVE | ARCHIVED
  summary      String?
  tags         Json? // ["action","period"]
  tagPalette   Json? // reusable TagCategory seed [{ key,label,color,sortOrder,breakdownCategory,budgetCode }]
  voicePalette Json? // saved character voices [{ character, voiceURI, rate, pitch }]
  timesUsed    Int      @default(0)
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  revisions  MasterScriptRevision[]
  linkedDocs ScriptDocument[]

  @@map("master_scripts")
}

model MasterScriptRevision {
  id             String       @id @default(cuid())
  masterScriptId String
  masterScript   MasterScript @relation(fields: [masterScriptId], references: [id], onDelete: Cascade)
  revisionLabel  String       // "White" | "Blue" | "v3"вЂ¦
  colorCode      String?
  pdfUrl         String       // /uploads/<file>
  pageCount      Int          @default(0)
  pageText       Json?        // [{ page, text }]
  scenes         Json?        // [{ sceneNumber, slugline, intExt, dayNight, pageStart, pageEnd, charStart }]
  uploadedById   String?
  createdAt      DateTime     @default(now())

  @@index([masterScriptId])
  @@map("master_script_revisions")
}

// SYS-13b P6 вЂ” browser-recorded voice memos attached to a revision (optionally a page).
model ScriptAudioNote {
  id          String   @id @default(cuid())
  revisionId  String
  page        Int?
  label       String?
  audioUrl    String // /uploads/<file>
  durationSec Int?
  createdById String?
  createdAt   DateTime @default(now())

