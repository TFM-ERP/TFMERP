  value              Decimal    @db.Decimal(12, 5)
  base               RateBase?
  capPeriod          CapPeriod?
  capAmount          Decimal?   @db.Decimal(14, 2)
  floorAmount        Decimal?   @db.Decimal(14, 2)
  tiers              Json?
  currency           String     @default("USD")
  glAccountCode      String?
  isEstimate         Boolean    @default(false)
  overrideReason     String? // when an accountant changes a value at snapshot
  enabled            Boolean    @default(true)

  // provenance carried into the project
  sourceTitle   String?
  sourceUrl     String?
  effectiveDate DateTime?
  frozenAt      DateTime  @default(now())

  @@index([projectId])
  @@map("project_rate_rules")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Production incentives & tax credits ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

enum IncentiveType {
  TAX_CREDIT
  REBATE
  CASH_REBATE
  GRANT
  EXEMPTION
}

model IncentiveProgram {
  id              String        @id @default(cuid())
  geoNodeId       String?
  geoNode         GeoNode?      @relation(fields: [geoNodeId], references: [id])
  name            String // "Georgia Film Tax Credit"
  authority       String? // "Georgia Dept. of Revenue"
  incentiveType   IncentiveType @default(TAX_CREDIT)
  ratePct         Decimal       @db.Decimal(6, 4) // fraction, e.g. 0.30
  basis           String        @default("QUALIFIED") // TOTAL | BTL | LABOR | WAGES | QUALIFIED
  minSpend        Decimal?      @db.Decimal(15, 2)
  capAmount       Decimal?      @db.Decimal(15, 2)
  upliftPct       Decimal?      @db.Decimal(6, 4) // optional bonus (e.g. GA logo uplift)
  transferable    Boolean       @default(false)
  refundable      Boolean       @default(false)
  currency        String        @default("USD")
  productionTypes Json? // applicability
  sourceTitle     String?
  sourceUrl       String?
  effectiveDate   DateTime?
  expirationDate  DateTime?
  isEstimate      Boolean       @default(true)
  isActive        Boolean       @default(true)
  notes           String?
  // Audit & eligibility conditions per the issuing authority's rules Гўв‚¬вЂќ drives the
  // project-entity trial balance / audit-pack enforcement (doc 18 Г‚В§5.4):
  // { auditRequired, auditorRequirement, auditDeadlineDays, dedicatedBankAccount,
  //   localEntityRequired, qualifyingSpendRules, eligibilityConditions[] }
  complianceRules Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([geoNodeId])
  @@map("incentive_programs")
}

model IncentiveClaim {
  id          String            @id @default(cuid())
