// ГўвЂќв‚¬ГўвЂќв‚¬ Production: Projects ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model ProductionProject {
  id            String           @id @default(cuid())
  projectNumber String           @unique // PRD-2024-0001
  title         String
  clientId      String?
  client        Client?          @relation(fields: [clientId], references: [id])
  projectType   String           @default("TVC") // TVC | CORPORATE | DOCUMENTARY | FEATURE | SHORT | MUSIC_VIDEO | OTHER
  status        ProductionStatus @default(DEVELOPMENT)

  startDate      DateTime?
  endDate        DateTime?
  shootStartDate DateTime?
  shootEndDate   DateTime?

  currency    Currency @default(AED)
  totalBudget Decimal? @db.Decimal(15, 2) // computed from active budget version

  // Production jurisdiction Гўв‚¬вЂќ drives JurisdictionTaxRule resolution and AI context.
  // Optional at DB level so `db push` works on existing data; MANDATORY at app level
  // (DynamicContextService refuses to run without it; seed-jurisdiction.js backfills).
  productionCountryId String?
  productionCountry   GeoNode? @relation("ProjectProductionCountry", fields: [productionCountryId], references: [id])
  emailSettings Json? // per-project email sender { enabled, smtp:{...} }
  logoUrl     String? // project / studio logo (shown next to company logo on reports)
  posterUrl       String? // tile poster (projects grid branding image)
  posterTransform Json?   // tile framing: { x, y, zoom, rotation } from the Identity & branding editor

  description String?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  budgetVersions BudgetVersion[]
  crew           ProductionCrew[]
  schedules      ProductionSchedule[]
  callSheets     CallSheet[]
  perDiems       PerDiem[]
  overages       Overage[]
  creditRoll     CreditRoll?
  transactions   ProjectTransaction[]
  vendors        ProductionVendor[]
  purchaseOrders PurchaseOrder[]
  costSnapshots  CostReportSnapshot[]
  pettyCashFloats PettyCashFloat[]
  strips         ProductionStrip[]
  breakdownElements BreakdownElement[]
  documents      ProjectDocument[]
  laborConfig    ProjectLaborConfig?
  projectRateRules ProjectRateRule[]
  incentives     ProjectIncentive[]
  incentiveClaims IncentiveClaim[]
  timecards      Timecard[]
  locations      Location[]
  budgetTransfers BudgetTransfer[]
  pendingVendors  PendingVendor[]
  budgetLifecycleLogs BudgetLifecycleLog[]
  globalsStaging      ProjectGlobalsStaging?
  bankAccounts        BankAccount[] // dedicated production account(s) Гўв‚¬вЂќ audit trail
  ledgerBankAccounts  LedgerBankAccount[] // reconciliation side of the dedicated account
  roleAssignments     ProjectRoleAssignment[] // per-project authorization layer (V1.2)
  breakdownShares     BreakdownShare[] @relation("ProjectBreakdownShares")

  // Per-diem rate defaults (project currency)
  perDiemInternational Decimal? @db.Decimal(12, 2)
  perDiemDomestic      Decimal? @db.Decimal(12, 2)

  // The single corporate/house entity that owns standalone (project-less) postings.
  isHouse Boolean @default(false)

  // Travel / Contracts / Casting modules
  trips             Trip[]
  contracts         ProjectContract[]
  castingCalls      CastingCall[]
  characterProfiles CharacterProfile[]
  consentLogs       ConsentLog[]
  talentReviews     TalentPerformanceReview[]
  accommodationAssignments AccommodationAssignment[]
  transportVehicles        TransportVehicle[]
  transportOrders          TransportOrder[]
  shuttleRoutes            ShuttleRoute[]
  arrivals                 TravelArrival[]
  fuelLogs                 FuelLog[]

  @@index([productionCountryId])
  @@map("production_projects")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Production Globals staging ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
// Holding area for schedule/rate globals captured during setup or import.
// Nothing here touches a budget version until an explicit, user-approved "push"
// writes the values into the WORKING version's BudgetGlobals (LOCKED versions
// are never written).
model ProjectGlobalsStaging {
  id        String            @id @default(cuid())
  projectId String            @unique
  project   ProductionProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  prepDays  Int?
  shootDays Int?
  wrapDays  Int?
  crewCount Int?
  eurToAed  Decimal? @db.Decimal(14, 6) // 1 EUR in AED
  usdToAed  Decimal? @db.Decimal(14, 6) // 1 USD in AED

  status            String    @default("DRAFT") // DRAFT | PUSHED
  pushedAt          DateTime?
  pushedToVersionId String? // BudgetVersion that received the values
  doodTallies       Json? // aggregate DOOD counts per category { generatedAt, categories: { CAST: {elements, workDays, holdDays}, Гўв‚¬В¦ } }
  notes             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("project_globals_staging")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ External CoA ГўвЂ вЂ™ Master Chart of Accounts mapping ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
// Maps imported account codes (Movie Magic, legacy ledgersГўв‚¬В¦) onto the enterprise
// Master CoA so imports and AI suggestions always resolve to real account codes.
model CoaMappingTable {
  id            String  @id @default(cuid())
  sourceSystem  String  @default("MOVIE_MAGIC") // MOVIE_MAGIC | LEGACY | OTHER
  externalCode  String // the code as it appears in the import
  externalLabel String? // description from the source file
  masterCode    String // Master CoA account code (e.g. "1100", "2310")
  masterTitle   String? // denormalised title for display / AI context
  isActive      Boolean @default(true)
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sourceSystem, externalCode])
  @@index([masterCode])
  @@map("coa_mapping_table")
}

enum LocationType {
  INT
  EXT
  STUDIO
  BACKLOT
  OTHER
}

enum LocationStatus {
  SCOUTING
  OPTION
  CONFIRMED
  RELEASED
}

// ГўвЂќв‚¬ГўвЂќв‚¬ SYS-07 Master Location Library ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
// A MasterLocation is a permanent COMPANY asset (no projectId). Projects link to
// it via the Location model (the per-project usage record). History accretes here.
enum MasterLocationStatus {
  PROSPECT // identified, not yet vetted
  LIBRARY // vetted, available to link
  PREFERRED // proven, go-to
  RESTRICTED // usable with caveats
  BLACKLISTED // do not use
  ARCHIVED
}

model MasterLocation {
  id      String               @id @default(cuid())
  code    String?              @unique // optional human ref e.g. LOC-0001
  name    String
  aliases Json? // ["Old Souk", "Heritage Village"]
  category LocationType        @default(EXT)
  subType  String? // Villa | Warehouse | Desert | Mosque | Office | Beach Гўв‚¬В¦
  status   MasterLocationStatus @default(LIBRARY)
  summary  String? // short scouting description
  tags     Json? // ["desert","period","sand-dunes","sunset"]

  // Geography
  country       String?  @default("United Arab Emirates")
  region        String? // emirate / state / province
  city          String?
  district      String?
  fullAddress   String?
  lat           Decimal? @db.Decimal(10, 7)
  lng           Decimal? @db.Decimal(10, 7)
  googleMapsUrl String?
  what3words    String?
  timezone      String?

  // Access & logistics (permanent attributes)
  accessNotes    String?
  parkingNotes   String?
  basecampNotes  String?
  nearestAirport String?
  driveTimeNotes String?

  // Technical (permanent attributes)
  powerAvailable  Boolean? // mains power on site
  powerNotes      String?
  internetNotes   String?
  cellularNotes   String?
  waterAvailable  Boolean?
  soundNotes      String? // ambient noise, flight paths, traffic
  ceilingHeightM  Decimal? @db.Decimal(6, 2)
  floorAreaSqm    Decimal? @db.Decimal(12, 2)

  // Restrictions & ownership (permanent)
  ownerName      String?
  ownerCompany   String?
  ownerPhone     String?
  ownerEmail     String?
  agentName      String?
  agentPhone     String?
  restrictions   String? // filming hours, no-fly, religious, heritage
  permitAuthority String? // default permitting body for this place
  standardFee    Decimal? @db.Decimal(14, 2)
  feeCurrency    String   @default("AED")
  feeNotes       String?

  // Safety (permanent)
  nearestHospitalName    String?
  nearestHospitalAddress String?
  nearestHospitalPhone   String?
  safetyNotes            String?

  // Aggregated production history (accreted from project usage)
  timesUsed        Int      @default(0)
  lastUsedAt       DateTime?
  totalSpentToDate Decimal  @db.Decimal(16, 2) @default(0)
  avgFeePerDay     Decimal? @db.Decimal(14, 2)
  historyNotes     String? // recurring issues / lessons learned

  notes String?

  media     LocationMedia[]
  usages    Location[] // per-project usage records linked back here

  // SYS-07 slice 7 Гўв‚¬вЂќ operational records held DIRECTLY on the library asset
  // (standalone module use, independent of any project).
  documents LocationDocument[]
  permits   LocationPermit[]
  security  LocationSecurity[]
  payments  LocationPayment[]

  createdById String?
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([country, region])
  @@map("master_locations")
}

enum LocationMediaType {
  PHOTO
  VIDEO
  PANO360
  DRONE
  FLOORPLAN
  CAD
  DOCUMENT
}

model LocationMedia {
  id               String          @id @default(cuid())
  masterLocationId String
  masterLocation   MasterLocation  @relation(fields: [masterLocationId], references: [id], onDelete: Cascade)

  type      LocationMediaType @default(PHOTO)
  url       String // /uploads/<file> or external URL
  thumbnailUrl String?
  caption   String?
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)
  capturedAt DateTime?
  uploadedById String?
  createdAt DateTime @default(now())

  @@index([masterLocationId])
  @@map("location_media")
}

model Location {
  id        String            @id @default(cuid())
  projectId String
  project   ProductionProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // SYS-07: link to the permanent master library asset (null = legacy/unlinked)
  masterLocationId String?
  masterLocation   MasterLocation? @relation(fields: [masterLocationId], references: [id])

  // per-project usage detail
  scenes    String? // scene numbers shot here
  shootStart DateTime?
  shootEnd   DateTime?

  // SYS-07 slice 3 Гўв‚¬вЂќ assessment
  techRecces  TechRecce[]
  evaluations LocationEvaluation[]

  // SYS-07 slice 4 Гўв‚¬вЂќ permits & risk
  permits LocationPermit[]
  risks   LocationRisk[]

  // SYS-07 slice 6 Гўв‚¬вЂќ LM document vault & pipeline (from the location-manager mailbox study)
  documents     LocationDocument[]
  pipelineStage LocationStage @default(SOURCING)

  // SYS-07 slice 7 Гўв‚¬вЂќ permits-as-workload, security, payments (mailbox evidence)
  security LocationSecurity[]
  payments LocationPayment[]

  name   String
  type   LocationType   @default(EXT)
  status LocationStatus @default(SCOUTING)

  // Geography (drives per-diem + call sheet)
  country     String? @default("United Arab Emirates")
  emirate     String? // Dubai, Abu Dhabi, Sharjah, Ajman, RAK, Fujairah, UAQ Гўв‚¬вЂќ or city
  area        String?
  fullAddress String?
  lat         Decimal? @db.Decimal(10, 7)
  lng         Decimal? @db.Decimal(10, 7)
  googleMapsUrl String?
  what3words  String?

  // People
  locationManagerId   String?
  locationAssistantId String?
  ownerContactName    String?
  ownerPhone          String?
  ownerEmail          String?

  // Logistics
  parkingNotes  String?
  basecampNotes String?
  accessNotes   String?
  facilities    Json? // { power, water, toilets, wifi }
  restrictions  String?

  // Safety
  nearestHospitalName    String?
  nearestHospitalAddress String?
  nearestHospitalPhone   String?

  // Money & compliance
  locationFeePerDay Decimal? @db.Decimal(14, 2)
  currency          String   @default("AED")
  permitRequired    Boolean  @default(false)
  permitStatus      String? // NONE | APPLIED | APPROVED | REJECTED
  permitNumber      String?
  permitExpiry      DateTime?
  permitDocUrl      String?

  photoUrls    Json?
  documentUrls Json?
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([masterLocationId])
  @@map("locations")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ SYS-07 V2 slice 1 Гўв‚¬вЂќ Location Needs (script location) ГўвЂ вЂ™ candidate Options ГўвЂ вЂ™ Lock ГўвЂќв‚¬ГўвЂќв‚¬
// projectId is a plain indexed FK (no Prisma relation), mirroring ScoutAssignment, so
// ProductionProject/Location stay untouched. null projectId = master/library scope (S9).
model LocationNeed {
  id               String   @id @default(cuid())
  projectId        String?
  name             String   // the script location string вЂ” join key to ProductionStrip.location
  intExt           String?
  sceneRefs        String?  // denormalized scene numbers (from the breakdown)
  brief            String?
  visualRefs       Json?    // mood-board image URLs / references
  requiredBy       DateTime?
  status           String   @default("SOURCING") // SOURCING | OPTIONS | LOCKED
  selectedOptionId String?
  // SYS-07 V2 Slice 6 вЂ” director sign-off on the option-comparison deck (gate before LOCK)
  signOffStatus    String   @default("PENDING") // PENDING | APPROVED | REJECTED
  signOffBy        String?
  signOffAt        DateTime?
  signOffNote      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  options          LocationNeedOption[]

  @@index([projectId])
  @@map("location_needs")
}

model LocationNeedOption {
  id           String       @id @default(cuid())
  needId       String
  need         LocationNeed @relation(fields: [needId], references: [id], onDelete: Cascade)
  locationId   String       // plain FK to Location (resolved in service; keeps Location untouched)
  optionStatus String       @default("PROPOSED") // PROPOSED | SCOUTING | RECCED | SHORTLISTED | APPROVED | REJECTED
  rank         Int?
  notes        String?
  isSelected   Boolean      @default(false)
  createdAt    DateTime     @default(now())

  @@index([needId])
  @@index([locationId])
  @@map("location_need_options")
}

// -- SYS-07 V2 . Slice 2 -- Scout Visit (field event + scout call sheet) --
// Generalizes per-location TechRecce into a multi-stop day. Dual-target:
// projectId null = master/library-scope visit. Plain-FK pattern (no Prisma
// relation to Project/Location/Crew) to keep those big models untouched.
model ScoutVisit {
  id                 String   @id @default(cuid())
  projectId          String?  // null = master / library-scope visit
  masterLocationId   String?  // optional library anchor for master-scope visits
  title              String
  type               String   @default("RECON") // RECON | PRELIMINARY | TECH_RECCE
  purpose            String?
  date               DateTime?
  callTime           String?  // crew call / meet time (free text e.g. "06:30")
  meetingPoint       String?  // unit base / rendezvous
  status             String   @default("PLANNED") // PLANNED | CONFIRMED | IN_PROGRESS | DONE | CANCELLED
  notes              String?
  transportRequested Boolean  @default(false) // S4: a transport request has been raised
  transportOrderId   String?  // S4: plain FK to the created TransportOrder (status read-back)
  clearancePackId    String?  // S3 hook
  createdById        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  stops              ScoutVisitStop[]
  members            ScoutVisitMember[]

  @@index([projectId])
  @@index([masterLocationId])
  @@map("scout_visits")
}

model ScoutVisitStop {
  id          String     @id @default(cuid())
  visitId     String
  visit       ScoutVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  needId      String?    // plain FK to LocationNeed (what we're scouting for)
  locationId  String?    // plain FK to Location (the candidate place to visit)
  label       String?    // free text if neither need/location resolves
  ordering    Int        @default(0) // route order
  arriveAt    String?    // per-stop arrival window (free text)
  departAt    String?
  notes       String?
  techRecceId String?    // a stop can spawn/attach a TechRecce result
  createdAt   DateTime   @default(now())

  @@index([visitId])
  @@index([needId])
  @@index([locationId])
  @@map("scout_visit_stops")
}

model ScoutVisitMember {
  id         String     @id @default(cuid())
  visitId    String
  visit      ScoutVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  crewId     String?    // plain FK to ProductionCrew
  userId     String?    // plain FK to User (system-user scout)
  name       String     // denormalized display name
  department String?
  roleTitle  String?
  phone      String?
  email      String?
  isLead     Boolean    @default(false) // scout lead / LM
  createdAt  DateTime   @default(now())

  @@index([visitId])
  @@index([crewId])
  @@map("scout_visit_members")
}

// -- SYS-07 V2 . Slice 3 -- Clearance pack (send party IDs to venues/authorities ahead) --
// Compiles consenting party members' identity docs into a time-limited shareable link (or
// printable pack) for venue management/security. PII controls: per-crew consent, link expiry,
// full access audit. Dual-target via projectId. Plain-FK pattern (crewId / visitId resolved).
model ClearancePack {
  id             String   @id @default(cuid())
  projectId      String?
  visitId        String?  // the scout visit this pack was built for (optional)
  title          String
  purpose        String?
  recipientName  String?  // venue management / security contact
  recipientOrg   String?
  recipientEmail String?
  token          String   @unique @default(cuid()) // time-limited public link key
  expiresAt      DateTime?
  status         String   @default("DRAFT") // DRAFT | SHARED | EXPIRED | REVOKED
  sharedAt       DateTime?
  message        String?
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  members  ClearancePackMember[]
  accesses ClearancePackAccess[]

  @@index([projectId])
  @@index([visitId])
  @@index([token])
  @@map("clearance_packs")
}

model ClearancePackMember {
  id            String        @id @default(cuid())
  packId        String
  pack          ClearancePack @relation(fields: [packId], references: [id], onDelete: Cascade)
  crewId        String?       // plain FK to ProductionCrew
  name          String
  roleTitle     String?
  department    String?
  // snapshot of the docs included at build time (later crew edits don't change what was shared)
  passportUrl   String?
  emiratesIdUrl String?
  photoUrl      String?
  otherDocs     Json?         // [{ label, url }]
  consentGiven  Boolean       @default(false)
  createdAt     DateTime      @default(now())

  @@index([packId])
  @@index([crewId])
  @@map("clearance_pack_members")
}

model ClearancePackAccess {
  id        String        @id @default(cuid())
  packId    String
  pack      ClearancePack @relation(fields: [packId], references: [id], onDelete: Cascade)
  event     String        // SHARED | VIEWED | DOWNLOADED | REVOKED | EXPIRED
  actor     String?       // user id/name, or "venue link"
  detail    String?
  ip        String?
  createdAt DateTime      @default(now())

  @@index([packId])
  @@map("clearance_pack_accesses")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ SYS-07 slice 2 Гўв‚¬вЂќ Scouting missions & field submissions ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
enum ScoutAssignmentType {
  INITIAL // first pass / general recon
  PHOTO // photo scout
  DIRECTOR // director scout
  PRODUCER // producer scout
  TECH_RECCE // technical recce
  PERMIT // permit feasibility
  FINAL // final lock
}

enum ScoutPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ScoutAssignmentStatus {
  OPEN
  IN_PROGRESS
  SUBMITTED // candidates submitted, awaiting decision
  COMPLETED
  CANCELLED
}

enum ScoutSubmissionStatus {
  PENDING // awaiting review
  SHORTLISTED
  ACCEPTED // promoted to library / linked
  REJECTED
}

// NB: projectId is a plain indexed FK (no Prisma relation) to keep ProductionProject
// untouched this slice; projects are guarded against hard-delete anyway.
model ScoutAssignment {
  id          String              @id @default(cuid())
  projectId   String
  title       String
  description String? // the brief Гўв‚¬вЂќ what we're looking for
  sceneRefs   String? // scenes this should cover
  visualRefs  Json? // mood-board image URLs / references
  locationType LocationType       @default(EXT)
  budgetTarget Decimal?           @db.Decimal(14, 2)
  feeCurrency  String             @default("AED")
  dueDate     DateTime?
  priority    ScoutPriority       @default(MEDIUM)
  type        ScoutAssignmentType @default(INITIAL)
  status      ScoutAssignmentStatus @default(OPEN)

  assignedToId   String? // user id of the scout
  assignedToName String? // denormalized for display

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions ScoutSubmission[]

  @@index([projectId])
  @@index([status])
  @@map("scout_assignments")
}

model ScoutSubmission {
  id           String          @id @default(cuid())
  assignmentId String
  assignment   ScoutAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  candidateName String
  summary       String?
  notes         String?

  // geo captured in the field
  lat           Decimal? @db.Decimal(10, 7)
  lng           Decimal? @db.Decimal(10, 7)
  fullAddress   String?
  googleMapsUrl String?
  what3words    String?

  media       Json? // array of photo URLs captured on site
  ownerName   String?
  ownerPhone  String?
  ownerEmail  String?

  // weighted evaluation { visual, access, logistics, cost, safety, ... , overall }
  evaluation  Json?
  estFeePerDay Decimal? @db.Decimal(14, 2)

  status                 ScoutSubmissionStatus @default(PENDING)
  acceptedMasterLocationId String? // set when accepted ГўвЂ вЂ™ promoted into the library
  reviewNotes            String?

  submittedById String?
  submittedByName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([assignmentId])
  @@index([status])
  @@map("scout_submissions")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ SYS-07 slice 3 Гўв‚¬вЂќ Tech recces & weighted evaluation ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
enum RecceStatus {
  PLANNED
  DONE
  CANCELLED
}

model TechRecce {
  id         String      @id @default(cuid())
  locationId String
  location   Location    @relation(fields: [locationId], references: [id], onDelete: Cascade)

  reccedAt    DateTime?
  conductedBy String?
  attendees   String? // free-text list of who attended
  summary     String?
  status      RecceStatus @default(PLANNED)

  notes     RecceNote[]
  createdById String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
  @@map("tech_recces")
}

model RecceNote {
  id          String    @id @default(cuid())
  techRecceId String
  techRecce   TechRecce @relation(fields: [techRecceId], references: [id], onDelete: Cascade)

  department     String // DIRECTOR | FIRST_AD | DOP | GAFFER | GRIP | SOUND | SFX | STUNTS | ART_PD | COSTUME_MAKEUP | PRODUCER | LM | TRANSPORT | SAFETY | CAMERA | ELECTRIC | ART | CONSTRUCTION | SECURITY | VFX | LOCATIONS | OTHER
  risks          String?
  equipmentNeeds String?
  crewNeeds      String?
  accessNotes    String?
  safetyNotes    String?
  powerNotes     String?
  photos         Json?

  // SYS-07 V2 Slice 5 вЂ” department-structured concern + triage + checklist
  note       String?  // the HOD's headline concern / observation
  severity   String   @default("INFO") // INFO | LOW | MEDIUM | HIGH | BLOCKER
  actionItem String?  // what must happen before shoot
  resolved   Boolean  @default(false)
  checklist  Json?    // { key: boolean } ticks against the department checklist template

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([techRecceId])
  @@map("recce_notes")
}

enum EvaluationRecommendation {
  RECOMMENDED
  ACCEPTABLE
  NOT_RECOMMENDED
}

model LocationEvaluation {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  // criterion scores 1-5: { visual, access, logistics, cost, safety,
  //   productionValue, permitComplexity, feasibility, comfort, schedule }
  scores         Json
  weights        Json? // optional override; equal-weight if null
  weightedScore  Decimal @db.Decimal(6, 3) @default(0) // 0..5, system-computed
  recommendation EvaluationRecommendation @default(ACCEPTABLE)
  notes          String?

  evaluatedById   String?
  evaluatedByName String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
  @@map("location_evaluations")
}

// -- SYS-07 V2 . Slice 6 -- Photo plates (the tagged Location Report / lookbook asset) --
// Purpose-tagged field photos per Location (and optionally per scout visit). Scene/shot refs
// make a plate a reusable previs/storyboard reference. Plain-FK pattern; dual-target.
model PhotoPlate {
  id           String   @id @default(cuid())
  projectId    String?
  locationId   String?  // plain FK to Location
  visitId      String?  // plain FK to ScoutVisit (capture context)
  url          String
  thumbnailUrl String?
  purpose      String   @default("WIDE") // APPROACH | WIDE | FEATURE | SIGHTLINE | INFRASTRUCTURE | PROBLEM | AMBIENT | REFERENCE
  caption      String?
  department   String?
  timeOfDay    String?  // morning | midday | afternoon | goldenHour | night
  sceneRef     String?
  shotRef      String?
  lat          Decimal? @db.Decimal(10, 7)
  lng          Decimal? @db.Decimal(10, 7)
  sortOrder    Int      @default(0)
  capturedAt   DateTime?
  uploadedById String?
  createdAt    DateTime @default(now())

  @@index([projectId])
  @@index([locationId])
  @@index([visitId])
  @@map("photo_plates")
}

// -- SYS-07 V2 . Slice 8 -- Scene-change request (the script feedback loop) --
// Raised from a PRELIMINARY/TECH_RECCE note against specific scenes ("rewrite to fit the
// venue"); routed to writer/script dept, tracked to resolution, reflected back in the breakdown.
// Plain-FK pattern; project-scoped.
model SceneChangeRequest {
  id           String   @id @default(cuid())
  projectId    String
  locationId   String?  // the location that triggered it
  needId       String?  // the LocationNeed
  visitId      String?  // raised from a scout visit / recce
  recceNoteId  String?  // raised from a specific department recce note
  sceneRefs    String?  // affected scene numbers (denormalized)
  title        String
  detail       String?  // what needs to change
  reason       String?  // why (venue constraint)
  department   String?  // which dept raised it
  raisedBy     String?
  raisedByName String?
  priority     String   @default("MEDIUM") // LOW | MEDIUM | HIGH | URGENT
  status       String   @default("OPEN")   // OPEN | ACK | IN_PROGRESS | RESOLVED | REJECTED
  resolution   String?
  resolvedBy   String?
  resolvedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([projectId])
  @@index([locationId])
  @@index([status])
  @@map("scene_change_requests")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ SYS-07 slice 4 Гўв‚¬вЂќ Permits & risk ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
enum PermitStatus {
  NOT_REQUIRED
  DRAFT
  APPLIED
  IN_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

// Typed permit categories Гўв‚¬вЂќ permits are ~88% of the LM's workload and span several
// authorities (mailbox evidence). Free-text `type` kept for back-compat / detail.
enum LocationPermitType {
  GROUND_FILMING // twofour54 ground filming permit
  DRONE_GCAA // drone / aerial (GCAA)
  ROAD_TRAFFIC // road/lane use (RTA)
  POLICE // police coordination / security clearance
  AIRPORT // airport airside (ADAC)
  HERITAGE_DCT // heritage / DCT site
  PARKING // parking permit
  MARINE // marine / coastguard
  PYRO_SFX // pyrotechnics / special effects
  FIREARMS // weapons / armoury
  OTHER
}

model LocationPermit {
  id         String    @id @default(cuid())
  // Dual-target: a permit belongs to a project location OR a master library location.
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)
  masterLocationId String?
  masterLocation   MasterLocation? @relation(fields: [masterLocationId], references: [id], onDelete: Cascade)

  permitType      LocationPermitType @default(OTHER)
  type            String? // free-text detail (legacy / specifics)
  authorityId     String?
  authorityRef    PermitAuthority? @relation(fields: [authorityId], references: [id])
  authority       String? // denormalised issuing-body name (e.g. twofour54, RTA)
  jurisdiction    String? // country / emirate / city
  referenceNumber String?
  status          PermitStatus @default(DRAFT)
  applicationDate DateTime?
  approvalDate    DateTime?
  expiryDate      DateTime?
  fee             Decimal? @db.Decimal(14, 2)
  currency        String   @default("AED")
  conditions      String? // conditions / restrictions attached to the permit
  docUrl          String? // attached permit PDF/image
  ocrData         Json? // raw OCR extraction for audit
  notes           String?

  // workflow routing available via WorkflowEntity.LOCATION
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([locationId])
  @@index([masterLocationId])
  @@index([status])
  @@index([permitType])
  @@map("location_permits")
}

// Reusable directory of issuing authorities (standalone, company-wide).
model PermitAuthority {
  id           String  @id @default(cuid())
  name         String  @unique
  category     String? // FILM_COMMISSION | AVIATION | ROADS | POLICE | AIRPORT | HERITAGE | MUNICIPALITY | OTHER
  jurisdiction String? // emirate / country covered
  contactName  String?
  email        String?
  phone        String?
  portalUrl    String?
  leadTimeDays Int? // typical processing lead time
  notes        String?
  permits      LocationPermit[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("permit_authorities")
}

enum RiskStatus {
  OPEN
  MITIGATED
  CLOSED
}

model LocationRisk {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  category   String // FIRE | WATER | HEIGHT | CROWD | WEATHER | TRAFFIC | SECURITY | WILDLIFE | ELECTRICAL | STRUCTURAL | HEAT | OTHER
  hazard     String
  likelihood Int     @default(1) // 1-5
  impact     Int     @default(1) // 1-5
  riskScore  Int     @default(1) // likelihood ГѓвЂ” impact (system-computed)
  mitigation String?
  owner      String? // who owns the mitigation
  emergencyProcedure String?
  nearestMedical     String?
  evacuationNotes    String?
  status     RiskStatus @default(OPEN)
  notes      String?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([locationId])
  @@index([status])
  @@map("location_risks")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ SYS-07 slice 6 Гўв‚¬вЂќ LM document vault & compliance ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
// Modelled on the real location-manager workflow (NOCs, agreements/releases,
// insurance, location guides, IDs, quotes) seen in the LM mailbox study.
enum LocationDocCategory {
  NOC // No Objection Certificate (often bilingual EN/AR) Гўв‚¬вЂќ the LM's #1 artifact
  LOCATION_AGREEMENT // location agreement / contract
  RELEASE // location release
  INSURANCE // public-liability (PLL) / COI certificate
  LOCATION_GUIDE // the per-location guide/pack issued to crew
  RISK_ASSESSMENT // risk-assessment questionnaire
  METHOD_STATEMENT // HSE method statement (pairs with risk assessment)
  ID_DOCUMENT // owner/landlord EID / trade licence
  QUOTE // rental quote / invoice
  PERMIT_DOC // ground filming permit document
  OTHER
}

enum LocationDocStatus {
  DRAFT
  REQUESTED // asked the owner/authority
  RECEIVED // came back
  SIGNED // executed
  ISSUED // we issued it (e.g. NOC letter)
  EXPIRED
  VOID
}

enum DocLanguage {
  EN
  AR
  BILINGUAL
}

enum LocationStage {
  SOURCING
  NOC_REQUESTED
  AGREEMENT_SENT
  PERMIT_APPLIED
  INSURANCE_RECEIVED
  CONFIRMED
  WRAPPED
}

model LocationDocument {
  id         String    @id @default(cuid())
  // Dual-target: a document belongs to a project location OR a master library location.
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)
  masterLocationId String?
  masterLocation   MasterLocation? @relation(fields: [masterLocationId], references: [id], onDelete: Cascade)

  category   LocationDocCategory @default(OTHER)
  title      String
  status     LocationDocStatus   @default(DRAFT)
  language   DocLanguage         @default(EN)

  partyName   String? // owner / landlord / authority on the document
  authority   String? // issuing body (Aldar, twofour54, RTA, municipalityГўв‚¬В¦)
  refNumber   String?
  issueDate   DateTime?
  signedDate  DateTime?
  expiryDate  DateTime? // drives insurance/NOC expiry alerts
  amount      Decimal? @db.Decimal(14, 2) // coverage value or quote amount
  currency    String   @default("AED")

  fileUrl String? // uploaded PDF/image
  ocrData Json? // raw OCR extraction (audit)
  notes   String?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([locationId])
  @@index([masterLocationId])
  @@index([category])
  @@index([expiryDate])
  @@map("location_documents")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ SYS-07 slice 7 Гўв‚¬вЂќ Security & marshals (2nd-biggest LM topic) ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
enum SecurityStatus {
  PLANNED
  CONFIRMED
  ON_SITE
  COMPLETED
  CANCELLED
}

model LocationSecurity {
  id         String    @id @default(cuid())
  // Dual-target: project location OR master library location.
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)
  masterLocationId String?
  masterLocation   MasterLocation? @relation(fields: [masterLocationId], references: [id], onDelete: Cascade)

  company      String?
  contactName  String?
  contactPhone String?
  guards       Int     @default(0)
  marshals     Int     @default(0)
  shiftStart   DateTime?
  shiftEnd     DateTime?
  days         Decimal  @db.Decimal(8, 2) @default(1)
  ratePerGuard Decimal? @db.Decimal(12, 2)
  totalCost    Decimal? @db.Decimal(14, 2)
  currency     String   @default("AED")
  status       SecurityStatus @default(PLANNED)
  postedTxnId  String? // ledger transaction once posted as a cost
  notes        String?

  createdById String?
