enum AccommodationType {
  HOTEL
  APARTMENT
  SERVICED_APARTMENT
  VILLA
  RESORT
  CREW_CAMP
  DORMITORY
  STAFF_HOUSING
  OTHER
}

enum RoomType {
  SINGLE
  DOUBLE
  TWIN
  SUITE
  EXECUTIVE_SUITE
  VILLA
  APARTMENT
  DORMITORY
  BED
}

enum AccommodationClass {
  STANDARD
  BUSINESS
  EXECUTIVE
  VIP
  ULTRA_VIP
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  BLOCKED
  MAINTENANCE
}

