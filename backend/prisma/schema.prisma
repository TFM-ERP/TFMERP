model GlobalTalentProfile {
  id        String       @id @default(cuid())
  fullName  String
  stageName String?
  status    TalentStatus @default(ACTIVE)

  email String?
  phone String?

  gender      String?
  ethnicity   String?
  nationality String?
  baseCity    String?
  languages   String[] @default([])
  skills      String[] @default([])
  heightCm    Int?
  physical    Json?

  // ГўвЂќв‚¬ГўвЂќв‚¬ SYS-10 V3.0 Гўв‚¬вЂќ Deep Talent Identity (V3-A) ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
  preferredName          String?
  nationalities          String[] @default([]) // multiple nationalities (beyond primary `nationality`)
  currentLocation        String?
  dialects               String[] @default([])
  accents                String[] @default([])
  weightKg               Int?
  tattoos                String?
  distinguishingFeatures String?
  biography              String?
  pressLinks             String[] @default([])
  categories             String[] @default([]) // TalentCategory values (multi): ACTOR, MODEL, VOICE_ARTISTГўв‚¬В¦
  whatsapp               String?
  emergencyContact       Json? // { name, relationship, phone }
  awards                 Json? // [{ name, year, body, work }]  (V3-B professional)

  headshotUrls String[] @default([])
  reelUrls     String[] @default([])
  resumeUrl    String?
  portfolioUrl String?

  unions      String[] @default([])
  unionStatus String?

  // Performer union/guild membership ГўвЂ вЂ™ drives fringes when cast (classificationCode 'PERFORMER').
  laborBodyId String?
  laborBody   LaborBody? @relation(fields: [laborBodyId], references: [id])

  // Talent representative (agent/manager) Гўв‚¬вЂќ a TALENT_REP user sees only their own talent.
  representedById String?
  representedBy   User?   @relation("TalentRepresentative", fields: [representedById], references: [id])

  // ГўвЂќв‚¬ГўвЂќв‚¬ Travel Requirement Engine (SYS-10 V2.0 Г‚В§2) Гўв‚¬вЂќ mirrored from the Travel Identity ГўвЂќв‚¬ГўвЂќв‚¬
  homeCountry             String?
  homeCity                String?
  workRegion              String?
  isLocalTalent           Boolean @default(false)
  travelRequired          Boolean @default(false)
  visaRequired            Boolean @default(false)
  accommodationRequired   Boolean @default(false)
  groundTransportRequired Boolean @default(false)

  agentName  String?
  agentEmail String?
  agencyName String?

  /// @PII
  dateOfBirth   DateTime?
  isMinor       Boolean   @default(false)
  guardianName  String?
  guardianEmail String?

  consentStatus      ConsentStatus @default(PENDING)
  consentGivenAt     DateTime?
  consentExpiresAt   DateTime?
  gdprConsentVersion String?
  lawfulBasis        String?
  dataRetentionUntil DateTime?
  erasureRequestedAt DateTime?

  submissions        Submission[]
  consentLogs        ConsentLog[]
  budgetLines        BudgetLineItem[]          @relation("BudgetLineCastTalent")
  travelIdentity     TravelerProfile?          @relation("TalentTravelIdentity")
  performanceReviews TalentPerformanceReview[]
  representations    TalentRepresentation[] // V3-B
  credits            TalentCredit[] // V3-B
  interactions       TalentInteraction[] // V3-C
  listMemberships    TalentListMember[] // V3-E

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([fullName])
  @@map("global_talent_profiles")
}

model CastingCall {
  id String @id @default(cuid())

  // Nullable ГўвЂ вЂ™ standalone casting calls (no project), e.g. talent-agency service.
  projectId String?
  project   ProductionProject? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  breakdownElementId String?
  breakdownElement   BreakdownElement? @relation(fields: [breakdownElementId], references: [id], onDelete: SetNull)

  // Crucial link #3 (V2.0) Гўв‚¬вЂќ the character this call casts.
  characterProfileId String?
  characterProfile   CharacterProfile? @relation(fields: [characterProfileId], references: [id], onDelete: SetNull)

  roleName             String
  roleType             CastingRoleType   @default(SUPPORTING)
  characterDescription String?
  status               CastingCallStatus @default(DRAFT)

  ageMin           Int?
  ageMax           Int?
  gender           String?
  ethnicity        String?
  languages        String[] @default([])
  specialSkills    String[] @default([])
  unionRequirement String?

  rateMin     Decimal? @db.Decimal(14, 2)
  rateMax     Decimal? @db.Decimal(14, 2)
  currency    Currency @default(AED)
  slotsToFill Int      @default(1)

  shootDatesNote String?
  deadline       DateTime?
  isPublic       Boolean   @default(false)

  castingDirectorId String?
  createdById       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  submissions      Submission[]
  auditionPackages AuditionPackage[] // V3-H

  @@index([projectId, status])
  @@index([breakdownElementId])
  @@map("casting_calls")
}

// Character Intelligence (SYS-10 V2.0 Г‚В§4) Гўв‚¬вЂќ sits between BreakdownElement and CastingCall.
model CharacterProfile {
  id        String             @id @default(cuid())
  projectId String?
  project   ProductionProject? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  breakdownElementId String?
  breakdownElement   BreakdownElement? @relation(fields: [breakdownElementId], references: [id], onDelete: SetNull)

  name String

  // Creative
  backstory     String?
  arc           String?
  relationships String?

  // Production
  shootDays     Int?
  locations     String?
  dialoguePages Decimal? @db.Decimal(8, 1)
  stuntDays     Int?

  // Casting
  requirements String?
  notes        String?

  // ГўвЂќв‚¬ГўвЂќв‚¬ SYS-10 V3.0 Гўв‚¬вЂќ Character Assets (V3-D) ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
  characterCode        String? // human "Character ID" e.g. CHAR-014
  scriptReference      String?
  personalityNotes     String?
  visualReferences     String[] @default([])
  scenesCount          Int?
  nightShoots          Int?
  travelDays           Int?
  // Structured casting requirements
  castingGender        String?
  ageRangeMin          Int?
  ageRangeMax          Int?
  castingEthnicity     String?
  castingNationality   String?
  castingLanguage      String?
  castingAccent        String?
  physicalRequirements String?
  requiredSkills       String[] @default([])
  certifications       String[] @default([])

  castingCalls CastingCall[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@map("character_profiles")
}

model Submission {
  id            String      @id @default(cuid())
  castingCallId String
  castingCall   CastingCall @relation(fields: [castingCallId], references: [id], onDelete: Cascade)

  talentId String
  talent   GlobalTalentProfile @relation(fields: [talentId], references: [id], onDelete: Cascade)

  status       SubmissionStatus @default(SUBMITTED)
  source       SubmissionSource @default(SELF)
  boardVerdict BoardVerdict? // producer/director review board

  coverNote        String?
  proposedRate     Decimal? @db.Decimal(14, 2)
  availabilityNote String?

  rank         Int?
  score        Int?
  reviewedById String?
  decisionNote String?

  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  auditions    Audition[]
  negotiation  TalentNegotiation?
  opsChecklist TalentOpsChecklist?
  selfTapes    SelfTapeSubmission[] // V3-H

  @@unique([castingCallId, talentId])
  @@index([castingCallId, status])
  @@map("casting_submissions")
}

// Talent Operations Hub (SYS-10 V2.0 Г‚В§3) Гўв‚¬вЂќ production/payroll prep per engagement.
// Contract & travel status are aggregated live from their own modules (not stored here).
model TalentOpsChecklist {
  id           String     @id @default(cuid())
  submissionId String     @unique
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  // Production
  wardrobeComplete     Boolean @default(false)
  measurementsComplete Boolean @default(false)
  fittingsComplete     Boolean @default(false)
  makeupNotesComplete  Boolean @default(false)
  // Payroll
  bankingComplete      Boolean @default(false)
  taxDocsComplete      Boolean @default(false)
  vendorSetupComplete  Boolean @default(false)

