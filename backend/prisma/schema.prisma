enum WorkflowEntity {
  INVOICE
  EXPENSE
  PURCHASE_ORDER
  PETTY_CASH
  TIMECARD
  CONTRACT
  TRIP
  BUDGET_TRANSFER
  OVERAGE
  BUDGET_CHANGE
  SCHEDULE_CHANGE
  LOCATION
  OTHER
}

enum WorkflowInstanceStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model WorkflowDefinition {
  id          String         @id @default(cuid())
  key         String         @unique // e.g. PO_STANDARD
  name        String
  entityType  WorkflowEntity
  description String?
  isActive    Boolean        @default(true)
  isSystem    Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  nodes     WorkflowNode[]
  instances WorkflowInstance[]

  @@index([entityType])
  @@map("workflow_definitions")
}

model WorkflowNode {
  id                  String             @id @default(cuid())
  definitionId        String
  definition          WorkflowDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  order               Int // 1-based sequence position
  name                String // "Department Head"
  // who may act on this node Гўв‚¬вЂќ project PermissionTemplate key OR global role (either matches)
  approverTemplateKey String?
  approverRole        String?
  slaHours            Int? // auto-escalate after this many hours (cron, later)
  autoApprove         Boolean            @default(false) // skip Гўв‚¬вЂќ system passes this node automatically

  @@unique([definitionId, order])
  @@map("workflow_nodes")
}

model WorkflowInstance {
  id           String                 @id @default(cuid())
  definitionId String
  definition   WorkflowDefinition     @relation(fields: [definitionId], references: [id])
  entityType   WorkflowEntity
  entityId     String
  projectId    String? // for project-scoped approver resolution
  label        String? // human summary e.g. "PO-2026-0007 Г‚В· 12,500 AED"
  status       WorkflowInstanceStatus @default(PENDING)
  currentOrder Int                    @default(1)
  startedById  String?
  closedAt     DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  actions ApprovalAction[]

  @@index([entityType, entityId])
  @@index([status])
  @@map("workflow_instances")
}

model ApprovalAction {
  id           String           @id @default(cuid())
  instanceId   String
  instance     WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  nodeOrder    Int
  action       String // APPROVED | REJECTED | DELEGATED | ESCALATED | AUTO | CANCELLED
  actorId      String?
  delegateToId String?
  comment      String?
  createdAt    DateTime         @default(now())

  @@index([instanceId])
  @@map("approval_actions")
}

