// it does NOT host or upload video (standing project rule "no video upload for now").
// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model AuditionPackage {
  id            String       @id @default(cuid())
  castingCallId String?
  castingCall   CastingCall? @relation(fields: [castingCallId], references: [id], onDelete: Cascade)

  title           String
  sides           String[]  @default([]) // links to sides documents
  ndaUrl          String?
  characterBrief  String?
  moodBoards      String[]  @default([]) // links
  referenceLinks  String[]  @default([]) // reference video links (not hosted)
  productionNotes String?
  deadline        DateTime?

  // Self-tape validation rules
  requiredFormat String? // e.g. "mp4"
  minResolution  String? // e.g. "1080p"
  maxDurationSec Int?

  selfTapes SelfTapeSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([castingCallId])
  @@map("audition_packages")
}

model SelfTapeSubmission {
  id           String           @id @default(cuid())
  packageId    String?
  package      AuditionPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)
  submissionId String?
  submission   Submission?      @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  talentId     String?

  // Link only Гўв‚¬вЂќ no hosting.
  videoUrl  String
  slateUrl  String?
  materials String[] @default([])

  // Reported / parsed metadata
  format      String?
  resolution  String?
  durationSec Int?

  // Auto-validation flags
  formatOk     Boolean?
  resolutionOk Boolean?
  durationOk   Boolean?
  deadlineOk   Boolean?

  status String  @default("RECEIVED") // RECEIVED | UNDER_REVIEW | ACCEPTED | REJECTED
  notes  String?

  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([packageId])
  @@index([submissionId])
  @@map("self_tape_submissions")
}
