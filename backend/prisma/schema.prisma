  @@map("hot_cost_accruals")
}

// -- SYS-13 . D2 -- Annotation layers + decoupled, text-anchored annotations --
// Layers belong to the document (carry across revisions); annotations bind to a revision but
// re-anchor forward (D3). Coordinates are normalized (0..1 of the page) so zoom/DPI never breaks
// the overlay. anchorText + surroundingContext drive the Levenshtein transfer.
model AnnotationLayer {
  id          String         @id @default(cuid())
  documentId  String
  document    ScriptDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  name        String         // "My Notes", "Art Department", "Director Private"вЂ¦
  type        String         @default("PERSONAL") // PERSONAL | DEPARTMENT | MEETING | SCRIPT_SUPE | EXEC
  department  String?        // dept context for DEPARTMENT layers (IAM in D4)
  color       String         @default("#eab308")
  visibility  String         @default("PRIVATE") // PRIVATE | SHARED_ROLE | PROJECT
  ownerUserId String?
  createdAt   DateTime       @default(now())

  annotations Annotation[]
  shares      LayerShare[]

  @@index([documentId])
  @@map("annotation_layers")
}

// -- SYS-13 . D5 -- Sides generation job (pruned, crossed-out, 2-up, watermarked) --
model SidesJob {
  id          String   @id @default(cuid())
  projectId   String
  documentId  String
  revisionId  String
  shootDate   DateTime?
  scenes      Json     // selected scene numbers
  recipients  Json     // [{ name, email, crewId, outputUrl }]
  baseUrl     String?  // un-watermarked base sides
  pageCount   Int      @default(0)
  status      String   @default("READY") // READY | SHARED | ERROR
  createdById String?
  createdAt   DateTime @default(now())

  @@index([projectId])
  @@map("sides_jobs")
}

// -- SYS-13 . D4 -- Layer share grants (the IAM wall for SHARED_ROLE layers) --
model LayerShare {
  id          String          @id @default(cuid())
  layerId     String
  layer       AnnotationLayer @relation(fields: [layerId], references: [id], onDelete: Cascade)
  templateKey String?         // PermissionTemplate.key (e.g. DEPT_HEAD, LINE_PRODUCER)
  department  String?         // share to a film department
  access      String          @default("VIEW") // VIEW | EDIT
  createdAt   DateTime        @default(now())

  @@index([layerId])
  @@map("layer_shares")
}

model Annotation {
  id                 String          @id @default(cuid())
  layerId            String
  layer              AnnotationLayer @relation(fields: [layerId], references: [id], onDelete: Cascade)
  revisionId         String
  documentId         String
  page               Int             @default(1)
  tool               String          @default("HIGHLIGHT") // HIGHLIGHT | PEN | TEXT | STICKY | TAG | TRAMLINE
  payload            Json?           // { color, points[], text, tagKey, budgetCode }

  // Text anchoring (D3 transfer)
  anchorText         String?
  anchorHash         String?
  anchorOffset       Int?
  surroundingContext String?         // ~100 chars each side to disambiguate duplicate lines

  // Normalized geometry (0..1 of the page)
  x Float @default(0)
  y Float @default(0)
  w Float @default(0)
  h Float @default(0)

  // Bridges / state
  associatedLineItemId String?       // D9 prop в†’ draft BudgetLineItem
  conflict             Boolean       @default(false) // D7 offline collision flag

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([revisionId])
  @@index([layerId])
  @@map("annotations")
}

