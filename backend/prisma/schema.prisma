// ============================================================
// FRINGE, UNION & PRODUCTION COMPLIANCE INTELLIGENCE
// Global master data (A) Г‚В· resolution (C) Г‚В· project snapshot (D)
// All money Decimal Г‚В· all rules typed Г‚В· effective-dated Г‚В· provenance-first
// ============================================================

enum GeoLevel {
  COUNTRY
  STATE
  REGION
  DISTRICT
  CITY
  ZONE
}

model GeoNode {
  id       String    @id @default(cuid())
  level    GeoLevel
  name     String
  code     String? // ISO country / state code
  parentId String?
  parent   GeoNode?  @relation("GeoTree", fields: [parentId], references: [id])
  children GeoNode[] @relation("GeoTree")

  laborBodies        LaborBody[]
  laborConfigs       ProjectLaborConfig[]
  incentivePrograms  IncentiveProgram[]
  taxRules           JurisdictionTaxRule[]
  productionProjects ProductionProject[]   @relation("ProjectProductionCountry")
  createdAt          DateTime              @default(now())

  @@index([parentId])
  @@index([level])
  @@map("geo_nodes")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Jurisdiction tax rules (VAT / GST per geography) ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
// Country-specific VAT rates and input-tax recovery rules, resolved from the
// project's productionCountry (with fallback up the GeoNode tree).
model JurisdictionTaxRule {
  id        String  @id @default(cuid())
  geoNodeId String
  geoNode   GeoNode @relation(fields: [geoNodeId], references: [id], onDelete: Cascade)

  taxKind String  @default("VAT") // VAT | GST | SALES_TAX | WITHHOLDING
  name    String // e.g. "UAE Standard VAT"
  ratePct Decimal @db.Decimal(7, 4) // 5.0000 = 5%

  recoverable Boolean  @default(true) // is input tax recoverable at all
  recoveryPct Decimal? @db.Decimal(7, 4) // % of input tax recoverable (null = 100 when recoverable)
  rules       Json? // structured recovery detail: category exceptions, registration thresholds, refund scheme notes

  effectiveDate DateTime?
  expiryDate    DateTime?
  isActive      Boolean   @default(true)
  sourceUrl     String? // official source citation
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([geoNodeId])
  @@index([isActive])
  @@map("jurisdiction_tax_rules")
}

enum LaborBodyKind {
  UNION
  GUILD
  STATUTORY
  PAYROLL_PROVIDER
}

model LaborBody {
  id        String        @id @default(cuid())
  kind      LaborBodyKind
  name      String // "SAG-AFTRA", "IATSE", "UAE MOHRE"
  shortName String? // "SAG", "IATSE"
  countryId String?
  country   GeoNode?      @relation(fields: [countryId], references: [id])
  website   String?
  notes     String?
  isActive  Boolean       @default(true)

  agreements     Agreement[]
  sources        RateSource[]
  talentProfiles GlobalTalentProfile[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([kind])
  @@map("labor_bodies")
}

enum AgreementStatus {
  DRAFT
  ACTIVE
  SUPERSEDED
  EXPIRED
}

model Agreement {
  id              String          @id @default(cuid())
  laborBodyId     String
  laborBody       LaborBody       @relation(fields: [laborBodyId], references: [id], onDelete: Cascade)
  name            String // "SAG-AFTRA Theatrical 2023-2026"
  productionTypes Json // ["FEATURE","TV_SERIES",...] applicability
  tier            String? // budget tier / scale
  effectiveDate   DateTime
  expirationDate  DateTime?
  status          AgreementStatus @default(ACTIVE)
  sourceId        String?
  source          RateSource?     @relation(fields: [sourceId], references: [id])
  notes           String?

  classifications Classification[]
  rateRules       RateRule[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([laborBodyId])
  @@index([status])
  @@map("agreements")
}

model Classification {
  id          String    @id @default(cuid())
  agreementId String
  agreement   Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  code        String // "PERFORMER","BG","STUNT","IATSE-LOCAL-600"
  title       String
  riskClass   String? // workers' comp class code

  rateRules RateRule[]
  createdAt DateTime   @default(now())

  @@index([agreementId])
  @@map("classifications")
}

enum RateType {
  PENSION
  HEALTH
  PENSION_HEALTH
  PAYROLL_TAX
  WORKERS_COMP
  UNEMPLOYMENT
  VACATION_PAY
  HOLIDAY_PAY
  EMPLOYER_TAX
  UNION_DUES
  GUILD_CONTRIB
  STATUTORY_GRATUITY
  HANDLING_FEE
  OTHER
}

enum CalcMethod {
  PERCENT
  FLAT_PER_DAY
  FLAT_PER_WEEK
  FLAT_PER_HOUR
  PERCENT_WITH_CAP
  TIERED
}

enum RateBase {
  GROSS
  STRAIGHT_TIME
  TAXABLE
  WORKED_DAYS
}

enum CapPeriod {
  WEEKLY
  MONTHLY
  ANNUAL
  PER_PRODUCTION
}

model RateRule {
  id               String          @id @default(cuid())
  agreementId      String
  agreement        Agreement       @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  classificationId String?
  classification   Classification? @relation(fields: [classificationId], references: [id])

  label         String // "SAG-AFTRA Pension"
  rateType      RateType
  calcMethod    CalcMethod
  value         Decimal    @db.Decimal(12, 5) // 0.205 (=20.5%) or 38.50 ($/day)
  base          RateBase?
  capPeriod     CapPeriod?
  capAmount     Decimal?   @db.Decimal(14, 2) // wage base / ceiling
  floorAmount   Decimal?   @db.Decimal(14, 2)
  tiers         Json? // TIERED: [{upTo, value}]
  currency      String     @default("USD")
  glAccountCode String? // maps to Chart of Accounts

  // provenance / audit
  sourceId       String?
  source         RateSource? @relation(fields: [sourceId], references: [id])
  effectiveDate  DateTime
  expirationDate DateTime?
  approvedById   String?
  approvedAt     DateTime?
  previousId     String? // version chain
  isEstimate     Boolean     @default(false) // flagged when uncited / approximate
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agreementId])
  @@index([rateType])
  @@index([effectiveDate])
  @@map("rate_rules")
}

model RateSource {
  id            String     @id @default(cuid())
  laborBodyId   String?
  laborBody     LaborBody? @relation(fields: [laborBodyId], references: [id])
  title         String // "SAG-AFTRA 2023 Theatrical MOA"
  url           String?
  publisher     String? // SAG-AFTRA, EP, Cast & Crew
  trusted       Boolean    @default(true) // allow-list flag
  retrievedAt   DateTime?
  lastHash      String? // content hash from last refresh (change detection)
  lastStatus    String? // OK | BLOCKED | ERROR | NOT_ALLOWLISTED from last refresh
  lastCheckedAt DateTime?
  createdAt     DateTime   @default(now())

  agreements Agreement[]
  rateRules  RateRule[]

  @@map("rate_sources")
}

enum ProposalStatus {
  PENDING
  APPROVED
  REJECTED
}

model RateChangeProposal {
  id           String         @id @default(cuid())
  origin       String // MANUAL | REFRESH | AI
  payload      Json // proposed RateRule fields
  diff         Json? // old vs new
  sourceId     String?
  confidence   Decimal?       @db.Decimal(5, 2)
  status       ProposalStatus @default(PENDING)
  reviewedById String?
  reviewedAt   DateTime?
  reviewNotes  String?
  createdAt    DateTime       @default(now())

  @@index([status])
  @@map("rate_change_proposals")
}

enum UnionStatus {
  UNION
  NON_UNION
  MIXED
}

model ProjectLaborConfig {
  id             String            @id @default(cuid())
  projectId      String            @unique
  project        ProductionProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  geoNodeId      String?
  geoNode        GeoNode?          @relation(fields: [geoNodeId], references: [id])
  productionType String
  unionStatus    UnionStatus       @default(NON_UNION)
  laborBodyIds   Json // selected unions/guilds
  asOfDate       DateTime // date used to resolve rates
  snapshotAt     DateTime?
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("project_labor_configs")
}

model ProjectRateRule {
  id           String            @id @default(cuid())
  projectId    String
  project      ProductionProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceRuleId String? // pointer to master RateRule (for "update available" detection)

  // frozen copy of RateRule fields (by value)
  laborBodyName      String
  agreementName      String
  classificationCode String?
  label              String
