  @@map("script_scenes")
}

// -- SYS-13 . D6 -- Script-supervisor lining (coverage + takes) в†’ Hot Cost --
model ScriptCoverage {
  id              String      @id @default(cuid())
  sceneId         String
  scene           ScriptScene @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  revisionId      String
  slate           String?     // slate / scene-take label e.g. "14"
  cameraSetup     String?     // A_CAM | B_CAM вЂ¦
  description     String?     // "Wide", "CU Jane"вЂ¦
