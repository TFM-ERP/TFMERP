// ГўвЂќв‚¬ГўвЂќв‚¬ SYS-07 slice 7 Гўв‚¬вЂќ Location payment schedule (quote ГўвЂ вЂ™ deposit ГўвЂ вЂ™ balance) ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
enum LocationPaymentKind {
  QUOTE
  DEPOSIT
  BALANCE
  ADDITIONAL
  REFUND
}

enum LocationPaymentStatus {
