  fringe Decimal @db.Decimal(15, 2) @default(0)
  total  Decimal @db.Decimal(15, 2) @default(0)

  status      String  @default("DRAFT") // DRAFT | APPROVED | POSTED
  postedTxnId String?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@map("timecards")
}

model ProjectDocument {
  id        String            @id @default(cuid())
  projectId String
  project   ProductionProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name       String
  kind       String  @default("FILE") // FILE | LINK
