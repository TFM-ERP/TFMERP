  @@map("script_audio_notes")
}

// ============================================================================
// SYS-13c вЂ” ScriptON Audio (AI Script Reader / Table Read / Audio Production)
// MVP. Plain-indexed-FK pattern (engine/ids carried as strings/ids, no relations
// onto large models). Every new table is additive & nullable-friendly.
// ============================================================================
model AudioEngine {
  id           String   @id @default(cuid())
  key          String   @unique // BROWSER | ELEVENLABS | OPENAI | AZURE | вЂ¦
  displayName  String
  tier         String   @default("STUDIO") // LIVE | STUDIO
  enabled      Boolean  @default(false)
  credentialRef String? // secret-manager handle / env var name; never the raw key
  baseUrl      String? // LOCAL engines: OpenAI-compatible server URL (Chatterbox/Piper/Melo wrappers)
  capabilities Json? // { tts, sfx, music, dubbing }
  defaultModel String?
  supportsCloning Boolean @default(false)
  costModel    Json? // { tts:{unit,rate}, sfx:{unit,rate}, music:{unit,rate}, currency, minCharge }
  rateLimit    Json?
  roleAllowList Json? // roles permitted to use this engine (null = all)
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("audio_engines")
}

model AudioRoutingPolicy {
  id                    String   @id @default(cuid())
  scope                 String   @default("ORG") // ORG | PROJECT
  projectId             String?
  capability            String // LIVE_READ | TTS | SFX | MUSIC | DUBBING
  defaultEngineId       String?
  allowedEngineIds      Json? // string[]
  fallbackChain         Json? // string[]
  projectOverrideAllowed Boolean @default(false)
  userMayOverride       Boolean  @default(false)
  updatedById           String?
  updatedAt             DateTime @updatedAt

  @@unique([scope, projectId, capability])
  @@index([projectId])
  @@map("audio_routing_policies")
}

