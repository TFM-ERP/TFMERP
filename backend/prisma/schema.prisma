// ============================================================
// TFM ERP Гўв‚¬вЂќ Prisma Schema
// The Film Makers FZ LLC
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ FX rates (for multi-currency consolidation) ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model FxRate {
  id        String   @id @default(cuid())
  currency  String   @unique // USD, EUR, GBPГўв‚¬В¦
  toBase    Decimal  @db.Decimal(14, 6) // value of 1 unit in base currency (AED)
  updatedAt DateTime @updatedAt

  @@map("fx_rates")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Cloud storage OAuth connections (team-shared) ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model IntegrationConnection {
  id            String    @id @default(cuid())
  provider      String    @unique // GDRIVE | DROPBOX
  accountName   String?
  accountEmail  String?
  accessToken   String?
  refreshToken  String?
  expiresAt     DateTime?
  scope         String?
  connectedById String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("integration_connections")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Enums ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

enum Activity {
  RENTAL
  PRODUCTION
  BOTH
}

enum UserRole {
  SYSTEM_ADMIN
  FINANCE_MANAGER
  ACCOUNTANT
  RENTAL_MANAGER
  RENTAL_COORDINATOR
  DISPATCHER
  DRIVER
  MAINTENANCE
  PRODUCTION_MANAGER
  PRODUCTION_COORDINATOR
  CREW
  HR_MANAGER
  SALES
  TALENT_REP        // agent/manager Гўв‚¬вЂќ sees only the talent they represent
  TRAVEL_COORDINATOR // travel/logistics Гўв‚¬вЂќ sees traveller passport/visa/ID PII
}

enum Currency {
  AED
  USD
  EUR
  GBP
  SAR
  CAD
}

enum QuotationStatus {
  DRAFT
  PENDING_REVIEW
  SENT
  VIEWED
  REVISION_REQUESTED
  APPROVED
  REJECTED
  EXPIRED
  CONVERTED
  CANCELLED
}

enum InvoiceType {
  PROFORMA
  TAX_INVOICE
  CREDIT_NOTE
  DEBIT_NOTE
}

enum InvoiceStatus {
  DRAFT
  PENDING_APPROVAL
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
  VOIDED
  REFUNDED
  BAD_DEBT
}

enum PaymentMethod {
  BANK_TRANSFER
  CHEQUE
  CASH
  CARD
  ONLINE
}

enum PaymentStatus {
  PENDING
  CLEARED
  BOUNCED
  REFUNDED
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PARTIALLY_APPROVED
  PAID
  ARCHIVED
}

enum VatType {
  STANDARD      // 5% UAE VAT
  ZERO_RATED    // 0%
  EXEMPT        // No VAT
  OUT_OF_SCOPE  // Not subject to VAT
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
  JOURNAL
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Core: Users ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model User {
  id               String    @id @default(cuid())
  fullName         String
  email            String    @unique
  mobile           String?
  passwordHash     String
  jobTitle         String?
  department       String?
  role             UserRole  @default(ACCOUNTANT)
  activity         Activity  @default(BOTH)
  isActive         Boolean   @default(true)
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?
  lastLoginAt      DateTime?
  approvalLimit    Decimal?  @db.Decimal(15, 2)
  avatarUrl        String?
  legalName         String?  // full legal name (HR/Finance-of-record); preferredName is the display name
  preferredName     String?
  legalNameProposed String?  // a self-service legal-name change parked here until HR/Finance verify docs
  legalNamePending  Boolean  @default(false) // true while legalNameProposed awaits sign-off

  // 1:1 link to the HR employee record (single source of truth for personnel data)
  employeeId       String?   @unique
  employee         Employee? @relation("EmployeeUser", fields: [employeeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  createdQuotations  Quotation[]     @relation("QuotationCreatedBy")
  approvedQuotations Quotation[]     @relation("QuotationApprovedBy")
  createdInvoices    Invoice[]       @relation("InvoiceCreatedBy")
  deductedQuotations Quotation[]     @relation("QuotationDeductionBy")
  deductedInvoices   Invoice[]       @relation("InvoiceDeductionBy")
  createdExpenses    Expense[]       @relation("ExpenseCreatedBy")
  approvedExpenses   Expense[]       @relation("ExpenseApprovedBy")
  createdBookings    RentalBooking[] @relation("BookingCreatedBy")
  damageReports      DamageReport[]  @relation("DamageReportedBy")
  loginHistory       LoginHistory[]
  sessions           UserSession[]
  backupCodes        TwoFactorBackupCode[]
  auditLogs          AuditLog[]
  statusChanges      StatusLog[]     @relation("StatusChangedBy")
  crewLinks          CrewMember[]    @relation("CrewParentUser") // crew rows mapped to this ERP user
  projectRoles       ProjectRoleAssignment[] // per-project authorization (V1.2)

  // Contracts module
  contractTemplates  ContractTemplate[] @relation("ContractTemplateCreatedBy")
  contractsCreated   ProjectContract[]  @relation("ProjectContractCreatedBy")
  contractPartyLinks ContractParty[]    @relation("ContractPartyUser")
  // Casting Гўв‚¬вЂќ talent this user represents (TALENT_REP)
  representedTalent  GlobalTalentProfile[] @relation("TalentRepresentative")
  // Breakdown sharing (in-app)
  breakdownSharesFrom BreakdownShare[] @relation("BreakdownShareFrom")
  breakdownSharesTo   BreakdownShare[] @relation("BreakdownShareTo")

  @@map("users")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Active sessions Гўв‚¬вЂќ one row per signed-in device; revoking deletes the row ГўвЂ вЂ™ that token 401s ГўвЂќв‚¬ГўвЂќв‚¬
model UserSession {
  id           String    @id @default(cuid()) // == the `sid` claim baked into the JWT
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceInfo   String?   // raw User-Agent
  ipAddress    String?
  lastSeenAt   DateTime  @default(now())
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@map("user_sessions")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ 2FA recovery codes Гўв‚¬вЂќ single-use, stored only as sha256 hashes ГўвЂќв‚¬ГўвЂќв‚¬
model TwoFactorBackupCode {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String    // sha256 of the normalised code (uppercase, no dashes)
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("two_factor_backup_codes")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Breakdown sharing Гўв‚¬вЂќ in-app "share to selected project users" (read-only) ГўвЂќв‚¬ГўвЂќв‚¬
model BreakdownShare {
  id         String    @id @default(cuid())
  projectId  String
  project    ProductionProject @relation("ProjectBreakdownShares", fields: [projectId], references: [id], onDelete: Cascade)
  kind       String    // DAY | LOCATION | ELEMENTS | REPORT
  refKey     String?   // e.g. shoot-day number, location name, category
  title      String
  message    String?
  sharedById String
  sharedBy   User      @relation("BreakdownShareFrom", fields: [sharedById], references: [id])
  sharedToId String
  sharedTo   User      @relation("BreakdownShareTo", fields: [sharedToId], references: [id])
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([sharedToId, readAt])
  @@index([projectId])
}

// ГўвЂќв‚¬ГўвЂќв‚¬ V1.2 Гўв‚¬вЂќ per-project authorization layer (doc system/05 Г‚В§2) ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
// LAYERS on top of the global role matrix: the global matrix is the coarse gate
// ("can touch Production at all"); these define what a user can do on ONE project.
model PermissionTemplate {
  id          String  @id @default(cuid())
  key         String  @unique // LINE_PRODUCER | UPM | DEPT_HEAD | KEY_ACCOUNTANT | COORDINATOR | OBSERVER
  name        String
  description String?
  // capability flags consumed by project-scoped guards, e.g.
  // { budget:'edit', costReport:'lock', po:'approve', ledger:'edit', crew:'manage' }
  permissions Json
  // hide sensitive fields from this template, e.g. ["dayRateAed","iban","passportNumber"]
  fieldLevelAccess Json?
  isSystem    Boolean @default(true) // seeded standard roles
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments ProjectRoleAssignment[]
  @@map("permission_templates")
}

model ProjectRoleAssignment {
  id         String   @id @default(cuid())
  projectId  String
  project    ProductionProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  templateId String
  template   PermissionTemplate @relation(fields: [templateId], references: [id])
  notes      String?
  costTreatment String @default("COMPANY_OVERHEAD") // COMPANY_OVERHEAD (access only) | PROJECT_HIRE (cost on a budget line)
  createdAt  DateTime @default(now())

  @@unique([projectId, userId]) // one role per user per project
  @@index([userId])
  @@map("project_role_assignments")
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  ipAddress String?
  userAgent String?
  success   Boolean
  createdAt DateTime @default(now())

  @@map("login_history")
}

// -- SYS-13 . D10 -- Email-OTP challenge for revealing masked PII (no SMS gateway) --
model OtpChallenge {
  id            String    @id @default(cuid())
  purpose       String    @default("PII_REVEAL")
  entityType    String    // employee | crewMember
  entityId      String
  fields        String[]  @default([]) // requested field keys (whitelisted server-side)
  target        String    // email the code was sent to (returned masked)
  codeHash      String
  expiresAt     DateTime
  attempts      Int       @default(0)
  maxAttempts   Int       @default(5)
  verifiedAt    DateTime?
  requestedById String?
  createdAt     DateTime  @default(now())

  @@index([entityType, entityId])
  @@map("otp_challenges")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Core: Clients (CRM) ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model Client {
  id              String   @id @default(cuid())
  companyName     String
  tradeName       String?
  trn             String?  // UAE Tax Registration Number
  billingAddress  String?
  city            String?
  country         String   @default("UAE")
  website         String?
  creditLimit     Decimal? @db.Decimal(15, 2)
  paymentTermDays Int      @default(30)
  currency        Currency @default(AED)
  notes           String?
  isActive        Boolean  @default(true)
  status          String   @default("ACTIVE")  // ACTIVE | INACTIVE | BLOCKED
  blockReason     String?
  email           String?
  phone           String?
  contactName     String?
  address         String?
  googleMapsUrl   String?

  // UAE Tax & Compliance
  vatId               String?
  tradeLicenseNumber  String?
  tradeLicenseExpiry  DateTime?
  tradeLicenseUrl     String?
  vatCertificateUrl   String?

  // Banking
  bankName        String?
  bankAccount     String?
  iban            String?
  swiftCode       String?
  bankBranch      String?
  bankAddress     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  contacts           ClientContact[]
  documents          ClientDocument[]
  directoryContacts  Contact[]
  quotations         Quotation[]
  invoices           Invoice[]
  payments           Payment[]
  rentalBookings     RentalBooking[]
  productionProjects ProductionProject[]

  @@map("clients")
}

model ClientDocument {
  id         String   @id @default(cuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  docType    String   @default("OTHER")  // TRADE_LICENSE | VAT_CERTIFICATE | CONTRACT | LPO | AGREEMENT | OTHER
  name       String
  fileUrl    String
  expiryDate DateTime?
  notes      String?
  createdAt  DateTime @default(now())

  @@map("client_documents")
}

model ClientContact {
  id        String  @id @default(cuid())
  clientId  String
  client    Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  title     String?
  email     String?
  mobile    String?
  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  @@map("client_contacts")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Core: Bank Accounts ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model BankAccount {
  id              String   @id @default(cuid())
  accountName     String
  bankName        String
  branch          String?
  accountNumber   String
  iban            String?
  swiftCode       String?
  currency        Currency @default(AED)
  bankAddress     String?
  qrPaymentData   String?
  notes           String?
  isActive        Boolean  @default(true)
  isDefaultInvoice    Boolean @default(false)
  isDefaultQuotation  Boolean @default(false)
  isDefaultReceiving  Boolean @default(false)

  // Dedicated production account Гўв‚¬вЂќ one project's audit-trail bank (ADFC & co.).
  // null = company account. The incentive claim tracker blocks when the applied
  // program's complianceRules.dedicatedBankAccount is true and no account is linked.
  projectId String?
  project   ProductionProject? @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  quotations Quotation[]
  invoices   Invoice[]
  payments   Payment[]

  @@map("bank_accounts")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Core: VAT / Tax Rates ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model TaxRate {
  id          String  @id @default(cuid())
  name        String  // e.g. "UAE VAT 5%", "Zero Rated"
  rate        Decimal @db.Decimal(5, 2) // e.g. 5.00
  vatType     VatType @default(STANDARD)
  description String?
  isDefault   Boolean @default(false)
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())

  quotationItems QuotationItem[]
  invoiceItems   InvoiceItem[]
  serviceItems   ServiceItem[]

  @@map("tax_rates")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Finance: Cost Centers & Service Catalog ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model CostCenter {
  id        String   @id @default(cuid())
  code      String?  @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services  ServiceItem[]

  @@map("cost_centers")
}

model ServiceItem {
  id            String   @id @default(cuid())
  name          String
  category      String?  // e.g. Personnel, Transportation, Fuel, Water, Waste, Support, Consumable
  unitOfMeasure String   @default("Service")  // Day | Hour | Trip | Service | Liter | Gallon | Ton | Unit
  unitPrice     Decimal  @default(0) @db.Decimal(15, 2)
  taxRateId     String?
  taxRate       TaxRate? @relation(fields: [taxRateId], references: [id])
  costCenterId  String?
  costCenter    CostCenter? @relation(fields: [costCenterId], references: [id])
  description   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("service_items")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Finance: Document Sequences ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model DocumentSequence {
  id        String  @id @default(cuid())
  prefix    String  @unique // e.g. "QT", "INV", "RCP", "PO"
  lastNumber Int    @default(0)
  year      Int

  @@map("document_sequences")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Finance: Quotations ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model Quotation {
  id               String          @id @default(cuid())
  quotationNumber  String          @unique // e.g. QT-2024-0001
  clientId         String
  client           Client          @relation(fields: [clientId], references: [id])
  bankAccountId    String?
  bankAccount      BankAccount?    @relation(fields: [bankAccountId], references: [id])
  activity         Activity        @default(RENTAL)
  status           QuotationStatus @default(DRAFT)

  // Dates
  issueDate        DateTime        @default(now())
  validUntil       DateTime?
  approvedAt       DateTime?

  // Pricing
  currency         Currency        @default(AED)
  subtotal         Decimal         @db.Decimal(15, 2) @default(0)
  discountType     String?         // "PERCENT" | "FIXED"
  discountValue    Decimal?        @db.Decimal(15, 2)
  discountAmount   Decimal         @db.Decimal(15, 2) @default(0)
  // Manual fixed deduction (goodwill / adjustment / negotiated reduction) applied before VAT
  deductionAmount      Decimal     @db.Decimal(15, 2) @default(0)
  deductionReason      String?
  deductionAppliedById String?
  deductionAppliedBy   User?       @relation("QuotationDeductionBy", fields: [deductionAppliedById], references: [id])
  deductionAppliedAt   DateTime?
  vatAmount        Decimal         @db.Decimal(15, 2) @default(0)
  total            Decimal         @db.Decimal(15, 2) @default(0)

  // VAT display
  vatDisplay       String          @default("SEPARATE") // "INCLUDED" | "EXCLUDED" | "SEPARATE" | "HIDDEN"
  vatNote          String?

  // Content
  subject          String?
  notes            String?
  termsConditions  String?
  internalNotes    String?

  // Tracking
  createdById      String
  createdBy        User            @relation("QuotationCreatedBy", fields: [createdById], references: [id])
  approvedById     String?
  approvedBy       User?           @relation("QuotationApprovedBy", fields: [approvedById], references: [id])
  sentAt           DateTime?
  clientApprovedAt DateTime?
  clientRejectedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  items    QuotationItem[]
  invoices Invoice[]         @relation("QuotationInvoices")
  bookings RentalBooking[]   @relation("BookingQuotation")

  @@map("quotations")
}

model QuotationItem {
  id            String    @id @default(cuid())
  quotationId   String
  quotation     Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  sortOrder     Int       @default(0)

  kind          String    @default("ASSET")  // ASSET | SERVICE
  serviceItemId String?
  description   String
  details       String?
  quantity      Decimal   @db.Decimal(10, 3) @default(1)
  unit          String?   // "day", "week", "unit", "hour"
  days          Int       @default(1)
  unitPrice     Decimal   @db.Decimal(15, 2)
  discountPct   Decimal   @db.Decimal(5, 2) @default(0)
  lineTotal     Decimal   @db.Decimal(15, 2)

  taxRateId     String?
  taxRate       TaxRate?  @relation(fields: [taxRateId], references: [id])
  taxAmount     Decimal   @db.Decimal(15, 2) @default(0)

  @@map("quotation_items")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Finance: Invoices ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique // e.g. INV-2024-0001
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id])
  bankAccountId   String?
  bankAccount     BankAccount?  @relation(fields: [bankAccountId], references: [id])
  quotationId     String?
  quotation       Quotation?    @relation("QuotationInvoices", fields: [quotationId], references: [id])
  activity        Activity      @default(RENTAL)
  invoiceType     InvoiceType   @default(TAX_INVOICE)
  status          InvoiceStatus @default(DRAFT)

  // Dates
  issueDate       DateTime      @default(now())
  dueDate         DateTime?
  sentAt          DateTime?

  // Pricing
  currency        Currency      @default(AED)
  subtotal        Decimal       @db.Decimal(15, 2) @default(0)
  discountAmount  Decimal       @db.Decimal(15, 2) @default(0)
  // Manual fixed deduction (goodwill / adjustment / negotiated reduction) applied before VAT
  deductionAmount      Decimal  @db.Decimal(15, 2) @default(0)
  deductionReason      String?
  deductionAppliedById String?
  deductionAppliedBy   User?    @relation("InvoiceDeductionBy", fields: [deductionAppliedById], references: [id])
  deductionAppliedAt   DateTime?
  vatAmount       Decimal       @db.Decimal(15, 2) @default(0)
  total           Decimal       @db.Decimal(15, 2) @default(0)
  amountPaid      Decimal       @db.Decimal(15, 2) @default(0)
  amountDue       Decimal       @db.Decimal(15, 2) @default(0)

  vatDisplay      String        @default("SEPARATE")

  // Content
  subject         String?
  notes           String?
  termsConditions String?
  internalNotes   String?
  poNumber        String?       // Client's Purchase Order number

  // Tracking
  createdById     String
  createdBy       User          @relation("InvoiceCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  items    InvoiceItem[]
  payments Payment[]
  booking  RentalBooking? @relation("BookingInvoices", fields: [bookingId], references: [id])
  bookingId String?

  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  sortOrder   Int      @default(0)

  kind        String   @default("ASSET")  // ASSET | SERVICE
  serviceItemId String?
  description String
  details     String?
  quantity    Decimal  @db.Decimal(10, 3) @default(1)
  unit        String?
  days        Int      @default(1)
  unitPrice   Decimal  @db.Decimal(15, 2)
  discountPct Decimal  @db.Decimal(5, 2) @default(0)
  lineTotal   Decimal  @db.Decimal(15, 2)

  taxRateId   String?
  taxRate     TaxRate? @relation(fields: [taxRateId], references: [id])
  taxAmount   Decimal  @db.Decimal(15, 2) @default(0)

  @@map("invoice_items")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Finance: Payments ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model Payment {
  id              String        @id @default(cuid())
  paymentNumber   String        @unique // e.g. RCP-2024-0001
  invoiceId       String
  invoice         Invoice       @relation(fields: [invoiceId], references: [id])
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id])
  bankAccountId   String?
  bankAccount     BankAccount?  @relation(fields: [bankAccountId], references: [id])

  amount          Decimal       @db.Decimal(15, 2)
  currency        Currency      @default(AED)
  paymentDate     DateTime      @default(now())
  method          PaymentMethod @default(BANK_TRANSFER)
  status          PaymentStatus @default(PENDING)
  reference       String?       // Cheque no. / transfer ref
  notes           String?

  clearedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payments")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Finance: Expenses ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model Expense {
  id              String        @id @default(cuid())
  expenseNumber   String        @unique // e.g. EXP-2024-0001
  activity        Activity      @default(RENTAL)
  category        String        // "Fuel", "Maintenance", "Office", "Crew", etc.
  description     String
  amount          Decimal       @db.Decimal(15, 2)
  currency        Currency      @default(AED)
  vatAmount       Decimal       @db.Decimal(15, 2) @default(0)
  totalAmount     Decimal       @db.Decimal(15, 2)
  expenseDate     DateTime      @default(now())
  status          ExpenseStatus @default(DRAFT)
  receiptUrl      String?
  notes           String?

  // Project/Job linking
  projectRef      String?       // Production project ID or Rental booking ID
  productionAccountCode String?  // Budget account code (e.g. "2200") for budget-vs-actual
  vendorName      String?
  supplierVatId   String?       // VAT ID of the supplier (for input VAT reclaim)

  // Supplier link
  supplierId      String?
  supplier        Supplier?     @relation(fields: [supplierId], references: [id])

  createdById     String
  createdBy       User          @relation("ExpenseCreatedBy", fields: [createdById], references: [id])
  approvedById    String?
  approvedBy      User?         @relation("ExpenseApprovedBy", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  paidAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("expenses")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Rental: Assets ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

enum AssetType {
  ARTIST_TRAILER
  STAR_TRAILER
  MAKEUP_TRAILER
  WARDROBE_TRAILER
  MOBILE_TOILET
  GENERATOR
  WATER_TANK
  WASTE_TANK
  SUPPORT_VEHICLE
  CREW_TRANSPORT
  UTILITY_TRAILER
  TRUCK
  TOWING_VEHICLE
  OTHER
}

enum AssetStatus {
  AVAILABLE
  RESERVED
  ON_HIRE
  IN_MAINTENANCE
  OUT_OF_SERVICE
  DAMAGED
  IN_TRANSIT
  RETIRED
  SOLD
}

enum BookingStatus {
  INQUIRY
  QUOTED
  AWAITING_PAYMENT
  APPROVED
  CONTRACT_SENT
  CONTRACT_SIGNED
  SCHEDULED
  DISPATCHED
  DELIVERED
  ACTIVE
  ON_HIRE
  EXTENDED
  PICKUP_SCHEDULED
  RETURNED
  INSPECTED
  COMPLETED
  CLOSED
  CANCELLED
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum MaintenanceType {
  PREVENTIVE
  CORRECTIVE
  INSPECTION
}

enum MaintenanceStatus {
  REPORTED
  SCHEDULED
  PENDING_APPROVAL
  APPROVED
  ASSIGNED
  WAITING_FOR_PARTS
  IN_PROGRESS
  TESTING
  COMPLETED
  CLOSED
  WARRANTY_CLAIM
  CANCELLED
}

enum DriverType {
  EMPLOYEE
  FREELANCE
}

enum JobStatus {
  ASSIGNED
  EN_ROUTE
  ARRIVED
  DELIVERED
  PICKED_UP
  COMPLETED
  CANCELLED
}

enum IncidentType {
  VEHICLE_BREAKDOWN
  TRAILER_ISSUE
  GENERATOR_FAILURE
  ACCIDENT
  DELAY
  SITE_ACCESS_ISSUE
  EQUIPMENT_DAMAGE
  OTHER
}

enum IncidentUrgency {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model Asset {
  id                String      @id @default(cuid())
  name              String
  assetType         AssetType
  // High-level category that drives which fields/tabs/compliance apply.
  // VEHICLE | GENERATOR | TRAILER | MOBILE_OFFICE | EQUIPMENT | OTHER
  category          String?
  // Generic identifier Гўв‚¬вЂќ serial number for non-vehicles (generators, equipment).
  serialNumber      String?
  // Category-specific attributes (engine, fuel, dimensions, power, etc.) as JSON.
  specs             Json?
  // Warranty (non-vehicle assets)
  warrantyExpiry    DateTime?
  warrantyProvider  String?
  plateNumber       String?
  plateEmirate      String?   // DXB | AUH | SHJ | AJM | RAK | FUJ | UAQ
  vinNumber         String?
  purchaseDate      DateTime?
  purchaseValue     Decimal?    @db.Decimal(15, 2)
  currentValue      Decimal?    @db.Decimal(15, 2)
  depreciation      Decimal?    @db.Decimal(5, 2)
  condition         String      @default("GOOD") // EXCELLENT | GOOD | FAIR | POOR
  status            AssetStatus @default(AVAILABLE)
  photos            String[]
  tilePhoto         String?     // photo tagged as the asset's tile background (grid view)
  notes             String?
  qrCode            String?     @unique

  // Self-propelled assets accrue their own mileage; towed units (trailers/caravans) do not.
  tracksMileage      Boolean   @default(false)
  // Current readings (preventive maintenance)
  currentOdometer    Int?
  currentEngineHours Int?

  // Registration & insurance
  registrationExpiry  DateTime?
  registrationDocUrl  String?   // Uploaded registration card / Mulkiya
  insuranceExpiry     DateTime?
  insurancePolicyRef  String?
  insuranceDocUrl     String?   // Uploaded insurance certificate

  // Trailer / caravan detailed specifications (stored as JSON)
  trailerSpecs        Json?     // See TrailerSpecs shape in comments below

  // Generator link (for trailers that use one)
  linkedGeneratorId   String?
  linkedGenerator     Asset?    @relation("TrailerGenerator", fields: [linkedGeneratorId], references: [id])
  connectedTrailers   Asset[]   @relation("TrailerGenerator")

  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookingItems    BookingItem[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  damageReports   DamageReport[]
  driverHistory   DriverJob[]
  incidents       IncidentReport[]
  vendorJobs      VendorMaintenanceJob[]
  spareParts      SparePart[]
  tireRecords     TireRecord[]
  maintenancePlans MaintenancePlan[]
  conditionReports ConditionReport[]
  transportVehicle TransportVehicle? // SYS-12 transport wrapper when this in-house asset is used on a production

  @@map("assets")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Rental: Drivers ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model Driver {
  id              String     @id @default(cuid())
  fullName        String
  driverType      DriverType @default(EMPLOYEE)
  mobile          String?
  email           String?
  emiratesId      String?
  emiratesIdExpiry DateTime?
  passportNumber  String?
  passportExpiry  DateTime?
  licenseNumber   String?
  licenseExpiry   DateTime?
  licenseClass    String?
  visaExpiry      DateTime?
  bankName        String?
  bankAccount     String?
  iban            String?
  dailyRate       Decimal?   @db.Decimal(10, 2)
  weeklyRate      Decimal?   @db.Decimal(10, 2)
  notes           String?
  isActive        Boolean    @default(true)
  photoUrl        String?

  // Document uploads
  emiratesIdDocUrl  String?   // Uploaded copy of Emirates ID
  passportDocUrl    String?   // Uploaded passport copy
  licenseDocUrl     String?   // Uploaded driving license copy

  // Direct-hire link Гўв‚¬вЂќ set when this driver is also an Employee
  employeeId String?  @unique
  employee   Employee? @relation("EmployeeDriverRecord", fields: [employeeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs      DriverJob[]
  incidents IncidentReport[]
  contacts  Contact[]
  payouts   DriverPayout[]
  transportDriver TransportDriver? // SYS-12 transport wrapper when this in-house driver is used on a production

  @@map("drivers")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Freelance driver payouts (payables) ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
model DriverPayout {
  id            String   @id @default(cuid())
  payoutNumber  String   @unique
  driverId      String
  driver        Driver   @relation(fields: [driverId], references: [id])
  status        String   @default("DRAFT") // DRAFT | APPROVED | PAID
  jobIds        String[]
  lineItems     Json?    // [{ jobId, bookingRef, rate, expenses, bonus, lineTotal }]
  subtotal      Decimal  @db.Decimal(15, 2) @default(0)
  total         Decimal  @db.Decimal(15, 2) @default(0)
  currency      Currency @default(AED)
  bankAccountId String?
  paidAt        DateTime?
  paymentRef    String?
  notes         String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("driver_payouts")
}

model DriverJob {
  id          String    @id @default(cuid())
  bookingId   String
  booking     RentalBooking @relation(fields: [bookingId], references: [id])
  driverId    String
  driver      Driver    @relation(fields: [driverId], references: [id])
  assetId     String?
  asset       Asset?    @relation(fields: [assetId], references: [id])

  jobType     String    // "DELIVERY" | "PICKUP" | "TRANSFER"
  status      JobStatus @default(ASSIGNED)
  scheduledAt DateTime
  startedAt   DateTime?
  arrivedAt   DateTime?
  completedAt DateTime?

  pickupLocation    String?
  dropoffLocation   String?
  destinationUrl    String?   // Google Maps link for the drop-off / destination
  bookingLocationId String?   // the scheduled site this leg moves the asset to
  gpsOnArrival      String?
  deliveryPhotos    String[]
  pickupPhotos      String[]
  driverNotes       String?

  fuelExpense       Decimal? @db.Decimal(10, 2)
  tollExpense       Decimal? @db.Decimal(10, 2)
  parkingExpense    Decimal? @db.Decimal(10, 2)
  foodAllowance     Decimal? @db.Decimal(10, 2)
  otherExpense      Decimal? @db.Decimal(10, 2)

  // Proof of work
  signatureUrl      String?     // Client/site rep signature
  receiptPhotoUrls  String[]    // Photos of receipts (fuel, toll, etc.)
  equipmentChecklist Json?      // { itemName: boolean } checklist

  // Bonus
  bonusAmount       Decimal? @db.Decimal(10, 2)
  bonusNotes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("driver_jobs")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Rental: Bookings ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model RentalBooking {
  id              String        @id @default(cuid())
  bookingNumber   String        @unique // e.g. RB-2024-0001
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id])
  quotationId     String?
  quotation       Quotation?    @relation("BookingQuotation", fields: [quotationId], references: [id])
  status          BookingStatus @default(INQUIRY)

  // Dates
  startDate       DateTime
  endDate         DateTime
  deliveryDate    DateTime?
  pickupDate      DateTime?

  // Location
  deliveryAddress String?
  deliveryCity    String?
  deliveryLocationUrl String?   // Google Maps link / pin for the delivery site
  deliveryNotes   String?
  pickupAddress   String?

  // Financials
  currency        Currency      @default(AED)
  subtotal        Decimal       @db.Decimal(15, 2) @default(0)
  discountAmount  Decimal       @db.Decimal(15, 2) @default(0)
  vatAmount       Decimal       @db.Decimal(15, 2) @default(0)
  total           Decimal       @db.Decimal(15, 2) @default(0)
  depositAmount   Decimal?      @db.Decimal(15, 2)

  notes           String?
  internalNotes   String?
  poNumber        String?

  createdById     String
  createdBy       User          @relation("BookingCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items        BookingItem[]
  contract     RentalContract?
  invoices     Invoice[]       @relation("BookingInvoices")
  driverJobs   DriverJob[]
  damageReports DamageReport[]
  incidents    IncidentReport[]
  conditionReports ConditionReport[]
  locations    BookingLocation[]

  @@map("rental_bookings")
}

model BookingItem {
  id          String        @id @default(cuid())
  bookingId   String
  booking     RentalBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  assetId     String
  asset       Asset         @relation(fields: [assetId], references: [id])
  sortOrder   Int           @default(0)

  description String?
  quantity    Int           @default(1)
  unit        String        @default("day")
  unitPrice   Decimal       @db.Decimal(15, 2)
  days        Int           @default(1)
  lineTotal   Decimal       @db.Decimal(15, 2)
  taxAmount   Decimal       @db.Decimal(15, 2) @default(0)

  // Logistics: which site this unit is currently at, what tows it (for towed units),
  // and per-hire mileage readings (self-driven units only).
  bookingLocationId String?      // current site within the hire
  towedById         String?      // BookingItem id of the self-driven unit towing this one
  checkoutOdometer  Int?
  returnOdometer    Int?
  checkoutAt        DateTime?
  returnAt          DateTime?
  mileageAllowanceKm Int?        // included km on this hire; beyond = excess (chargeable)
  allocationStatus  String       @default("RESERVED") // RESERVED | DISPATCHED | ON_LOCATION | RETURNED

  @@map("booking_items")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Rental: Contracts ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model RentalContract {
  id              String         @id @default(cuid())
  contractNumber  String         @unique // e.g. RC-2024-0001
  bookingId       String         @unique
  booking         RentalBooking  @relation(fields: [bookingId], references: [id])
  status          ContractStatus @default(DRAFT)

  // Content
  terms           String?
  cancellationPolicy  String?
  liabilityClauses    String?
  damageDepositClause String?
  paymentTerms        String?

  // Signing
  sentAt          DateTime?
  signedAt        DateTime?
  signedByName    String?
  signedPdfUrl    String?
  signatureData   String?  // base64 or URL

  expiresAt       DateTime?
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("rental_contracts")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Rental: Maintenance ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model MaintenanceLog {
  id              String            @id @default(cuid())
  assetId         String
  asset           Asset             @relation(fields: [assetId], references: [id])
  maintenanceType MaintenanceType   @default(PREVENTIVE)
  status          MaintenanceStatus @default(REPORTED)

  description     String
  scheduledDate   DateTime
  completedDate   DateTime?
  cost            Decimal?          @db.Decimal(10, 2)
  vendorName      String?
  invoiceRef      String?
  partsReplaced   String?
  technicianNotes String?
  nextServiceDate DateTime?
  nextServiceKm   Int?
  downTimeDays    Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("maintenance_logs")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Rental: Fuel ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model FuelLog {
  id            String   @id @default(cuid())
  // In-house fleet asset (optional Гўв‚¬вЂќ SYS-12.E broadened this to also cover hired
  // production vehicles, which are not Assets).
  assetId       String?
  asset         Asset?   @relation(fields: [assetId], references: [id])

  // SYS-12.E Гўв‚¬вЂќ production fuel on a hired TransportVehicle, scoped to a project,
  // optionally attributed to a transport driver (for fuel-by-driver reporting).
  transportVehicleId String?
  transportVehicle   TransportVehicle? @relation(fields: [transportVehicleId], references: [id], onDelete: SetNull)
  projectId          String?
  project            ProductionProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  transportDriverId  String?
  transportDriver    TransportDriver?  @relation(fields: [transportDriverId], references: [id], onDelete: SetNull)

  logDate       DateTime @default(now())
  litres        Decimal  @db.Decimal(8, 2)
  costPerLitre  Decimal  @db.Decimal(6, 3)
  totalCost     Decimal  @db.Decimal(10, 2)
  odometer      Int?
  runtimeHours  Decimal? @db.Decimal(8, 2) // for generators
  receiptUrl    String?
  notes         String?
  bookingRef    String?

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([transportVehicleId])
  @@index([assetId])
  @@index([transportDriverId])
  @@map("fuel_logs")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Rental: Damage ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model DamageReport {
  id            String        @id @default(cuid())
  reportNumber  String        @unique // DR-2024-0001
  assetId       String
  asset         Asset         @relation(fields: [assetId], references: [id])
  bookingId     String?
  booking       RentalBooking? @relation(fields: [bookingId], references: [id])

  description   String
  severity      String        @default("MINOR") // MINOR | MODERATE | SEVERE
  reportedAt    DateTime      @default(now())
  location      String?
  gpsLocation   String?
  photos        String[]
  videos        String[]

  // Resolution
  clientLiable  Boolean       @default(false)
  repairCost    Decimal?      @db.Decimal(10, 2)
  insuranceClaim Boolean      @default(false)
  claimRef      String?
  resolvedAt    DateTime?
  resolutionNotes String?

  reportedById  String
  reportedBy    User          @relation("DamageReportedBy", fields: [reportedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("damage_reports")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Rental: Incidents ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model IncidentReport {
  id              String          @id @default(cuid())
  incidentNumber  String          @unique // INC-2024-0001
  incidentType    IncidentType
  urgency         IncidentUrgency @default(MEDIUM)
  status          IncidentStatus  @default(OPEN)

  title           String
  description     String
  location        String?
  gpsLocation     String?
  occurredAt      DateTime        @default(now())
  photos          String[]

  // Links
  driverId        String?
  driver          Driver?         @relation(fields: [driverId], references: [id])
  assetId         String?
  asset           Asset?          @relation(fields: [assetId], references: [id])
  bookingId       String?
  booking         RentalBooking?  @relation(fields: [bookingId], references: [id])

  // Resolution
  resolvedAt      DateTime?
  resolutionNotes String?
  resolutionCost  Decimal?        @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("incident_reports")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Suppliers ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

enum SupplierStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

enum SupplierDocType {
  TRADE_LICENSE
  VAT_CERTIFICATE
  INSURANCE
  CONTRACT
  BANK_DETAILS
  QUOTATION
  INVOICE
  WARRANTY
  OTHER
}

enum SupplierContactRole {
  SALES
  FINANCE
  OPERATIONS
  TECHNICAL
  MANAGEMENT
  EMERGENCY
  OTHER
}

model Supplier {
  id           String         @id @default(cuid())
  supplierCode String?        @unique  // Auto-generated: SUP-0001
  name         String
  tradeName    String?
  category     String?        // legacy single category (kept for compat)
  categories   String[]       // multi-select: can be multiple from SUPPLIER_CATEGORIES

  // Google Maps / location
  googleMapsUrl   String?
  gpsCoordinates  String?     // "lat,lng" or full Plus Code

  // Link to a MaintenanceVendor when this supplier is also a workshop
  vendorId  String?            @unique
  vendor    MaintenanceVendor? @relation("SupplierVendorLink", fields: [vendorId], references: [id])

  status       SupplierStatus @default(ACTIVE)
  isActive     Boolean        @default(true)   // kept for backward compat (true when ACTIVE)

  // UAE Tax & Compliance
  trn                  String?
  vatId                String?
  trnCertificateUrl    String?
  tradeLicenseNumber   String?
  tradeLicenseExpiry   DateTime?
  tradeLicenseUrl      String?
  businessLicenseUrl   String?
  insuranceDocUrl      String?
  insuranceExpiry      DateTime?
  contractExpiry       DateTime?

  // Primary Contact (kept for quick display)
  contactName  String?
  email        String?
  phone        String?
  address      String?
  city         String?
  country      String   @default("UAE")
  website      String?

  // Banking
  bankName        String?
  bankAccount     String?
  iban            String?
  swiftCode       String?
  bankBranch      String?
  bankAddress     String?

  // Terms & Financials
  currency        Currency @default(AED)
  paymentTermDays Int?
  creditLimit     Decimal? @db.Decimal(15, 2)
  notes           String?
  blacklistReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Logistics vendor ranking (SYS-12)
  ranking VendorRanking?

  expenses  Expense[]
  contacts  Contact[]          // global contact directory links
  supplierContacts SupplierContact[]
  documents        SupplierDocument[]
  accommodationProperties AccommodationProperty[]
  transportVehicles       TransportVehicle[] @relation("TransportVehicleSupplier")
  transportDrivers        TransportDriver[]  @relation("TransportDriverSupplier")

  @@map("suppliers")
}

model SupplierContact {
  id         String              @id @default(cuid())
  supplierId String
  supplier   Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  // Optional link to global Contact directory
  globalContactId String?
  globalContact   Contact? @relation("SupplierContactGlobal", fields: [globalContactId], references: [id])

  fullName   String
  role       SupplierContactRole @default(OTHER)
  jobTitle   String?
  department String?

  mobile     String?
  whatsapp   String?
  email      String?
  officePhone String?
  preferredContact String?     // "mobile" | "whatsapp" | "email"

  isPrimary  Boolean @default(false)
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("supplier_contacts")
}

model SupplierDocument {
  id         String          @id @default(cuid())
  supplierId String
  supplier   Supplier        @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  docType    SupplierDocType @default(OTHER)
  name       String
  fileUrl    String
  expiryDate DateTime?
  notes      String?

  createdAt DateTime @default(now())

  @@map("supplier_documents")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Production: Enums ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

