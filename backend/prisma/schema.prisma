  APPROVED
  PAID
  DISPUTED
  CANCELLED
}

enum VendorPaymentStatus {
  PENDING
  CLEARED
  BOUNCED
}

model MaintenanceVendor {
  id            String      @id @default(cuid())
  name          String
  vendorType    VendorType  @default(AUTO_WORKSHOP)
  secondaryType VendorType?

  // Contact
  contactPerson String?
  mobile        String?
  whatsapp      String?
  email         String?
  website       String?
  address       String?
  city          String?
  country       String?
  googleMapsUrl String?
  gpsCoordinates String?
  notes         String?
  isActive      Boolean @default(true)

  // UAE compliance
  trn                  String?
  tradeLicenseNumber   String?
  tradeLicenseExpiry   DateTime?

  // Payment
  currency        Currency @default(AED)
  paymentTermDays Int      @default(30)
  bankName        String?
  bankAccountNo   String?
  iban            String?
  swiftCode       String?

  // Back-link: set when this vendor was created from a Supplier profile
  supplierId String? @unique
  supplier   Supplier? @relation("SupplierVendorLink")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents VendorDocument[]
  contacts  Contact[]
  jobs      VendorMaintenanceJob[]
  quotations VendorQuotation[]
  invoices  VendorInvoice[]
  payments  VendorPayment[]
  spareParts SparePart[]
  tireRecords TireRecord[]

  @@map("maintenance_vendors")
}

model VendorDocument {
  id       String        @id @default(cuid())
  vendorId String
  vendor   MaintenanceVendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  docType  VendorDocType @default(OTHER)
  name     String
  url      String
  expiryDate DateTime?
  notes    String?

  createdAt DateTime @default(now())

  @@map("vendor_documents")
}

model VendorMaintenanceJob {
  id        String           @id @default(cuid())
  jobNumber String           @unique // VJ-2024-0001
  vendorId  String
  vendor    MaintenanceVendor @relation(fields: [vendorId], references: [id])
  assetId   String?
  asset     Asset?           @relation(fields: [assetId], references: [id])

  status    VendorJobStatus   @default(PENDING)
  priority  VendorJobPriority @default(NORMAL)
  category  String?           // "Engine", "AC", "Electrical", "Tyres", "Body", "Generator", etc.

  problemDescription String
  internalNotes      String?

  openedAt             DateTime @default(now())
  estimatedCompletion  DateTime?
  actualCompletion     DateTime?

  // Asset state at job open
  currentOdometer Int?
  currentHours    Decimal? @db.Decimal(10, 2)
  assetLocation   String?

  // Financials (filled as job progresses)
  laborCost   Decimal? @db.Decimal(15, 2)
  partsCost   Decimal? @db.Decimal(15, 2)
  subtotal    Decimal? @db.Decimal(15, 2)
  vatAmount   Decimal? @db.Decimal(15, 2)
  totalCost   Decimal? @db.Decimal(15, 2)

  photos      String[]
  attachmentUrls String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  spareParts SparePart[]
  quotations VendorQuotation[]
  invoices   VendorInvoice[]
  tireRecords TireRecord[]

  @@map("vendor_maintenance_jobs")
}

model SparePart {
  id       String @id @default(cuid())
  name     String
  partNumber String?
  manufacturer String?

  vendorId String?
  vendor   MaintenanceVendor? @relation(fields: [vendorId], references: [id])
  assetId  String?
  asset    Asset?  @relation(fields: [assetId], references: [id])
  jobId    String?
  job      VendorMaintenanceJob? @relation(fields: [jobId], references: [id])

  // Purchase
  purchaseDate   DateTime?
  purchasePrice  Decimal?   @db.Decimal(12, 2)
  vatAmount      Decimal?   @db.Decimal(12, 2)
  invoiceUrl     String?

  // Installation
  installationDate DateTime?

  // Warranty & lifecycle
  warrantyStart          DateTime?
  warrantyEnd            DateTime?
  expectedLifespanYears  Decimal?  @db.Decimal(5, 2)
  expectedLifespanKm     Int?
  expectedLifespanHours  Int?

  condition String?  @default("NEW") // NEW | GOOD | FAIR | WORN
  notes     String?
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("spare_parts")
}

model TireRecord {
  id       String @id @default(cuid())
  assetId  String
  asset    Asset  @relation(fields: [assetId], references: [id])
  vendorId String?
  vendor   MaintenanceVendor? @relation(fields: [vendorId], references: [id])
  jobId    String?
  job      VendorMaintenanceJob? @relation(fields: [jobId], references: [id])

  position     String   // FL | FR | RL | RR | SPARE | DUAL_RL | DUAL_RR
  manufacturer String?
  model        String?
  size         String?  // e.g. "275/70R22.5"

  purchaseDate    DateTime?
  installationDate DateTime?
  purchasePrice   Decimal?  @db.Decimal(12, 2)
  invoiceUrl      String?

  warrantyStart        DateTime?
  warrantyEnd          DateTime?
  expectedLifespanKm   Int?
  expectedLifespanYears Decimal? @db.Decimal(5, 2)

  odometerAtInstall Int?
  currentOdometer   Int?

  notes    String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tire_records")
}

model VendorQuotation {
  id              String @id @default(cuid())
  quotationNumber String @unique // VQ-2024-0001
  vendorId        String
  vendor          MaintenanceVendor @relation(fields: [vendorId], references: [id])
  jobId           String?
  job             VendorMaintenanceJob? @relation(fields: [jobId], references: [id])

  status    String   @default("PENDING") // PENDING | APPROVED | REJECTED | SUPERSEDED
  issuedAt  DateTime @default(now())
  validUntil DateTime?
  approvedAt DateTime?

  laborCost  Decimal? @db.Decimal(15, 2)
  partsCost  Decimal? @db.Decimal(15, 2)
  subtotal   Decimal  @db.Decimal(15, 2) @default(0)
  vatAmount  Decimal  @db.Decimal(15, 2) @default(0)
  total      Decimal  @db.Decimal(15, 2) @default(0)

  vendorRef   String?   // Vendor's own quotation number
  docUrl      String?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices VendorInvoice[]

  @@map("vendor_quotations")
}

model VendorInvoice {
  id            String              @id @default(cuid())
  invoiceNumber String              @unique // VIN-2024-0001
  vendorId      String
  vendor        MaintenanceVendor   @relation(fields: [vendorId], references: [id])
  jobId         String?
  job           VendorMaintenanceJob? @relation(fields: [jobId], references: [id])
  quotationId   String?
  quotation     VendorQuotation?    @relation(fields: [quotationId], references: [id])

  status     VendorInvoiceStatus @default(SUBMITTED)
  issuedAt   DateTime            @default(now())
  dueDate    DateTime?
  approvedAt DateTime?

  laborCost   Decimal  @db.Decimal(15, 2) @default(0)
  partsCost   Decimal  @db.Decimal(15, 2) @default(0)
  subtotal    Decimal  @db.Decimal(15, 2) @default(0)
  vatAmount   Decimal  @db.Decimal(15, 2) @default(0)
  total       Decimal  @db.Decimal(15, 2) @default(0)
  amountPaid  Decimal  @db.Decimal(15, 2) @default(0)
  amountDue   Decimal  @db.Decimal(15, 2) @default(0)

  vendorInvoiceRef String?  // Vendor's own invoice number
  docUrl           String?
  notes            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments VendorPayment[]

  @@map("vendor_invoices")
}

model VendorPayment {
  id            String    @id @default(cuid())
  paymentNumber String    @unique // VP-2024-0001
  vendorId      String
  vendor        MaintenanceVendor @relation(fields: [vendorId], references: [id])
  invoiceId     String?
  invoice       VendorInvoice? @relation(fields: [invoiceId], references: [id])

  amount      Decimal            @db.Decimal(15, 2)
  currency    Currency           @default(AED)
  paymentDate DateTime           @default(now())
  method      PaymentMethod      @default(BANK_TRANSFER)
  status      VendorPaymentStatus @default(PENDING)
  reference   String?
  notes       String?
  receiptUrl  String?

  clearedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("vendor_payments")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Contact Directory ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

enum ContactType {
  CREW_MEMBER
  VENDOR_EMPLOYEE
  CLIENT_EMPLOYEE
  WORKSHOP_EMPLOYEE
  DRIVER_CONTACT
  SUPPLIER_EMPLOYEE
  FREELANCER
  OTHER
}

model Contact {
  id          String      @id @default(cuid())
  name        String
  contactType ContactType @default(OTHER)
  jobTitle    String?
  department  String?
  company     String?     // free-text (for workshop staff, independent, etc.)

  // Communication
  mobile    String?
  whatsapp  String?
  landline  String?     // UAE landline e.g. +971 2 xxx xxxx
  email     String?

  // Optional links to existing entities
  clientId   String?
  client     Client?            @relation(fields: [clientId], references: [id])
  vendorId   String?
  vendor     MaintenanceVendor? @relation(fields: [vendorId], references: [id])
  supplierId String?
  supplier   Supplier?          @relation(fields: [supplierId], references: [id])
  driverId   String?
  driver     Driver?            @relation(fields: [driverId], references: [id])

  notes    String?
  isActive Boolean @default(true)

  // Reverse: SupplierContacts that point to this global Contact entry
  supplierContactLinks SupplierContact[] @relation("SupplierContactGlobal")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contacts")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Company Settings (singleton) ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model CompanySettings {
  id              String   @id @default("singleton")

  // Company Identity
  name            String   @default("The Film Makers FZ LLC")
  tradeName       String?
  trn             String?   // UAE Tax Registration Number
  address         String?
  city            String?
  country         String   @default("UAE")
  phone           String?
  email           String?
  website         String?
  logoUrl         String?

  // Finance Defaults
  defaultCurrency        String  @default("AED")
  vatRate                Decimal @db.Decimal(5, 2) @default(5)
  defaultPaymentTermDays Int     @default(30)
  invoicePrefix          String  @default("INV")
  quotationPrefix        String  @default("QT")
  bookingPrefix          String  @default("RB")

  // Default Bank Details (shown on invoices/quotations)
  defaultBankName        String?
  defaultBankAccount     String?
  defaultBankIban        String?
  defaultBankSwift       String?
  defaultBankBranch      String?
  defaultBankAddress     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("company_settings")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Audit Trail ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String   // "CREATE" | "UPDATE" | "DELETE" | "EXPORT" | "APPROVE"
  resource   String   // "Invoice" | "Quotation" | etc.
  resourceId String
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([resource, resourceId])
  @@index([userId])
  @@map("audit_logs")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Global Status Change Log ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
// Central audit trail for every status transition across all modules

model StatusLog {
  id             String    @id @default(cuid())
  module         String    // "Invoice" | "Quotation" | "Booking" | "Asset" | "Maintenance" | "Expense"
  recordId       String    // ID of the record whose status changed
  recordRef      String?   // Human-readable ref (e.g. INV-2026-0001)
  previousStatus String?   // null when record is first created
  newStatus      String
  changedById    String
  changedBy      User      @relation("StatusChangedBy", fields: [changedById], references: [id])
  changedAt      DateTime  @default(now())
  notes          String?   // Optional comment explaining the change
  isAutomatic    Boolean   @default(false) // true for system-triggered changes (e.g. overdue cron)
  metadata       Json?     // Extra context (e.g. payment amount that triggered PAID)

  @@index([module, recordId])
  @@index([changedById])
  @@index([changedAt])
  @@map("status_logs")
}

// ============================================================
// COMPANY MANAGEMENT MODULE
// ============================================================

model CompanyProfile {
  id                    String   @id @default(cuid())
  legalName             String
  tradeName             String?
  logoUrl               String?
  darkLogoUrl           String?  // dark-mode logo (white lettering) вЂ” used by the app shell in dark theme
  stampUrl              String?
  registrationNumber    String?
  trn                   String?
  corporateTaxNumber    String?
  poBox                 String?
  website               String?
  mainEmail             String?
  billingEmail          String?
  mainPhone             String?
  emergencyPhone        String?
  address               String?
  city                  String?
  emirate               String?
  country               String?  @default("United Arab Emirates")
  timeZone              String?  @default("Asia/Dubai")
  currency              String?  @default("AED")
  language              String?  @default("English")
  classification        String?  @default("Mainland")
  licensingAuthority    String?
  licenseType           String?
  businessActivity      String?
  tradeLicenseNumber    String?
  licenseIssueDate      DateTime?
  licenseExpiryDate     DateTime?
  licenseStatus         String?  @default("Active")
  mohreEstablishmentNumber       String?
  labourFileNumber               String?
  immigrationEstablishmentNumber String?
  chamberOfCommerceNumber        String?
  economicDeptRegistration       String?
  freeZoneAuthority              String?
  freeZoneRegistrationNumber     String?
  establishmentCardNumber        String?
  immigrationFileNumber          String?
  vatStatus                      String?  @default("Registered")
  vatRegistrationDate            DateTime?
  defaultVatRate                 Float    @default(5)
  corporateTaxStatus             String?  @default("Registered")
  corporateTaxRegistrationDate   DateTime?
  defaultCorporateTaxRate        Float    @default(9)
  invoiceLogoUrl        String?
  watermarkUrl          String?
  emailSignature        String?
  brandPrimaryColor     String?  @default("#0f172a")
  brandSecondaryColor   String?  @default("#c3a56e")
  brandAccentColor      String?  @default("#2563eb")
  // Preferences / document numbering (consolidated from CompanySettings)
  invoicePrefix          String?  @default("INV")
  quotationPrefix        String?  @default("QT")
  bookingPrefix          String?  @default("RB")
  receiptPrefix          String?  @default("RCP")
  defaultPaymentTermDays Int      @default(30)
  dateFormat             String?  @default("DD/MM/YYYY")
  // Invoice / quotation report appearance (colors, titles, column toggles, footer textГўв‚¬В¦)
  documentSettings       Json?
  // SMTP + collections/dunning configuration (smtp, remindersEnabled, rules[], statementFooter)
  emailSettings          Json?
  setupComplete         Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  bankAccounts          CompanyBankAccount[]
  locations             CompanyLocation[]
  documents             CompanyDocument[]

  @@map("company_profiles")
}

model CompanyBankAccount {
  id            String   @id @default(cuid())
  companyId     String
  company       CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  accountName   String
  bankName      String
  branch        String?
  accountNumber String?
  iban          String?
  swift         String?
  currency      String?  @default("AED")
  bankAddress   String?
  isDefault     Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("company_bank_accounts")
}

model CompanyLocation {
  id            String   @id @default(cuid())
  companyId     String
  company       CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name          String
  type          String?  @default("Head Office")
  address       String?
  googleMapsUrl String?
  gpsLat        Float?
  gpsLng        Float?
  contactNumber String?
  manager       String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("company_locations")
}

model CompanyDocument {
  id          String   @id @default(cuid())
  companyId   String
  company     CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title       String
  type        String?
  fileUrl     String?
  issueDate   DateTime?
  expiryDate  DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("company_documents")
}

// ============================================================
// HR & WORKFORCE MODULE
// ============================================================

model Employee {
  id                String   @id @default(cuid())
  employeeNumber    String?  @unique
  firstName         String
  middleName        String?
  lastName          String?
  displayName       String?
  photoUrl          String?
  gender            String?
  dateOfBirth       DateTime?
  nationality       String?
  maritalStatus     String?
  status            String   @default("Active")
  mobile            String?
  whatsapp          String?
  email             String?
  personalEmail     String?
  homeAddress       String?
  emergencyContactName         String?
  emergencyContactNumber       String?
  emergencyContactRelationship String?
  department        String?
  position          String?
  jobTitle          String?
  grade             String?
  employmentType    String?  @default("FullTime")
  joiningDate       DateTime?
  probationStart    DateTime?
  probationEnd      DateTime?
  contractStart     DateTime?
  contractEnd       DateTime?
  resignationDate   DateTime?
  terminationDate   DateTime?
  reportingManagerId String?
  manager           Employee?  @relation("ManagerReports", fields: [reportingManagerId], references: [id])
  reports           Employee[] @relation("ManagerReports")
  workLocation      String?
  labourCardNumber     String?
  workPermitNumber     String?
  workPermitIssueDate  DateTime?
  workPermitExpiryDate DateTime?
  labourCardStatus     String?
  employmentCardNumber     String?
  employmentCardIssueDate  DateTime?
  employmentCardExpiryDate DateTime?
  employmentPermitInfo     String?
  emiratesId        String?
  emiratesIdExpiry  DateTime?
  passportNumber    String?
  passportExpiry    DateTime?
  visaNumber        String?
  visaExpiry        DateTime?
  payStructure      String?  @default("Monthly")
  basicSalary       Float    @default(0)
  housingAllowance  Float    @default(0)
  transportAllowance Float   @default(0)
  foodAllowance     Float    @default(0)
  mobileAllowance   Float    @default(0)
  fuelAllowance     Float    @default(0)
  otherAllowance    Float    @default(0)
  dailyRate         Float    @default(0)
  hourlyRate        Float    @default(0)
  bankName          String?
  bankAccountName   String?
  iban              String?
  accountNumber     String?
  swift             String?
  isDriver          Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  documents         EmployeeDocument[]
  leaveRequests     LeaveRequest[]
  assets            AssetAssignment[]
  certifications    Certification[]
  driverProfile     DriverProfile?
  driverRecord      Driver?    @relation("EmployeeDriverRecord")
  // 1:1 system user account (optional Гўв‚¬вЂќ created when system access is granted)
  user              User?      @relation("EmployeeUser")

  @@map("employees")
}

model EmployeeDocument {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type        String?
  title       String
  fileUrl     String?
  issueDate   DateTime?
  expiryDate  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("employee_documents")
}

model LeaveRequest {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type        String   @default("Annual")
  startDate   DateTime
  endDate     DateTime
  days        Float    @default(0)
  status      String   @default("Pending")
  reason      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("leave_requests")
}

model AttendanceRecord {
  id          String   @id @default(cuid())
  employeeId  String
  date        DateTime @default(now())
  clockIn     DateTime?
  clockOut    DateTime?
  hours       Float    @default(0)
  status      String   @default("Present")
  createdAt   DateTime @default(now())

  @@map("attendance_records")
}

model DriverProfile {
  id                String   @id @default(cuid())
  employeeId        String   @unique
  employee          Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  driverType        String?  @default("EmployeeDriver")
  licenseNumber     String?
  licenseCategory   String?
  licenseIssueDate  DateTime?
  licenseExpiryDate DateTime?
  driverStatus      String?  @default("Available")
  rating            Float?
  dailyRate         Float    @default(0)
  tripRate          Float    @default(0)
  overtimeRate      Float    @default(0)
  paymentTerms      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("driver_profiles")
}

model AssetAssignment {
  id             String   @id @default(cuid())
  employeeId     String
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  assetName      String
  assetType      String?
  assignmentDate DateTime?
  returnDate     DateTime?
  status         String   @default("Assigned")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("asset_assignments")
}

model Certification {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  name        String
  issuingBody String?
  issueDate   DateTime?
  expiryDate  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("certifications")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Preventive maintenance ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
model MaintenancePlan {
  id            String   @id @default(cuid())
  assetId       String
  asset         Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  taskName      String
  intervalDays  Int?
  intervalKm    Int?
  intervalHours Int?
  lastServiceDate     DateTime?
  lastServiceOdometer Int?
  lastServiceHours    Int?
  notes         String?
  isActive      Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("maintenance_plans")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Delivery / return condition inspections ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
model ConditionReport {
  id            String        @id @default(cuid())
  bookingId     String
  booking       RentalBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  assetId       String?
  asset         Asset?        @relation(fields: [assetId], references: [id])
  type          String        // DELIVERY | RETURN
  inspectedAt   DateTime      @default(now())
  inspectedBy   String?
  odometer      Int?
  fuelLevel     String?
  checklist     Json?         // [{ item, ok, note }]
  damageNotes   String?
  photos        String[]
  signatureName String?
  notes         String?
  createdAt DateTime @default(now())

  @@map("condition_reports")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Role-based access control ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
// One row per (role, module) with an access level: 0 none Г‚В· 1 view Г‚В· 2 edit Г‚В· 3 manage
model RolePermission {
  id     String   @id @default(cuid())
  role   UserRole
  module String
  level  Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([role, module])
  @@map("role_permissions")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Collections: dunning / reminder audit log ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
model ReminderLog {
  id        String   @id @default(cuid())
  invoiceId String
  clientId  String?
  level     String   // rule level key, e.g. BEFORE_DUE / DUE / OVERDUE_7 / MANUAL
  channel   String   @default("email")
  to        String?
  subject   String?
  status    String   @default("SENT") // SENT | FAILED
  error     String?
  sentById  String?
  sentAt    DateTime @default(now())

  @@index([invoiceId])
  @@map("reminder_logs")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ CRM: leads & sales pipeline ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
model Lead {
  id             String   @id @default(cuid())
  companyName    String?
  contactName    String?
  email          String?
  phone          String?
  source         String? // Referral | Website | Walk-in | Repeat | Other
  status         String   @default("NEW") // NEW | CONTACTED | QUALIFIED | CONVERTED | LOST
  estimatedValue Decimal? @db.Decimal(15, 2)
  ownerId        String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  opportunities Opportunity[]

  @@map("leads")
}

model Opportunity {
  id                String    @id @default(cuid())
  title             String
  clientId          String?
  leadId            String?
  lead              Lead?     @relation(fields: [leadId], references: [id])
  stage             String    @default("QUALIFIED") // QUALIFIED | PROPOSAL | NEGOTIATION | WON | LOST
  value             Decimal   @default(0) @db.Decimal(15, 2)
  probability       Int       @default(50)
  expectedCloseDate DateTime?
  source            String?
  ownerId           String?
  quotationId       String?
  lostReason        String?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("opportunities")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Production: freelance crew directory ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
model CrewMember {
  id                    String    @id @default(cuid())
  name                  String
  department            String?
  role                  String?
  nationality           String?
  baseCountry           String?
  baseEmirate           String? // home emirate/city for UAE locals (drives per-diem eligibility)
  isLocal               Boolean   @default(true) // local hire vs flown-in
  bio                   String? // "Description" (ADFC)
  reelUrl               String?
  // ГўвЂќв‚¬ГўвЂќв‚¬ Professional profile (ADFC reel-scout parity) ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
  resumeUrl             String? // CV / resume PDF ("View File / Resume")
  skills                String? // Special Skills & Experience (free text / newline list)
  links                 Json? // Weblinks: [{ label, url }]  (IMDB, showreel, website, socials)
  credits               Json? // Previous work: [{ year, title, role, department }]
  categories            Json? // Extra dept-role categories beyond primary: [{ department, role }]
  affiliations          Json? // Experience tags: ["Emirati Crew & Talent","International Productions Experience",Гўв‚¬В¦]
  email                 String?
  phone                 String? // local number
  phone2                String? // second / international number
  photoUrl              String?
  // Rate card Гўв‚¬вЂќ SHOOT rate + a shared PREP/WRAP rate (prep and wrap are always the
  // same rate). Both pull into budget labour blocks per stage.
  dayRateUsd            Decimal?  @db.Decimal(12, 2) // shoot day rate
  dayRateAed            Decimal?  @db.Decimal(12, 2)
  weeklyRateUsd         Decimal?  @db.Decimal(12, 2) // shoot weekly rate
  weeklyRateAed         Decimal?  @db.Decimal(12, 2)
  prepWrapDayRateUsd    Decimal?  @db.Decimal(12, 2)
  prepWrapDayRateAed    Decimal?  @db.Decimal(12, 2)
  prepWrapWeeklyRateUsd Decimal?  @db.Decimal(12, 2)
  prepWrapWeeklyRateAed Decimal?  @db.Decimal(12, 2)
  // Identity documents
  passportNumber        String?
  passportExpiry        DateTime?
  visaNumber            String?
  visaExpiry            DateTime?
  emiratesId            String?
  emiratesIdExpiry      DateTime?
  passportDocUrl        String?
  visaDocUrl            String?
  emiratesIdDocUrl      String?
  ibanDocUrl            String? // IBAN / bank certificate
  // Banking (for freelancer payments)
  bankName              String?
  bankAddress           String?
  accountName           String?
  accountNumber         String?
  swiftCode             String?
  routingNumber         String?
  iban                  String?
  status                String    @default("ACTIVE") // ACTIVE | INACTIVE
  notes                 String?

  // ГўвЂќв‚¬ГўвЂќв‚¬ ERP identity link (V1.2 Гўв‚¬вЂќ doc system/05) ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
  // null  = portal/payroll person ONLY Гўв‚¬вЂќ zero ERP ledger access (temporary crew)
  // set   = this crew member IS a real parent-system User (staff LP, key accountant)
  //         ГўвЂ вЂ™ their global RBAC + project role unlock ledger/PO/cost-report rights.
  // Keeps the parent user directory clean: temporary crew never become Users.
  parentSystemUserId String?
  parentSystemUser   User?   @relation("CrewParentUser", fields: [parentSystemUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments ProductionCrew[]

  travelerProfile TravelerProfile?

  @@index([parentSystemUserId])
  @@map("crew_members")
}

