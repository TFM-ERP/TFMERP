// SYS-12.C Гўв‚¬вЂќ Transport operations
//
// PURPOSE DISTINCTION (non-negotiable): the existing Rentals module rents OUT the
// company's own vehicles & caravans (a rental business). This module HIRES vehicles
// & drivers from external rental companies FOR productions. A TransportVehicle is a
// thin wrapper that is EITHER in-house (links an Asset) OR hired (links a Supplier
// rental company + rate/period + Гўв‚¬вЂќ in slice E Гўв‚¬вЂќ a PurchaseOrder). Same for drivers.
// It shares the fleet data but the purpose & the money flow are different.
// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

enum TransportVehicleSource {
  IN_HOUSE // links an existing fleet Asset
  HIRED // rented from an external rental-company Supplier
}

enum TransportVehicleType {
  SEDAN
  SUV
  VAN
  MINIBUS
  BUS
  LUXURY
  PICKUP
  TRUCK
  PRODUCTION_VEHICLE
  OTHER
}

enum TransportDriverSource {
  IN_HOUSE // links an existing fleet Driver
  HIRED // supplied by the rental / chauffeur company
  FREELANCE // independent driver hired directly
}

enum TransportOrderType {
  TALENT_PICKUP
  CREW_SHUTTLE
  AIRPORT_PICKUP
  AIRPORT_DROPOFF
  EQUIPMENT_RUN
  INTER_LOCATION
  OTHER
}

enum TransportStatus {
  REQUESTED
  ASSIGNED
  EN_ROUTE
  COMPLETED
  CANCELLED
}

// A vehicle available to a production Гўв‚¬вЂќ in-house (Asset) OR hired (Supplier).
model TransportVehicle {
  id     String                 @id @default(cuid())
  source TransportVehicleSource @default(HIRED)

  // In-house link (one-to-one with the fleet Asset)
  assetId String? @unique
  asset   Asset?  @relation(fields: [assetId], references: [id], onDelete: SetNull)

  // Hired link Гўв‚¬вЂќ the rental-company vendor
  supplierId String?
  supplier   Supplier? @relation("TransportVehicleSupplier", fields: [supplierId], references: [id], onDelete: SetNull)

  vehicleType  TransportVehicleType @default(SEDAN)
  make         String?
  model        String?
  plateNumber  String?
  plateEmirate String?
  year         Int?
  capacity     Int?                 @default(4)
  color        String?

  // Hire commercials
  dailyRate    Decimal?  @db.Decimal(12, 2)
  monthlyRate  Decimal?  @db.Decimal(12, 2)
  currency     Currency  @default(AED)
  rentalStart  DateTime?
  rentalEnd    DateTime?
  mileageLimit Int?
  insuranceRef String?

  // Two-Ledger commitment for the hire (SYS-12.E)
  purchaseOrderId String?        @unique
  purchaseOrder   PurchaseOrder? @relation("TransportVehiclePO", fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  postedTxnId     String? // ProjectTransaction id once the hire is posted as an actual

  // Optional project scoping (null = master pool, usable across projects)
  projectId String?
  project   ProductionProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  status   String  @default("AVAILABLE") // AVAILABLE | ASSIGNED | MAINTENANCE | OFF_HIRE
  notes    String?
  isActive Boolean @default(true)

  orders        TransportOrder[]
  shuttleRoutes ShuttleRoute[]
  arrivals      TravelArrival[]
  fuelLogs      FuelLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([supplierId])
  @@map("transport_vehicles")
}

// A driver available to a production Гўв‚¬вЂќ in-house (Driver) OR hired/freelance.
model TransportDriver {
  id     String                @id @default(cuid())
  source TransportDriverSource @default(HIRED)

  // In-house link (one-to-one with the fleet Driver)
  driverId String? @unique
  driver   Driver? @relation(fields: [driverId], references: [id], onDelete: SetNull)

  // Hired link Гўв‚¬вЂќ the chauffeur / rental company
  supplierId String?
  supplier   Supplier? @relation("TransportDriverSupplier", fields: [supplierId], references: [id], onDelete: SetNull)

  fullName      String
  mobile        String?
  licenseNumber String?
  licenseExpiry DateTime?
  languages     String[]  @default([])
  notes         String?
  isActive      Boolean   @default(true)

  orders        TransportOrder[]
  shuttleRoutes ShuttleRoute[]
  arrivals      TravelArrival[]
  fuelLogs      FuelLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([supplierId])
  @@map("transport_drivers")
}

// A movement: a vehicle + driver taking passengers from A to B at a time.
model TransportOrder {
  id        String             @id @default(cuid())
  projectId String?
  project   ProductionProject? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  type         TransportOrderType @default(TALENT_PICKUP)
  fromLocation String?
  toLocation   String?
  scheduledAt  DateTime?

  vehicleId String?
  vehicle   TransportVehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  driverId  String?
  driver    TransportDriver?  @relation(fields: [driverId], references: [id], onDelete: SetNull)

  status        TransportStatus @default(REQUESTED)
  purpose       String?
  passengerNote String? // free-text count when passengers aren't identity-tracked
  notes         String?

  passengers TransportPassenger[]

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId, scheduledAt])
  @@index([status])
  @@map("transport_orders")
}

// Join: an identity passenger on a transport order (the universal TravelerProfile).
model TransportPassenger {
  id         String          @id @default(cuid())
  orderId    String
  order      TransportOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  travelerId String
  traveler   TravelerProfile @relation(fields: [travelerId], references: [id], onDelete: Cascade)

  @@unique([orderId, travelerId])
  @@map("transport_passengers")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
// SYS-12.D Гўв‚¬вЂќ Shuttle & bus scheduling
//
// Recurring, multi-stop routes (Hotel A ГўвЂ вЂ™ Base Camp ГўвЂ вЂ™ Studio ГўвЂ вЂ™ Airport) with a
// capacity, an assigned vehicle + driver (reusing SYS-12.C), an ordered set of
// stops, and a regular-rider manifest (universal TravelerProfile, optionally
// boarding at a named stop). Capacity = vehicle capacity (or route override).
// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

enum ShuttleFrequency {
  DAILY
  WEEKDAYS
  WEEKLY
  CUSTOM
}

model ShuttleRoute {
  id        String             @id @default(cuid())
  projectId String?
  project   ProductionProject? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name          String
  frequency     ShuttleFrequency @default(DAILY)
  daysOfWeek    String[]         @default([]) // ['MON','TUE',...] when CUSTOM/WEEKLY
  departureTime String? // "07:00" Гўв‚¬вЂќ first-stop departure
  capacity      Int? // overrides vehicle capacity when set

  vehicleId String?
  vehicle   TransportVehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  driverId  String?
  driver    TransportDriver?  @relation(fields: [driverId], references: [id], onDelete: SetNull)

  status String  @default("ACTIVE") // ACTIVE | PAUSED | ARCHIVED
  notes  String?

  stops  ShuttleStop[]
  riders ShuttleRider[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@map("shuttle_routes")
}

model ShuttleStop {
  id      String       @id @default(cuid())
  routeId String
  route   ShuttleRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

  sequence       Int
  name           String
  arrivalTime    String? // "07:20"
  gpsCoordinates String?
  notes          String?

  boardingRiders ShuttleRider[] @relation("RiderPickupStop")

  @@index([routeId])
  @@map("shuttle_stops")
}

model ShuttleRider {
  id         String          @id @default(cuid())
  routeId    String
  route      ShuttleRoute    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  travelerId String
  traveler   TravelerProfile @relation(fields: [travelerId], references: [id], onDelete: Cascade)

  pickupStopId String?
  pickupStop   ShuttleStop? @relation("RiderPickupStop", fields: [pickupStopId], references: [id], onDelete: SetNull)

  notes String?

  createdAt DateTime @default(now())

  @@unique([routeId, travelerId])
  @@map("shuttle_riders")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
// SYS-10 V3.0 Гўв‚¬вЂќ Talent Intelligence Platform (V3-B representation/credits, V3-C CRM)
// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

enum RepresentationType {
  AGENCY
  MANAGER
  LAWYER
  PUBLICIST
  BUSINESS_MANAGER
  ASSISTANT
}

enum CreditType {
  FILM
  TV
  COMMERCIAL
  THEATRE
  OTHER
}

enum InteractionType {
  MEETING
  PHONE_CALL
  VIDEO_CALL
  FESTIVAL_MEETING
  SCRIPT_SENT
  AUDITION_INVITE
  CALLBACK_INVITE
  OFFER_MADE
  OFFER_DECLINED
  BOOKING_CONFIRMED
  CONTRACT_SIGNED
  EMAIL
  NOTE
  OTHER
}

// V3-B Гўв‚¬вЂќ a representation relationship (agency/manager/lawyer/publicist/biz-mgr/PA).
model TalentRepresentation {
  id       String              @id @default(cuid())
  talentId String
  talent   GlobalTalentProfile @relation(fields: [talentId], references: [id], onDelete: Cascade)

  repType       RepresentationType @default(AGENCY)
  name          String
  company       String?
  email         String?
  phone         String?
  commissionPct Decimal?           @db.Decimal(5, 2)
  territory     String?
  contractStart DateTime?
  contractEnd   DateTime?
  isPrimary     Boolean            @default(false)
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([talentId])
  @@map("talent_representations")
}

// V3-B Гўв‚¬вЂќ a filmography / credit line.
model TalentCredit {
  id       String              @id @default(cuid())
  talentId String
  talent   GlobalTalentProfile @relation(fields: [talentId], references: [id], onDelete: Cascade)

  creditType        CreditType @default(FILM)
  title             String
  role              String?
  year              Int?
  productionCompany String?
  director          String?
  link              String?
  notes             String?

  createdAt DateTime @default(now())

  @@index([talentId])
  @@map("talent_credits")
}

// V3-C Гўв‚¬вЂќ CRM interaction timeline entry.
model TalentInteraction {
  id       String              @id @default(cuid())
  talentId String
  talent   GlobalTalentProfile @relation(fields: [talentId], references: [id], onDelete: Cascade)

  type          InteractionType @default(NOTE)
  occurredAt    DateTime        @default(now())
  userId        String?
  notes         String?
  attachments   String[]        @default([])
  followUpDate  DateTime?
  projectId     String?
  castingCallId String?

  createdAt DateTime @default(now())

  @@index([talentId])
  @@index([followUpDate])
  @@map("talent_interactions")
}

// V3-E Гўв‚¬вЂќ a saved search template (reusable filter set).
model SavedSearch {
  id        String   @id @default(cuid())
  name      String
  ownerId   String?
  filters   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("saved_searches")
}

// V3-E Гўв‚¬вЂќ a curated talent list / shortlist (cross-project).
model TalentList {
  id        String  @id @default(cuid())
  name      String
  kind      String  @default("LIST") // LIST | SHORTLIST
  ownerId   String?
  projectId String? // optional project shortlist (scalar link)
  notes     String?

  members TalentListMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("talent_lists")
}

model TalentListMember {
  id       String              @id @default(cuid())
  listId   String
  list     TalentList          @relation(fields: [listId], references: [id], onDelete: Cascade)
  talentId String
  talent   GlobalTalentProfile @relation(fields: [talentId], references: [id], onDelete: Cascade)
  notes    String?
  addedAt  DateTime            @default(now())

  @@unique([listId, talentId])
  @@map("talent_list_members")
}

