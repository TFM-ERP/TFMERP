model BookingItem {
  id          String        @id @default(cuid())
  bookingId   String
  booking     RentalBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  assetId     String
  asset       Asset         @relation(fields: [assetId], references: [id])
  sortOrder   Int           @default(0)

  description String?
  quantity    Int           @default(1)
  unit        String        @default("day")
  unitPrice   Decimal       @db.Decimal(15, 2)
  days        Int           @default(1)
  lineTotal   Decimal       @db.Decimal(15, 2)
  taxAmount   Decimal       @db.Decimal(15, 2) @default(0)

  @@map("booking_items")
}

// ── Rental: Contracts ─────────────────────────────────────────────────────────

model RentalContract {
  id              String         @id @default(cuid())
  contractNumber  String         @unique // e.g. RC-2024-0001
  bookingId       String         @unique
  booking         RentalBooking  @relation(fields: [bookingId], references: [id])
  status          ContractStatus @default(DRAFT)

  // Content
  terms           String?
  cancellationPolicy  String?
  liabilityClauses    String?
  damageDepositClause String?
  paymentTerms        String?

  // Signing
  sentAt          DateTime?
  signedAt        DateTime?
  signedByName    String?
  signedPdfUrl    String?
  signatureData   String?  // base64 or URL

  expiresAt       DateTime?
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("rental_contracts")
}

// ── Rental: Maintenance ───────────────────────────────────────────────────────

model MaintenanceLog {
  id              String            @id @default(cuid())
  assetId         String
  asset           Asset             @relation(fields: [assetId], references: [id])
  maintenanceType MaintenanceType   @default(PREVENTIVE)
  status          MaintenanceStatus @default(REPORTED)

  description     String
  scheduledDate   DateTime
  completedDate   DateTime?
  cost            Decimal?          @db.Decimal(10, 2)
  vendorName      String?
  invoiceRef      String?
  partsReplaced   String?
  technicianNotes String?
  nextServiceDate DateTime?
  nextServiceKm   Int?
  downTimeDays    Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("maintenance_logs")
}

// ── Rental: Fuel ──────────────────────────────────────────────────────────────

model FuelLog {
  id            String   @id @default(cuid())
  // In-house fleet asset (optional — SYS-12.E broadened this to also cover hired
  // production vehicles, which are not Assets).
  assetId       String?
  asset         Asset?   @relation(fields: [assetId], references: [id])

  // SYS-12.E — production fuel on a hired TransportVehicle, scoped to a project,
  // optionally attributed to a transport driver (for fuel-by-driver reporting).
  transportVehicleId String?
  transportVehicle   TransportVehicle? @relation(fields: [transportVehicleId], references: [id], onDelete: SetNull)
  projectId          String?
  project            ProductionProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  transportDriverId  String?
  transportDriver    TransportDriver?  @relation(fields: [transportDriverId], references: [id], onDelete: SetNull)

  logDate       DateTime @default(now())
  litres        Decimal  @db.Decimal(8, 2)
  costPerLitre  Decimal  @db.Decimal(6, 3)
  totalCost     Decimal  @db.Decimal(10, 2)
  odometer      Int?
  runtimeHours  Decimal? @db.Decimal(8, 2) // for generators
  receiptUrl    String?
  notes         String?
  bookingRef    String?

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([transportVehicleId])
  @@index([assetId])
  @@index([transportDriverId])
  @@map("fuel_logs")
}

// ── Rental: Damage ────────────────────────────────────────────────────────────

model DamageReport {
  id            String        @id @default(cuid())
  reportNumber  String        @unique // DR-2024-0001
  assetId       String
  asset         Asset         @relation(fields: [assetId], references: [id])
  bookingId     String?
  booking       RentalBooking? @relation(fields: [bookingId], references: [id])

  description   String
  severity      String        @default("MINOR") // MINOR | MODERATE | SEVERE
  reportedAt    DateTime      @default(now())
  location      String?
  gpsLocation   String?
  photos        String[]
  videos        String[]

  // Resolution
  clientLiable  Boolean       @default(false)
  repairCost    Decimal?      @db.Decimal(10, 2)
  insuranceClaim Boolean      @default(false)
  claimRef      String?
  resolvedAt    DateTime?
  resolutionNotes String?

  reportedById  String
  reportedBy    User          @relation("DamageReportedBy", fields: [reportedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("damage_reports")
}

// ── Rental: Incidents ─────────────────────────────────────────────────────────

model IncidentReport {
  id              String          @id @default(cuid())
  incidentNumber  String          @unique // INC-2024-0001
  incidentType    IncidentType
  urgency         IncidentUrgency @default(MEDIUM)
  status          IncidentStatus  @default(OPEN)

  title           String
  description     String
  location        String?
  gpsLocation     String?
  occurredAt      DateTime        @default(now())
  photos          String[]

  // Links
  driverId        String?
  driver          Driver?         @relation(fields: [driverId], references: [id])
  assetId         String?
  asset           Asset?          @relation(fields: [assetId], references: [id])
  bookingId       String?
  booking         RentalBooking?  @relation(fields: [bookingId], references: [id])

  // Resolution
  resolvedAt      DateTime?
  resolutionNotes String?
  resolutionCost  Decimal?        @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("incident_reports")
}

// ── Suppliers ─────────────────────────────────────────────────────────────────

enum SupplierStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

enum SupplierDocType {
  TRADE_LICENSE
  VAT_CERTIFICATE
  INSURANCE
  CONTRACT
  BANK_DETAILS
  QUOTATION
  INVOICE
  WARRANTY
  OTHER
}

enum SupplierContactRole {
  SALES
  FINANCE
  OPERATIONS
  TECHNICAL
  MANAGEMENT
  EMERGENCY
  OTHER
}

model Supplier {
  id           String         @id @default(cuid())
  supplierCode String?        @unique  // Auto-generated: SUP-0001
  name         String
  tradeName    String?
  category     String?        // legacy single category (kept for compat)
  categories   String[]       // multi-select: can be multiple from SUPPLIER_CATEGORIES

  // Google Maps / location
  googleMapsUrl   String?
  gpsCoordinates  String?     // "lat,lng" or full Plus Code

  // Link to a MaintenanceVendor when this supplier is also a workshop
  vendorId  String?            @unique
  vendor    MaintenanceVendor? @relation("SupplierVendorLink", fields: [vendorId], references: [id])

  status       SupplierStatus @default(ACTIVE)
  isActive     Boolean        @default(true)   // kept for backward compat (true when ACTIVE)

  // UAE Tax & Compliance
  trn                  String?
  vatId                String?
  trnCertificateUrl    String?
  tradeLicenseNumber   String?
  tradeLicenseExpiry   DateTime?
  tradeLicenseUrl      String?
  businessLicenseUrl   String?
  insuranceDocUrl      String?
  insuranceExpiry      DateTime?
  contractExpiry       DateTime?

  // Primary Contact (kept for quick display)
  contactName  String?
  email        String?
  phone        String?
  address      String?
  city         String?
  country      String   @default("UAE")
  website      String?

  // Banking
  bankName        String?
  bankAccount     String?
  iban            String?
  swiftCode       String?
  bankBranch      String?
  bankAddress     String?

  // Terms & Financials
  currency        Currency @default(AED)
  paymentTermDays Int?
  creditLimit     Decimal? @db.Decimal(15, 2)
  notes           String?
  blacklistReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Logistics vendor ranking (SYS-12)
  ranking VendorRanking?

  expenses  Expense[]
  contacts  Contact[]          // global contact directory links
  supplierContacts SupplierContact[]
  documents        SupplierDocument[]
  accommodationProperties AccommodationProperty[]
  transportVehicles       TransportVehicle[] @relation("TransportVehicleSupplier")
  transportDrivers        TransportDriver[]  @relation("TransportDriverSupplier")

  @@map("suppliers")
}

model SupplierContact {
  id         String              @id @default(cuid())
  supplierId String
  supplier   Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  // Optional link to global Contact directory
  globalContactId String?
  globalContact   Contact? @relation("SupplierContactGlobal", fields: [globalContactId], references: [id])

  fullName   String
  role       SupplierContactRole @default(OTHER)
  jobTitle   String?
  department String?

  mobile     String?
  whatsapp   String?
  email      String?
  officePhone String?
  preferredContact String?     // "mobile" | "whatsapp" | "email"

  isPrimary  Boolean @default(false)
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("supplier_contacts")
}

model SupplierDocument {
  id         String          @id @default(cuid())
  supplierId String
  supplier   Supplier        @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  docType    SupplierDocType @default(OTHER)
  name       String
  fileUrl    String
  expiryDate DateTime?
  notes      String?

  createdAt DateTime @default(now())

  @@map("supplier_documents")
}

// ── Production: Enums ─────────────────────────────────────────────────────────

enum ProductionStatus {
  DEVELOPMENT
  PRE_PRODUCTION
  PRODUCTION
  POST_PRODUCTION
  DELIVERED
  CANCELLED
  ARCHIVED
}

enum BudgetVersionStatus {
  DRAFT    // initial compilation stage
  REVIEW   // V1, V2… submitted for approval
  APPROVED // validated by Producer/Client
  LOCKED   // frozen historical baseline (enforced read-only)
  WORKING  // active working copy branched from a locked baseline
}

enum ProductionCrewRole {
  EXECUTIVE_PRODUCER
  PRODUCER
  LINE_PRODUCER
  DIRECTOR
  ASSISTANT_DIRECTOR
  DOP
  CAMERA_OPERATOR
  GAFFER
  GRIP
  SOUND
  ART_DIRECTOR
  STYLIST
  MAKEUP
  WARDROBE
  EDITOR
  COLORIST
  VFX_ARTIST
  MUSIC_COMPOSER
  PRODUCTION_COORDINATOR
  PRODUCTION_ASSISTANT
  DRIVER
  OTHER
}

// ── Production: Projects ──────────────────────────────────────────────────────

model ProductionProject {
  id            String           @id @default(cuid())
  projectNumber String           @unique // PRD-2024-0001
  title         String
  clientId      String?
  client        Client?          @relation(fields: [clientId], references: [id])
  projectType   String           @default("TVC") // TVC | CORPORATE | DOCUMENTARY | FEATURE | SHORT | MUSIC_VIDEO | OTHER
  status        ProductionStatus @default(DEVELOPMENT)

  startDate      DateTime?
  endDate        DateTime?
  shootStartDate DateTime?
  shootEndDate   DateTime?

  currency    Currency @default(AED)
  totalBudget Decimal? @db.Decimal(15, 2) // computed from active budget version

  // Production jurisdiction — drives JurisdictionTaxRule resolution and AI context.
  // Optional at DB level so `db push` works on existing data; MANDATORY at app level
  // (DynamicContextService refuses to run without it; seed-jurisdiction.js backfills).
  productionCountryId String?
  productionCountry   GeoNode? @relation("ProjectProductionCountry", fields: [productionCountryId], references: [id])
  emailSettings Json? // per-project email sender { enabled, smtp:{...} }
  logoUrl     String? // project / studio logo (shown next to company logo on reports)

  description String?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  budgetVersions BudgetVersion[]
  crew           ProductionCrew[]
  schedules      ProductionSchedule[]
  callSheets     CallSheet[]
  perDiems       PerDiem[]
  overages       Overage[]
  creditRoll     CreditRoll?
  transactions   ProjectTransaction[]
  vendors        ProductionVendor[]
  purchaseOrders PurchaseOrder[]
  costSnapshots  CostReportSnapshot[]
  pettyCashFloats PettyCashFloat[]
  strips         ProductionStrip[]
  breakdownElements BreakdownElement[]
  documents      ProjectDocument[]
  laborConfig    ProjectLaborConfig?
  projectRateRules ProjectRateRule[]
  incentives     ProjectIncentive[]
  incentiveClaims IncentiveClaim[]
  timecards      Timecard[]
  locations      Location[]
  budgetTransfers BudgetTransfer[]
  pendingVendors  PendingVendor[]
  budgetLifecycleLogs BudgetLifecycleLog[]
  globalsStaging      ProjectGlobalsStaging?
  bankAccounts        BankAccount[] // dedicated production account(s) — audit trail
  ledgerBankAccounts  LedgerBankAccount[] // reconciliation side of the dedicated account
  roleAssignments     ProjectRoleAssignment[] // per-project authorization layer (V1.2)

  // Per-diem rate defaults (project currency)
  perDiemInternational Decimal? @db.Decimal(12, 2)
  perDiemDomestic      Decimal? @db.Decimal(12, 2)

  // The single corporate/house entity that owns standalone (project-less) postings.
  isHouse Boolean @default(false)

  // Travel / Contracts / Casting modules
  trips             Trip[]
  contracts         ProjectContract[]
  castingCalls      CastingCall[]
  characterProfiles CharacterProfile[]
  consentLogs       ConsentLog[]
  talentReviews     TalentPerformanceReview[]
  accommodationAssignments AccommodationAssignment[]
  transportVehicles        TransportVehicle[]
  transportOrders          TransportOrder[]
  shuttleRoutes            ShuttleRoute[]
  arrivals                 TravelArrival[]
  fuelLogs                 FuelLog[]

  @@index([productionCountryId])
  @@map("production_projects")
}

// ── Production Globals staging ─────────────────────────────────────────────────
// Holding area for schedule/rate globals captured during setup or import.
// Nothing here touches a budget version until an explicit, user-approved "push"
// writes the values into the WORKING version's BudgetGlobals (LOCKED versions
// are never written).
model ProjectGlobalsStaging {
  id        String            @id @default(cuid())
  projectId String            @unique
  project   ProductionProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  prepDays  Int?
  shootDays Int?
  wrapDays  Int?
  crewCount Int?
  eurToAed  Decimal? @db.Decimal(14, 6) // 1 EUR in AED
  usdToAed  Decimal? @db.Decimal(14, 6) // 1 USD in AED

  status            String    @default("DRAFT") // DRAFT | PUSHED
  pushedAt          DateTime?
  pushedToVersionId String? // BudgetVersion that received the values
  doodTallies       Json? // aggregate DOOD counts per category { generatedAt, categories: { CAST: {elements, workDays, holdDays}, … } }
  notes             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("project_globals_staging")
}

// ── External CoA → Master Chart of Accounts mapping ────────────────────────────
// Maps imported account codes (Movie Magic, legacy ledgers…) onto the enterprise
// Master CoA so imports and AI suggestions always resolve to real account codes.
model CoaMappingTable {
  id            String  @id @default(cuid())
  sourceSystem  String  @default("MOVIE_MAGIC") // MOVIE_MAGIC | LEGACY | OTHER
  externalCode  String // the code as it appears in the import
  externalLabel String? // description from the source file
  masterCode    String // Master CoA account code (e.g. "1100", "2310")
  masterTitle   String? // denormalised title for display / AI context
  isActive      Boolean @default(true)
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sourceSystem, externalCode])
  @@index([masterCode])
  @@map("coa_mapping_table")
}

enum LocationType {
  INT
  EXT
  STUDIO
  BACKLOT
  OTHER
}

enum LocationStatus {
  SCOUTING
  OPTION
  CONFIRMED
  RELEASED
}

// ── SYS-07 Master Location Library ───────────────────────────────────────────
// A MasterLocation is a permanent COMPANY asset (no projectId). Projects link to
// it via the Location model (the per-project usage record). History accretes here.
enum MasterLocationStatus {
  PROSPECT // identified, not yet vetted
  LIBRARY // vetted, available to link
  PREFERRED // proven, go-to
  RESTRICTED // usable with caveats
  BLACKLISTED // do not use
  ARCHIVED
}

model MasterLocation {
  id      String               @id @default(cuid())
  code    String?              @unique // optional human ref e.g. LOC-0001
  name    String
  aliases Json? // ["Old Souk", "Heritage Village"]
  category LocationType        @default(EXT)
  subType  String? // Villa | Warehouse | Desert | Mosque | Office | Beach …
  status   MasterLocationStatus @default(LIBRARY)
  summary  String? // short scouting description
  tags     Json? // ["desert","period","sand-dunes","sunset"]

  // Geography
  country       String?  @default("United Arab Emirates")
  region        String? // emirate / state / province
  city          String?
  district      String?
  fullAddress   String?
  lat           Decimal? @db.Decimal(10, 7)
  lng           Decimal? @db.Decimal(10, 7)
  googleMapsUrl String?
  what3words    String?
  timezone      String?

  // Access & logistics (permanent attributes)
  accessNotes    String?
  parkingNotes   String?
  basecampNotes  String?
  nearestAirport String?
  driveTimeNotes String?

  // Technical (permanent attributes)
  powerAvailable  Boolean? // mains power on site
  powerNotes      String?
  internetNotes   String?
  cellularNotes   String?
  waterAvailable  Boolean?
  soundNotes      String? // ambient noise, flight paths, traffic
  ceilingHeightM  Decimal? @db.Decimal(6, 2)
  floorAreaSqm    Decimal? @db.Decimal(12, 2)

  // Restrictions & ownership (permanent)
  ownerName      String?
  ownerCompany   String?
  ownerPhone     String?
  ownerEmail     String?
  agentName      String?
  agentPhone     String?
  restrictions   String? // filming hours, no-fly, religious, heritage
  permitAuthority String? // default permitting body for this place
  standardFee    Decimal? @db.Decimal(14, 2)
  feeCurrency    String   @default("AED")
  feeNotes       String?

  // Safety (permanent)
  nearestHospitalName    String?
  nearestHospitalAddress String?
  nearestHospitalPhone   String?
  safetyNotes            String?

  // Aggregated production history (accreted from project usage)
  timesUsed        Int      @default(0)
  lastUsedAt       DateTime?
  totalSpentToDate Decimal  @db.Decimal(16, 2) @default(0)
  avgFeePerDay     Decimal? @db.Decimal(14, 2)
  historyNotes     String? // recurring issues / lessons learned

  notes String?

  media     LocationMedia[]
  usages    Location[] // per-project usage records linked back here

  // SYS-07 slice 7 — operational records held DIRECTLY on the library asset
  // (standalone module use, independent of any project).
  documents LocationDocument[]
  permits   LocationPermit[]
  security  LocationSecurity[]
  payments  LocationPayment[]

  createdById String?
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([country, region])
  @@map("master_locations")
}

enum LocationMediaType {
  PHOTO
  VIDEO
  PANO360
  DRONE
  FLOORPLAN
  CAD
  DOCUMENT
}

model LocationMedia {
  id               String          @id @default(cuid())
  masterLocationId String
  masterLocation   MasterLocation  @relation(fields: [masterLocationId], references: [id], onDelete: Cascade)

  type      LocationMediaType @default(PHOTO)
  url       String // /uploads/<file> or external URL
  thumbnailUrl String?
  caption   String?
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)
  capturedAt DateTime?
  uploadedById String?
  createdAt DateTime @default(now())

  @@index([masterLocationId])
  @@map("location_media")
}

model Location {
  id        String            @id @default(cuid())
  projectId String
  project   ProductionProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // SYS-07: link to the permanent master library asset (null = legacy/unlinked)
  masterLocationId String?
  masterLocation   MasterLocation? @relation(fields: [masterLocationId], references: [id])

  // per-project usage detail
  scenes    String? // scene numbers shot here
  shootStart DateTime?
  shootEnd   DateTime?

  // SYS-07 slice 3 — assessment
  techRecces  TechRecce[]
  evaluations LocationEvaluation[]

  // SYS-07 slice 4 — permits & risk
  permits LocationPermit[]
  risks   LocationRisk[]

  // SYS-07 slice 6 — LM document vault & pipeline (from the location-manager mailbox study)
  documents     LocationDocument[]
  pipelineStage LocationStage @default(SOURCING)

  // SYS-07 slice 7 — permits-as-workload, security, payments (mailbox evidence)
  security LocationSecurity[]
  payments LocationPayment[]

  name   String
  type   LocationType   @default(EXT)
  status LocationStatus @default(SCOUTING)

  // Geography (drives per-diem + call sheet)
  country     String? @default("United Arab Emirates")
  emirate     String? // Dubai, Abu Dhabi, Sharjah, Ajman, RAK, Fujairah, UAQ — or city
  area        String?
  fullAddress String?
  lat         Decimal? @db.Decimal(10, 7)
  lng         Decimal? @db.Decimal(10, 7)
  googleMapsUrl String?
  what3words  String?

  // People
  locationManagerId   String?
  locationAssistantId String?
  ownerContactName    String?
  ownerPhone          String?
  ownerEmail          String?

  // Logistics
  parkingNotes  String?
  basecampNotes String?
  accessNotes   String?
  facilities    Json? // { power, water, toilets, wifi }
  restrictions  String?

  // Safety
  nearestHospitalName    String?
  nearestHospitalAddress String?
  nearestHospitalPhone   String?

  // Money & compliance
  locationFeePerDay Decimal? @db.Decimal(14, 2)
  currency          String   @default("AED")
  permitRequired    Boolean  @default(false)
  permitStatus      String? // NONE | APPLIED | APPROVED | REJECTED
  permitNumber      String?
  permitExpiry      DateTime?
  permitDocUrl      String?

  photoUrls    Json?
  documentUrls Json?
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([masterLocationId])
  @@map("locations")
}

// ── SYS-07 slice 2 — Scouting missions & field submissions ───────────────────
enum ScoutAssignmentType {
  INITIAL // first pass / general recon
  PHOTO // photo scout
  DIRECTOR // director scout
  PRODUCER // producer scout
  TECH_RECCE // technical recce
  PERMIT // permit feasibility
  FINAL // final lock
}

enum ScoutPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ScoutAssignmentStatus {
  OPEN
  IN_PROGRESS
  SUBMITTED // candidates submitted, awaiting decision
  COMPLETED
  CANCELLED
}

enum ScoutSubmissionStatus {
  PENDING // awaiting review
  SHORTLISTED
  ACCEPTED // promoted to library / linked
  REJECTED
}

// NB: projectId is a plain indexed FK (no Prisma relation) to keep ProductionProject
// untouched this slice; projects are guarded against hard-delete anyway.
model ScoutAssignment {
  id          String              @id @default(cuid())
  projectId   String
  title       String
  description String? // the brief — what we're looking for
  sceneRefs   String? // scenes this should cover
  visualRefs  Json? // mood-board image URLs / references
  locationType LocationType       @default(EXT)
  budgetTarget Decimal?           @db.Decimal(14, 2)
  feeCurrency  String             @default("AED")
  dueDate     DateTime?
  priority    ScoutPriority       @default(MEDIUM)
  type        ScoutAssignmentType @default(INITIAL)
  status      ScoutAssignmentStatus @default(OPEN)

  assignedToId   String? // user id of the scout
  assignedToName String? // denormalized for display

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions ScoutSubmission[]

  @@index([projectId])
  @@index([status])
  @@map("scout_assignments")
}

model ScoutSubmission {
  id           String          @id @default(cuid())
  assignmentId String
  assignment   ScoutAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  candidateName String
  summary       String?
  notes         String?

  // geo captured in the field
  lat           Decimal? @db.Decimal(10, 7)
  lng           Decimal? @db.Decimal(10, 7)
  fullAddress   String?
  googleMapsUrl String?
  what3words    String?

  media       Json? // array of photo URLs captured on site
  ownerName   String?
  ownerPhone  String?
  ownerEmail  String?

  // weighted evaluation { visual, access, logistics, cost, safety, ... , overall }
  evaluation  Json?
  estFeePerDay Decimal? @db.Decimal(14, 2)

  status                 ScoutSubmissionStatus @default(PENDING)
  acceptedMasterLocationId String? // set when accepted → promoted into the library
  reviewNotes            String?

  submittedById String?
  submittedByName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([assignmentId])
  @@index([status])
  @@map("scout_submissions")
}

// ── SYS-07 slice 3 — Tech recces & weighted evaluation ───────────────────────
enum RecceStatus {
  PLANNED
  DONE
  CANCELLED
}

model TechRecce {
  id         String      @id @default(cuid())
  locationId String
  location   Location    @relation(fields: [locationId], references: [id], onDelete: Cascade)

  reccedAt    DateTime?
  conductedBy String?
  attendees   String? // free-text list of who attended
  summary     String?
  status      RecceStatus @default(PLANNED)

  notes     RecceNote[]
  createdById String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
  @@map("tech_recces")
}

model RecceNote {
  id          String    @id @default(cuid())
  techRecceId String
  techRecce   TechRecce @relation(fields: [techRecceId], references: [id], onDelete: Cascade)

  department     String // CAMERA | GRIP | ELECTRIC | SOUND | ART | CONSTRUCTION | TRANSPORT | SECURITY | STUNTS | SFX | VFX | LOCATIONS | OTHER
  risks          String?
  equipmentNeeds String?
  crewNeeds      String?
  accessNotes    String?
  safetyNotes    String?
  powerNotes     String?
  photos         Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([techRecceId])
  @@map("recce_notes")
}

enum EvaluationRecommendation {
  RECOMMENDED
  ACCEPTABLE
  NOT_RECOMMENDED
}

model LocationEvaluation {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  // criterion scores 1-5: { visual, access, logistics, cost, safety,
  //   productionValue, permitComplexity, feasibility, comfort, schedule }
  scores         Json
  weights        Json? // optional override; equal-weight if null
  weightedScore  Decimal @db.Decimal(6, 3) @default(0) // 0..5, system-computed
  recommendation EvaluationRecommendation @default(ACCEPTABLE)
  notes          String?

  evaluatedById   String?
  evaluatedByName String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
  @@map("location_evaluations")
}

// ── SYS-07 slice 4 — Permits & risk ──────────────────────────────────────────
enum PermitStatus {
  NOT_REQUIRED
  DRAFT
  APPLIED
  IN_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

// Typed permit categories — permits are ~88% of the LM's workload and span several
// authorities (mailbox evidence). Free-text `type` kept for back-compat / detail.
enum LocationPermitType {
  GROUND_FILMING // twofour54 ground filming permit
  DRONE_GCAA // drone / aerial (GCAA)
  ROAD_TRAFFIC // road/lane use (RTA)
  POLICE // police coordination / security clearance
  AIRPORT // airport airside (ADAC)
  HERITAGE_DCT // heritage / DCT site
  PARKING // parking permit
  MARINE // marine / coastguard
  PYRO_SFX // pyrotechnics / special effects
  FIREARMS // weapons / armoury
  OTHER
}

model LocationPermit {
  id         String    @id @default(cuid())
  // Dual-target: a permit belongs to a project location OR a master library location.
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)
  masterLocationId String?
  masterLocation   MasterLocation? @relation(fields: [masterLocationId], references: [id], onDelete: Cascade)

  permitType      LocationPermitType @default(OTHER)
  type            String? // free-text detail (legacy / specifics)
  authorityId     String?
  authorityRef    PermitAuthority? @relation(fields: [authorityId], references: [id])
  authority       String? // denormalised issuing-body name (e.g. twofour54, RTA)
  jurisdiction    String? // country / emirate / city
  referenceNumber String?
  status          PermitStatus @default(DRAFT)
  applicationDate DateTime?
  approvalDate    DateTime?
  expiryDate      DateTime?
  fee             Decimal? @db.Decimal(14, 2)
  currency        String   @default("AED")
  conditions      String? // conditions / restrictions attached to the permit
  docUrl          String? // attached permit PDF/image
  ocrData         Json? // raw OCR extraction for audit
  notes           String?

  // workflow routing available via WorkflowEntity.LOCATION
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([locationId])
  @@index([masterLocationId])
  @@index([status])
  @@index([permitType])
  @@map("location_permits")
}

// Reusable directory of issuing authorities (standalone, company-wide).
model PermitAuthority {
  id           String  @id @default(cuid())
  name         String  @unique
  category     String? // FILM_COMMISSION | AVIATION | ROADS | POLICE | AIRPORT | HERITAGE | MUNICIPALITY | OTHER
  jurisdiction String? // emirate / country covered
  contactName  String?
  email        String?
  phone        String?
  portalUrl    String?
  leadTimeDays Int? // typical processing lead time
  notes        String?
  permits      LocationPermit[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("permit_authorities")
}

enum RiskStatus {
  OPEN
  MITIGATED
  CLOSED
}

model LocationRisk {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  category   String // FIRE | WATER | HEIGHT | CROWD | WEATHER | TRAFFIC | SECURITY | WILDLIFE | ELECTRICAL | STRUCTURAL | HEAT | OTHER
  hazard     String
  likelihood Int     @default(1) // 1-5
  impact     Int     @default(1) // 1-5
  riskScore  Int     @default(1) // likelihood × impact (system-computed)
  mitigation String?
  owner      String? // who owns the mitigation
  emergencyProcedure String?
  nearestMedical     String?
  evacuationNotes    String?
  status     RiskStatus @default(OPEN)
  notes      String?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([locationId])
  @@index([status])
  @@map("location_risks")
}

// ── SYS-07 slice 6 — LM document vault & compliance ──────────────────────────
// Modelled on the real location-manager workflow (NOCs, agreements/releases,
// insurance, location guides, IDs, quotes) seen in the LM mailbox study.
enum LocationDocCategory {
  NOC // No Objection Certificate (often bilingual EN/AR) — the LM's #1 artifact
  LOCATION_AGREEMENT // location agreement / contract
  RELEASE // location release
  INSURANCE // public-liability (PLL) / COI certificate
  LOCATION_GUIDE // the per-location guide/pack issued to crew
  RISK_ASSESSMENT // risk-assessment questionnaire
  METHOD_STATEMENT // HSE method statement (pairs with risk assessment)
  ID_DOCUMENT // owner/landlord EID / trade licence
  QUOTE // rental quote / invoice
  PERMIT_DOC // ground filming permit document
  OTHER
}

enum LocationDocStatus {
  DRAFT
  REQUESTED // asked the owner/authority
  RECEIVED // came back
  SIGNED // executed
  ISSUED // we issued it (e.g. NOC letter)
  EXPIRED
  VOID
}

enum DocLanguage {
  EN
  AR
  BILINGUAL
}

enum LocationStage {
  SOURCING
  NOC_REQUESTED
  AGREEMENT_SENT
  PERMIT_APPLIED
  INSURANCE_RECEIVED
  CONFIRMED
  WRAPPED
}

model LocationDocument {
  id         String    @id @default(cuid())
  // Dual-target: a document belongs to a project location OR a master library location.
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)
  masterLocationId String?
  masterLocation   MasterLocation? @relation(fields: [masterLocationId], references: [id], onDelete: Cascade)

  category   LocationDocCategory @default(OTHER)
  title      String
  status     LocationDocStatus   @default(DRAFT)
  language   DocLanguage         @default(EN)

  partyName   String? // owner / landlord / authority on the document
  authority   String? // issuing body (Aldar, twofour54, RTA, municipality…)
  refNumber   String?
  issueDate   DateTime?
  signedDate  DateTime?
  expiryDate  DateTime? // drives insurance/NOC expiry alerts
  amount      Decimal? @db.Decimal(14, 2) // coverage value or quote amount
  currency    String   @default("AED")

  fileUrl String? // uploaded PDF/image
  ocrData Json? // raw OCR extraction (audit)
  notes   String?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([locationId])
  @@index([masterLocationId])
  @@index([category])
  @@index([expiryDate])
  @@map("location_documents")
}

// ── SYS-07 slice 7 — Security & marshals (2nd-biggest LM topic) ──────────────
