enum PendingVendorStatus {
  PENDING
  APPROVED
  REJECTED
}

// Staging table for vendor self-onboarding submissions (via a time-limited JWT link).
// Approving one maps it into a Supplier master + a linked ProductionVendor.
model PendingVendor {
  id        String              @id @default(cuid())
  projectId String
  project   ProductionProject   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status    PendingVendorStatus @default(PENDING)

  name            String
  tradeName       String?
  category        String?
  contactName     String?
  phone           String?
  email           String?
  address         String?
  city            String?
  country         String? @default("United Arab Emirates")
  trn             String?
  vatId           String?
  iban            String?
  bankName        String?
  bankAccount     String?
  swiftCode       String?
  trnCertUrl      String? // uploaded TRN certificate
  tradeLicenseUrl String? // uploaded trade licence
  notes           String?

  submittedIp        String?
  reviewedById       String?
  reviewedAt         DateTime?
  productionVendorId String? // set on approval
  supplierId         String? // set on approval

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([status])
  @@map("pending_vendors")
}

model PurchaseOrder {
  id        String            @id @default(cuid())
  projectId String
  project   ProductionProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  poNumber  String            @unique

  vendorId        String?
  vendor          ProductionVendor? @relation(fields: [vendorId], references: [id])
  vendorName      String?
  costCenterCode  String? // budget account code
  costCenterTitle String?
  description     String
  date            DateTime          @default(now())
  expectedDate    DateTime?

  amount          Decimal @db.Decimal(15, 2) @default(0)
  taxAmount       Decimal @db.Decimal(15, 2) @default(0)
  total           Decimal @db.Decimal(15, 2) @default(0)
  invoicedAmount  Decimal @db.Decimal(15, 2) @default(0)
  currency        Currency @default(AED)

  status      PurchaseOrderStatus @default(DRAFT)
  notes       String?
  createdById String?

  // ── E-invoicing: KSA ZATCA Phase 2 (Fatoora) — same block as ProjectTransaction ──
  invoiceClassification    InvoiceClassification?
  zatcaUuid                String?
  zatcaIcv                 Int?
  zatcaXmlHash             String?
  zatcaPreviousInvoiceHash String?
  zatcaCryptographicStamp  String?
  zatcaCsid                String?
  zatcaQrCode              String?
  zatcaClearanceStatus     String? // PENDING | CLEARED | REPORTED | REJECTED
  zatcaClearedAt           DateTime?
  // ── E-invoicing: Jordan JoFotara (ISTD) ──────────────────────────────────────
  jordanFawateeryUuid String?
  jordanFawateeryQR   String?
  ublStandardVersion  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Travel / Contracts back-links (one-to-one)
  itinerary Itinerary?
  contract  ProjectContract?
  transportVehicle TransportVehicle? @relation("TransportVehiclePO") // SYS-12 hired-vehicle commitment

  @@index([projectId])
  @@map("purchase_orders")
}

model CostReportSnapshot {
  id        String            @id @default(cuid())
  projectId String
  project   ProductionProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  asOf      DateTime          @default(now())
  label     String?
  data      Json // full per-cost-center report
  budget    Decimal @db.Decimal(15, 2) @default(0)
  committed Decimal @db.Decimal(15, 2) @default(0)
  actual    Decimal @db.Decimal(15, 2) @default(0)
