  standardPct Decimal @default(0.35) @db.Decimal(6, 4)
  criteria    Json? // [{key,label,points,selected}]
  totalPoints Int     @default(0)
  enhancedPct Decimal @default(0) @db.Decimal(6, 4)
  totalPct    Decimal @default(0.35) @db.Decimal(6, 4)

  adqpe           Decimal? @db.Decimal(15, 2) // qualifying spend
