// ── Per-Project Accounting Ledger (standalone production books) ────────────────

enum ProjectTxnKind {
  INCOME
  COST
  SALES_REVENUE      // distribution income: MGs, box office, licensing (7000 series)
  CORPORATE_OVERHEAD // internal studio costs, separated from physical production (9000 series)
}

enum ProjectTxnStatus {
  DRAFT
  APPROVED
  INVOICED
  PAID
  RECEIVED
  VOID
}

model ProjectTransaction {
  id        String            @id @default(cuid())
  projectId String
  project   ProductionProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  kind         ProjectTxnKind
  date         DateTime          @default(now())
  accountCode  String? // budget account code (for COSTs → Budget vs Actual)
  accountTitle String?
  category     String?
  description  String
  party        String? // client (income) or vendor (cost)
  reference    String?

  amount    Decimal  @db.Decimal(15, 2) @default(0)
  taxAmount Decimal  @db.Decimal(15, 2) @default(0)
  total     Decimal  @db.Decimal(15, 2) @default(0)
  currency  Currency @default(AED)

  status      ProjectTxnStatus @default(DRAFT)
  createdById String?

  // Accounts Payable (for COSTs treated as vendor invoices)
  invoiceNumber String?
  vendorId      String?
  dueDate       DateTime?
  paidDate      DateTime?
  paidAmount    Decimal?  @db.Decimal(15, 2)
  paidById      String? // who released the payment (segregation-of-duties audit)
  approvedById  String? // who/which workflow approved it as an actual (audit)

  // ── E-invoicing: KSA ZATCA Phase 2 (Fatoora) ─────────────────────────────────
  // Populated by the clearance/reporting middleware response — never hand-entered.
  // B2B/B2G = real-time CLEARANCE before issue · B2C (simplified) = REPORTED ≤24h.
  invoiceClassification    InvoiceClassification?
  zatcaUuid                String? // 36-char invoice UUID (unique across the ZATCA ecosystem)
  zatcaIcv                 Int? // ICV — invoice counter value, strictly sequential per EGS unit
  zatcaXmlHash             String? // hash of the signed UBL 2.1 XML (this invoice)
  zatcaPreviousInvoiceHash String? // PIH — hash chain to the immediately preceding invoice
  zatcaCryptographicStamp  String? // ECDSA stamp (simplified: device CSID stamp; standard: ZATCA stamp on clearance)
  zatcaCsid                String? // Cryptographic Stamp Identifier used
  zatcaQrCode              String? // base64 TLV QR (Phase 2: incl. stamp, public key, ECDSA signature)
  zatcaClearanceStatus     String? // PENDING | CLEARED | REPORTED | REJECTED
  zatcaClearedAt           DateTime?

  // ── E-invoicing: Jordan JoFotara (ISTD) — UBL 2.1, clearance model ───────────
  jordanFawateeryUuid String? // submission UUID returned by JoFotara
  jordanFawateeryQR   String? // ISTD-issued QR after validation (must appear on the customer invoice)
  ublStandardVersion  String? // payload dialect marker, e.g. "UBL 2.1"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([accountCode])
  @@index([zatcaUuid])
  @@map("project_transactions")
}

// ZATCA invoice classification — drives clearance (B2B/B2G) vs 24h reporting (B2C)
enum InvoiceClassification {
  B2B
  B2C
  B2G
}

// ── Accounting period close (lock a week/month for true 'as-of' reporting) ──────
model AccountingPeriod {
  id        String   @id @default(cuid())
  projectId String
  period    String // "2026-06" (month) — close granularity
  status    String   @default("OPEN") // OPEN | CLOSED
  closedAt  DateTime?
  closedBy  String?
  createdAt DateTime @default(now())

  @@unique([projectId, period])
  @@index([projectId])
  @@map("accounting_periods")
}

