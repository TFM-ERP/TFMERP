  pageStart         Int            @default(1)
  pageEnd           Int            @default(1)
  charStart         Int?           // char offset of the slugline within the page text
  productionStripId String?        // optional link to the scheduling ProductionStrip (same scene #)
  sortOrder         Int            @default(0)
  // SYS-13b P3 вЂ” special tags (scene-level)
  description       String?        // one-line scene synopsis
  storyDay          String?        // story-day label, e.g. "DAY 1"
  tagNote           String?        // free scene note
  createdAt         DateTime       @default(now())

  coverage ScriptCoverage[]

