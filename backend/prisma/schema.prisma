  status     PerDiemStatus @default(PENDING)
  notes      String?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
  @@map("per_diems")
}

enum CallSheetStatus {
  DRAFT
  PUBLISHED
}

model CallSheet {
  id        String            @id @default(cuid())
  projectId String
  project   ProductionProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  dayNumber Int             @default(1)
  totalDays Int?
  shootDate DateTime
  status    CallSheetStatus @default(DRAFT)

  // Call times
  generalCall  String? // "06:00"
  shootingCall String?
  estWrap      String?

  // Weather / daylight
  weather  String?
  tempHigh String?
  tempLow  String?
  sunrise  String?
  sunset   String?
  goldenHourAm String? // SYS-07 V2 S7 вЂ” morning golden-hour end (sunrise в†’ +6В° elevation)
  goldenHourPm String? // evening golden-hour start (+6В° elevation в†’ sunset)

  // Location
  locationId      String? // link to a Location record
  locationName    String?
  locationAddress String?
  locationMapUrl  String?
  parkingNotes    String?
  basecampNotes   String?

  // Nearest hospital (safety)
  hospitalName    String?
  hospitalAddress String?
  hospitalPhone   String?

  // Structured blocks (editable arrays)
  keyContacts     Json? // [{ role, name, phone }]
  scheduleItems   Json? // [{ time, scene, intExt, description, pages, cast, location }]
  castCalls       Json? // [{ cast, character, callTime, hmw, onSet, remarks }]
  backgroundCalls Json? // [{ description, count, callTime, location }]
  crewCalls       Json? // [{ department, name, role, callTime }]
  advanceSchedule Json? // next-day: [{ time, scene, description, location }]

  notes       String?
  safetyNotes String?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
  @@map("call_sheets")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Inventory / Consumables ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

enum StockMoveType {
  IN
  OUT
  ADJUST
}

model InventoryItem {
  id           String  @id @default(cuid())
  sku          String? @unique // optional stock code
  name         String
  category     String? // "Gels", "Tape", "Batteries", "Hardware", "Expendables"
  unit         String  @default("each") // each, roll, box, pack, metre, litre, set
  unitCost     Decimal @db.Decimal(15, 2) @default(0)
  quantity     Decimal @db.Decimal(15, 3) @default(0) // current on hand
  reorderLevel Decimal @db.Decimal(15, 3) @default(0) // low-stock threshold
  location     String? // store / shelf / bin
  supplierId   String?
  supplierName String?
  notes        String?
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movements StockMovement[]

  @@map("inventory_items")
}

model StockMovement {
  id     String        @id @default(cuid())
  itemId String
  item   InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  type         StockMoveType
  quantity     Decimal       @db.Decimal(15, 3) // always positive; type drives direction
  unitCost     Decimal?      @db.Decimal(15, 2)
  reference    String? // rental booking id / production project id / PO number
  reason       String? // "Consumed on shoot", "Stocktake", "Purchase"
  notes        String?
  balanceAfter Decimal       @db.Decimal(15, 3) @default(0)

  createdById  String?
  movementDate DateTime      @default(now())
  createdAt    DateTime      @default(now())

  @@index([itemId])
  @@map("stock_movements")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Accounting (General Ledger + Bank Reconciliation) ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

enum GlAccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum JournalStatus {
  DRAFT
  POSTED
  VOID
}

model GlAccount {
  id          String        @id @default(cuid())
  code        String        @unique // "1000", "4000"
  name        String
  type        GlAccountType
  subtype     String? // "Current Asset", "Cost of Sales", "Operating Expense"
  description String?
  isBank      Boolean       @default(false) // cash/bank accounts (reconcilable)
  isActive    Boolean       @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines       JournalLine[]
  bankAccount LedgerBankAccount?

  @@map("gl_accounts")
}

model JournalEntry {
  id          String        @id @default(cuid())
  entryNumber String        @unique // JE-2026-0001
  date        DateTime
  memo        String?
  reference   String?
  source      String        @default("MANUAL") // MANUAL | SYSTEM
  sourceType  String? // INVOICE | EXPENSE | PAYMENT (auto-posted)
  sourceId    String?
  status      JournalStatus @default(DRAFT)
  postedAt    DateTime?
  createdById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sourceType, sourceId])

  lines JournalLine[]

  @@map("journal_entries")
}

model JournalLine {
  id          String    @id @default(cuid())
  entryId     String
  entry       JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  accountId   String
  account     GlAccount @relation(fields: [accountId], references: [id])
  description String?
  debit       Decimal   @db.Decimal(15, 2) @default(0)
  credit      Decimal   @db.Decimal(15, 2) @default(0)
  sortOrder   Int       @default(0)

  // Bank reconciliation
  reconciled   Boolean   @default(false)
  reconciledAt DateTime?

  @@index([entryId])
  @@index([accountId])
  @@map("journal_lines")
}

model LedgerBankAccount {
  id            String    @id @default(cuid())
  name          String
  bankName      String?
  accountNumber String?
  currency      Currency  @default(AED)
  glAccountId   String    @unique
  glAccount     GlAccount @relation(fields: [glAccountId], references: [id])

  // Dedicated production account (reconciliation side) Гўв‚¬вЂќ pairs with BankAccount.projectId
  projectId String?
  project   ProductionProject? @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())

  reconciliations BankReconciliation[]

  @@map("ledger_bank_accounts")
}

model BankReconciliation {
  id               String      @id @default(cuid())
  bankAccountId    String
  bankAccount      LedgerBankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  statementDate    DateTime
  statementBalance Decimal     @db.Decimal(15, 2)
  clearedBalance   Decimal     @db.Decimal(15, 2) @default(0)
  status           String      @default("OPEN") // OPEN | COMPLETED
  completedAt      DateTime?

  createdAt DateTime @default(now())

  @@map("bank_reconciliations")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Approval Routing (multi-step) ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model ApprovalRequest {
  id          String         @id @default(cuid())
  entityType  String         // "EXPENSE"
  entityId    String
  title       String
  amount      Decimal        @db.Decimal(15, 2) @default(0)
  status      ApprovalStatus @default(PENDING)
  currentStep Int            @default(0)
  createdById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  steps ApprovalStep[]

  @@index([entityType, entityId])
  @@map("approval_requests")
}

model ApprovalStep {
  id        String          @id @default(cuid())
  requestId String
  request   ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  stepOrder    Int
  approverRole String         // expected approver (label)
  status       ApprovalStatus @default(PENDING)
  decidedById  String?
  decidedByName String?
  decidedAt    DateTime?
  comment      String?

  @@index([requestId])
  @@map("approval_steps")
}

model BudgetVersion {
  id          String              @id @default(cuid())
  projectId   String
  project     ProductionProject   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versionName String // "Budget V1", "Working Copy Гўв‚¬вЂќ June Update"
  status      BudgetVersionStatus @default(DRAFT)
  isActive    Boolean             @default(false)
  notes       String?
  lockedAt    DateTime?

  // Sequential lifecycle versioning (assigned when submitted for REVIEW: V1, V2 Гўв‚¬В¦)
  versionSequence Int @default(0)
  // Branching: a WORKING copy remembers which locked baseline it branched from
  parentVersionId String?
  parentVersion   BudgetVersion?  @relation("VersionBranching", fields: [parentVersionId], references: [id])
  childVersions   BudgetVersion[] @relation("VersionBranching")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  globals       BudgetGlobal[]
  sections      BudgetSection[]
  fringes       FringeProfile[]
  lifecycleLogs BudgetLifecycleLog[]

  @@map("budget_versions")
}

// Audit trail for every budget lifecycle status change (who, what role, when, why)
model BudgetLifecycleLog {
  id              String            @id @default(cuid())
  projectId       String
  project         ProductionProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  budgetVersionId String
  budgetVersion   BudgetVersion     @relation(fields: [budgetVersionId], references: [id], onDelete: Cascade)

  fromStatus      BudgetVersionStatus
  toStatus        BudgetVersionStatus
  versionNameSnap String // what the version was called at that moment (e.g. "Budget V3")

  changedById   String?
  changedByRole String? // project crew role (or system role) at time of change
  notes         String? // reason (e.g. "Client approved new BTL rebates")
  createdAt     DateTime @default(now())

  @@index([projectId])
  @@index([budgetVersionId])
  @@map("budget_lifecycle_logs")
}

model BudgetGlobal {
  id              String        @id @default(cuid())
  budgetVersionId String
  budgetVersion   BudgetVersion @relation(fields: [budgetVersionId], references: [id], onDelete: Cascade)
  key             String // "shoot_days", "prep_weeks"
  label           String // "Shoot Days", "Prep Weeks"
  value           Decimal       @db.Decimal(10, 3)
  unit            String? // "days", "weeks"

  @@unique([budgetVersionId, key])
  @@map("budget_globals")
}

model FringeProfile {
  id              String        @id @default(cuid())
  budgetVersionId String
  budgetVersion   BudgetVersion @relation(fields: [budgetVersionId], references: [id], onDelete: Cascade)
  name            String // "UAE Crew", "Freelance"
  percentage      Decimal       @db.Decimal(5, 2) // 18.00
  description     String?

  @@map("fringe_profiles")
}

model BudgetSection {
  id              String        @id @default(cuid())
  budgetVersionId String
  budgetVersion   BudgetVersion @relation(fields: [budgetVersionId], references: [id], onDelete: Cascade)
  code            String // "1000", "2000"
  title           String // "Above The Line", "Production"
  tier            String? // ATL | BTL | POST | OTHER (industry tiering)
  sortOrder       Int           @default(0)
  color           String? // optional color for UI

  accounts BudgetAccount[]

  @@map("budget_sections")
}

model BudgetAccount {
  id        String        @id @default(cuid())
  sectionId String
  section   BudgetSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  code      String // "1100", "2100"
  title     String // "Director", "Camera Department"
  sortOrder Int           @default(0)
  etcAmount Decimal?      @db.Decimal(15, 2) // manual Estimate-To-Complete override

  lineItems BudgetLineItem[]

  @@map("budget_accounts")
}

model BudgetLineItem {
  id        String        @id @default(cuid())
  accountId String
  account   BudgetAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  sortOrder Int           @default(0)

  code            String? // sub-account code e.g. "1210"
  subTitle        String? // sub-account title e.g. "LINE PRODUCER"
  description     String
  quantityFormula String? // e.g. "shoot_days + prep_days" Гўв‚¬вЂќ references globals
  quantity        Decimal @db.Decimal(10, 3) @default(1) // resolved value
  units           String? // "days", "weeks", "hours", "units", "lump"
  rate            Decimal @db.Decimal(15, 2) @default(0)

  // Multi-currency
  currency     Currency @default(AED)
  exchangeRate Decimal  @db.Decimal(10, 4) @default(1)

  // Fringe
  fringeProfileId String?
  fringePct       Decimal @db.Decimal(5, 2) @default(0)

  // Labor classification (links line to applicable union/statutory rate rules)
  classificationCode String? // e.g. "PERFORMER", "IATSE-LOCAL-600", "DIRECTOR"
  fringeDetail       Json?   // computed per-rule burden breakdown [{rateRuleId, rateType, label, amount}]

  // Cast performer link ГўвЂ вЂ™ auto-sets classificationCode 'PERFORMER' from the talent's union.
  castTalentId String?
  castTalent   GlobalTalentProfile? @relation("BudgetLineCastTalent", fields: [castTalentId], references: [id])

  // Labour stage breakdown (prep/shoot/wrap/post) Гўв‚¬вЂќ rate per stage from the crew card
  crewMemberId String? // link to Crew Directory (freelancer) for rate-card auto-fill + assignee
  stages       Json?   // [{ stage:'PREP'|'SHOOT'|'WRAP'|'POST', qty, unit, rate, amount }]

  // Provenance Гўв‚¬вЂќ where this line's numbers came from, and the original AI/import suggestion
  origin              LineItemOrigin @default(MANUAL)
  aiSuggestedRate     Decimal?       @db.Decimal(15, 2) // preserved when a human overrides
  aiSuggestedQuantity Decimal?       @db.Decimal(10, 3) // preserved when a human overrides

  // Computed totals (in project base currency)
  subtotal     Decimal @db.Decimal(15, 2) @default(0) // qty * rate / exchangeRate
  fringeAmount Decimal @db.Decimal(15, 2) @default(0) // subtotal * fringePct/100
  total        Decimal @db.Decimal(15, 2) @default(0) // subtotal + fringeAmount

  notes String?

  // SYS-13 D9 вЂ” prop в†’ draft budget line bridge (staged from a script TAG annotation)
  isDraft            Boolean @default(false)
  sourceAnnotationId String?

  contracts ProjectContract[]

  @@map("budget_line_items")
}

enum LineItemOrigin {
  MANUAL              // typed by a user
  AI_GENERATED        // produced by an AI assistant
  SCRIPT_IMPORT       // pulled from an imported script
  SCRIPT_TAG          // staged from a script prop/tag annotation (SYS-13 D9)
  AUTO_BREAKDOWN      // generated from the scene breakdown
  MANUAL_OVERRIDE     // started as AI/import, then a human changed it (original kept in aiSuggested* fields)
  MOVIE_MAGIC_IMPORT  // imported from a Movie Magic Budgeting (.mmb/.xml/.csv) file
}

model ProductionCrew {
  id        String            @id @default(cuid())
  projectId String
  project   ProductionProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name       String
  role       ProductionCrewRole @default(OTHER)
  department String? // film department (taxonomy)
  roleTitle  String? // specific job title within the department (free text)
  isInternal Boolean            @default(false)
  costTreatment String @default("PROJECT_HIRE") // PROJECT_HIRE (payable, cost on project) | COMPANY_OVERHEAD (not charged/paid on this project)

  // Driver licence (only when the person uses a production vehicle)
  productionVehicle    Boolean   @default(false)
  driverLicenseNumber  String?
  driverLicenseExpiry  DateTime?
  driverLicenseDocUrl  String?
  userId     String?
  email      String?
  mobile     String?

  // Link to Crew Directory (freelancer registry)
  crewMemberId String?
  crewMember   CrewMember? @relation(fields: [crewMemberId], references: [id])

  // Assignment details
  startDate DateTime?
  endDate   DateTime?
  location  String?

  dailyRate  Decimal? @db.Decimal(10, 2)
  weeklyRate Decimal? @db.Decimal(10, 2)
  totalDays  Int?
  totalPaid  Decimal? @db.Decimal(10, 2)
  notes      String?

  // Deal memo / contract tracking
  dealMemoStatus String  @default("NOT_SENT") // NOT_SENT | SENT | SIGNED
  ndaStatus      String  @default("NOT_REQUIRED") // NOT_REQUIRED | SENT | SIGNED
  dealMemoUrl    String?
  contractUrl    String?

  // SYS-07 V2 Slice 3 вЂ” identity docs + venue-share consent (for scout clearance packs)
  idShareConsent   Boolean   @default(false) // "OK to share my ID with venues/authorities"
  idShareConsentAt DateTime?
  passportUrl      String?
  passportExpiry   DateTime?
  emiratesIdUrl    String?
  emiratesIdExpiry DateTime?
  idPhotoUrl       String?   // headshot for the gate/security pass

  createdAt DateTime @default(now())

  perDiems PerDiem[]

  contracts ProjectContract[]

  @@map("production_crew")
}

model ProductionSchedule {
  id        String            @id @default(cuid())
  projectId String
  project   ProductionProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  dayNumber Int
  date      DateTime
  location  String?
  callTime  String?
  wrapTime  String?
  scenes    String?
  notes     String?

  @@map("production_schedules")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ Maintenance Vendors ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

enum VendorType {
  AUTO_WORKSHOP
