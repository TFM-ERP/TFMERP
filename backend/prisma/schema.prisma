  documentId    String
  document      ScriptDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  revisionLabel String         // "White" | "Blue" | "Pink" | "v3"вЂ¦
  colorCode     String?        // hex for the version chip
  pdfUrl        String         // /uploads/<file>
  pageCount     Int            @default(0)
  pageText      Json?          // [{ page, text }] captured at upload (anchor source)
