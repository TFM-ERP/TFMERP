// ГўвЂќв‚¬ГўвЂќв‚¬ Payroll timecards (cast/crew) ГўвЂ вЂ™ coded, fringed cost ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
model Timecard {
  id        String            @id @default(cuid())
  projectId String
  project   ProductionProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name               String
  role               String?
  classificationCode String? // drives fringes (PERFORMER / IATSE-CREW / Гўв‚¬В¦)
  accountCode        String? // budget cost center
  accountTitle       String?
  weekEnding         DateTime?

  days        Decimal @db.Decimal(8, 2) @default(0)
  dailyRate   Decimal @db.Decimal(12, 2) @default(0)
  otHours     Decimal @db.Decimal(8, 2) @default(0)
  otRate      Decimal @db.Decimal(12, 2) @default(0)
  boxRental   Decimal @db.Decimal(12, 2) @default(0)
  kitRental   Decimal @db.Decimal(12, 2) @default(0)
  perDiemDays Decimal @db.Decimal(8, 2) @default(0)
  perDiemRate Decimal @db.Decimal(12, 2) @default(0)
