  REQUESTED
  RESERVED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

// A physical property Гўв‚¬вЂќ hotel, apartment block, villa, crew camp, dormitory.
model AccommodationProperty {
  id   String            @id @default(cuid())
  name String
  type AccommodationType @default(HOTEL)

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  address        String?
  city           String?
  country        String? @default("United Arab Emirates")
  gpsCoordinates String?
  contactName    String?
  contactPhone   String?
  contactEmail   String?
  notes          String?
  isActive       Boolean @default(true)

  rooms       RoomInventory[]
  assignments AccommodationAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@map("accommodation_properties")
}

// A room / unit / bed within a property.
model RoomInventory {
  id         String                @id @default(cuid())
  propertyId String
  property   AccommodationProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  roomNumber  String
  type        RoomType   @default(SINGLE)
  capacity    Int        @default(1)
  nightlyRate Decimal?   @db.Decimal(12, 2)
  currency    Currency   @default(AED)
  status      RoomStatus @default(AVAILABLE)
  notes       String?

  assignments AccommodationAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId])
  @@map("room_inventory")
}

// Puts a person (TravelerProfile Гўв‚¬вЂќ the universal identity) into a room/property.
model AccommodationAssignment {
  id         String          @id @default(cuid())
  travelerId String
  traveler   TravelerProfile @relation(fields: [travelerId], references: [id], onDelete: Cascade)

  propertyId String?
  property   AccommodationProperty? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  roomId     String?
  room       RoomInventory?         @relation(fields: [roomId], references: [id], onDelete: SetNull)

  projectId String?
  project   ProductionProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Link back to the trip-bound hotel booking when the stay came from Travel.
  hotelBookingId String?       @unique
  hotelBooking   HotelBooking? @relation(fields: [hotelBookingId], references: [id], onDelete: SetNull)

  accommodationClass AccommodationClass  @default(STANDARD)
  status             AccommodationStatus @default(RESERVED)
  checkIn            DateTime?
  checkOut           DateTime?
  notes              String?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
  @@index([travelerId])
  @@map("accommodation_assignments")
}

