model ContractTemplate {
  id          String       @id @default(cuid())
  name        String
  type        ContractType @default(OTHER)
  description String?
  language    String       @default("en")
  version     Int          @default(1)
  isActive    Boolean      @default(true)

  bodyMarkdown String

  variables    Json?
  governingLaw String?
  jurisdiction String?

  clauses          ClauseTemplate[]
  projectContracts ProjectContract[]

  createdById String?
  createdBy   User?    @relation("ContractTemplateCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type, isActive])
  @@map("contract_templates")
}

model ClauseTemplate {
  id           String  @id @default(cuid())
  code         String  @unique
  title        String
  category     String?
  bodyMarkdown String
  language     String  @default("en")
  version      Int     @default(1)
  isMandatory  Boolean @default(false)
  riskLevel    String?
  isActive     Boolean @default(true)

  templateId String?
  template   ContractTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  orderIndex Int               @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, isActive])
  @@map("clause_templates")
}

model ProjectContract {
  id             String                @id @default(cuid())
  contractNumber String                @unique
  title          String
  type           ContractType          @default(OTHER)
  status         ProjectContractStatus @default(DRAFT)
  language       String                @default("en")

  // Nullable ГўвЂ вЂ™ standalone contracts (no project) post to the House/Corporate ledger.
  projectId String?
  project   ProductionProject? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  templateId String?
  template   ContractTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  budgetLineItemId String?
  budgetLineItem   BudgetLineItem? @relation(fields: [budgetLineItemId], references: [id], onDelete: SetNull)

  productionCrewId String?
  productionCrew   ProductionCrew? @relation(fields: [productionCrewId], references: [id], onDelete: SetNull)

  bodyMarkdown   String?
  resolvedVars   Json?
  rateSnapshotId String?
  dailyRate      Decimal? @db.Decimal(14, 2)

  contractValue Decimal?  @db.Decimal(16, 2)
  currency      Currency  @default(AED)
  startDate     DateTime?
  endDate       DateTime?
  effectiveDate DateTime?
  expiryDate    DateTime?
  signedAt      DateTime?

  esignProvider   String?
  esignEnvelopeId String? @unique

  purchaseOrderId String?        @unique
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)

  workflowInstanceId String?

  parties   ContractParty[]
  auditLogs SignatureAuditLog[]

  createdById String?
  createdBy   User?    @relation("ProjectContractCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId, status])
  @@index([budgetLineItemId])
  @@index([productionCrewId])
  @@map("project_contracts")
}

model ContractParty {
  id         String          @id @default(cuid())
  contractId String
  contract   ProjectContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  role         ContractPartyRole @default(OTHER)
  name         String
  email        String?
  organization String?
  title        String?

  signerOrder     Int             @default(1)
  signatureStatus SignatureStatus @default(PENDING)
  signatureMethod SignatureMethod @default(ESIGN)
  signedAt        DateTime?
  ipAddress       String?

  userId String?
  user   User?   @relation("ContractPartyUser", fields: [userId], references: [id])

  auditLogs SignatureAuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contractId, signerOrder])
  @@map("contract_parties")
}

model SignatureAuditLog {
  id         String          @id @default(cuid())
  contractId String
  contract   ProjectContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  partyId String?
  party   ContractParty? @relation(fields: [partyId], references: [id], onDelete: SetNull)

  event           SignatureEvent
  method          SignatureMethod?
  actorName       String?
  actorEmail      String?
  ipAddress       String?
  userAgent       String?
  documentHash    String?
  providerEventId String?
  metadata        Json?

  createdAt DateTime @default(now())

  @@index([contractId, createdAt])
  @@map("signature_audit_logs")
}

