// ── Preventive maintenance ───────────────────────────────────────────────────
model MaintenancePlan {
  id            String   @id @default(cuid())
  assetId       String
  asset         Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  taskName      String
  intervalDays  Int?
  intervalKm    Int?
  intervalHours Int?
  lastServiceDate     DateTime?
  lastServiceOdometer Int?
  lastServiceHours    Int?
  notes         String?
  isActive      Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("maintenance_plans")
}

// ── Delivery / return condition inspections ──────────────────────────────────
model ConditionReport {
  id            String        @id @default(cuid())
  bookingId     String
  booking       RentalBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  assetId       String?
  asset         Asset?        @relation(fields: [assetId], references: [id])
  type          String        // DELIVERY | RETURN
  inspectedAt   DateTime      @default(now())
  inspectedBy   String?
  odometer      Int?
  fuelLevel     String?
  checklist     Json?         // [{ item, ok, note }]
  damageNotes   String?
  photos        String[]
  signatureName String?
  notes         String?
  createdAt DateTime @default(now())

  @@map("condition_reports")
}

// ── Role-based access control ────────────────────────────────────────────────
// One row per (role, module) with an access level: 0 none · 1 view · 2 edit · 3 manage
model RolePermission {
  id     String   @id @default(cuid())
  role   UserRole
  module String
  level  Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([role, module])
  @@map("role_permissions")
}

// ── Collections: dunning / reminder audit log ────────────────────────────────
model ReminderLog {
  id        String   @id @default(cuid())
  invoiceId String
  clientId  String?
  level     String   // rule level key, e.g. BEFORE_DUE / DUE / OVERDUE_7 / MANUAL
  channel   String   @default("email")
  to        String?
  subject   String?
  status    String   @default("SENT") // SENT | FAILED
  error     String?
  sentById  String?
  sentAt    DateTime @default(now())

  @@index([invoiceId])
  @@map("reminder_logs")
}

// ── CRM: leads & sales pipeline ──────────────────────────────────────────────
model Lead {
  id             String   @id @default(cuid())
  companyName    String?
  contactName    String?
  email          String?
  phone          String?
  source         String?  // Referral | Website | Walk-in | Repeat | Other
  status         String   @default("NEW") // NEW | CONTACTED | QUALIFIED | CONVERTED | LOST
  estimatedValue Decimal? @db.Decimal(15,